@model QLTB.Models.BGHDashboardViewModel
@{
    ViewBag.Title = "Dashboard BGH";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    /* 1. XÓA BỎ CÁC PHẦN TRÙNG LẶP CỦA HỆ THỐNG CŨ */
    /* Bạn thay các selector dưới đây bằng ID hoặc Class thực tế của Layout cũ nế nó không ẩn */
    .sidebar, .main-sidebar, .navbar-static-top, .main-header, .top-nav-old, #sidebar-wrapper {
        display: none !important;
    }

    /* Đảm bảo nội dung không bị đẩy lùi vào trong do Sidebar cũ */
    body, .content-wrapper, #page-content-wrapper {
        margin: 0 !important;
        padding: 0 !important;
        background-color: #F0F4F8 !important; /* Màu nền xanh xám nhạt */
    }

    :root {
        --ip-blue: #D1E4F3; /* Màu xanh iPhone 15 */
        --ip-blue-dark: #7EA1BB;
        --text-color: #2C3E50;
    }

    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        color: var(--text-color);
        padding-top: 80px;
    }

    /* 2. THANH ĐIỀU HƯỚNG DUY NHẤT (TOP NAV) */
    .modern-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(15px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 40px;
        z-index: 9999;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }

    .nav-left {
        font-weight: 700;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .nav-center {
        display: flex;
        background: #f1f3f5;
        padding: 5px;
        border-radius: 15px;
        gap: 5px;
    }

    .nav-item {
        padding: 8px 20px;
        border-radius: 12px;
        text-decoration: none !important;
        color: var(--text-color);
        font-size: 0.9rem;
        font-weight: 500;
        transition: 0.3s;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.6);
        }

        .nav-item.active {
            background: white;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            color: var(--ip-blue-dark);
        }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    /* 3. NỘI DUNG CHÍNH */
    .dashboard-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .welcome-banner {
        background: var(--ip-blue);
        border-radius: 30px;
        padding: 40px;
        margin-bottom: 30px;
        border: 1px solid rgba(255,255,255,0.4);
    }

        .welcome-banner h1 {
            font-weight: 700;
            margin-bottom: 5px;
        }

    /* Cards Thống kê */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        padding: 25px;
        border-radius: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        transition: 0.3s;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-card .val {
            font-size: 2.2rem;
            font-weight: 800;
            display: block;
        }

        .stat-card .label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #95A5A6;
            text-transform: uppercase;
        }

    /* Cards Chức năng */
    .action-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .action-card {
        background: white;
        padding: 30px;
        border-radius: 30px;
        text-align: center;
        text-decoration: none !important;
        color: var(--text-color);
        transition: 0.3s;
        border: 1px solid transparent;
    }

        .action-card:hover {
            border-color: var(--ip-blue);
            background: #fafbfc;
        }

        .action-card i {
            font-size: 2.5rem;
            margin-bottom: 15px;
            display: block;
            color: var(--ip-blue-dark);
        }

    .logout-link {
        color: #e74c3c;
        text-decoration: none;
        font-size: 1.2rem;
    }
</style>

<nav class="modern-nav">
    <div class="nav-left">
        <i class="bi bi-apple"></i>
        <span>HỆ THỐNG QUẢN LÝ</span>
    </div>

    <div class="nav-center">
        <a href="#" class="nav-item">Trang chủ</a>
        <a href="#" class="nav-item active">Dashboard</a>
        <a href="@Url.Action("XetDuyetYeuCau","BGH")" class="nav-item">Xét duyệt</a>
        <a href="@Url.Action("ThongKeTaiSan","BGH")" class="nav-item">Thống kê</a>
        <a href="@Url.Action("TheoDoi","BGH")" class="nav-item">Theo dõi</a>
    </div>

    <div class="nav-right">
        <div class="position-relative">
            <i class="bi bi-bell fs-5"></i>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.5rem;">3</span>
        </div>
        <span class="fw-bold small">Ban Giám Hiệu</span>
        <a href="@Url.Action("Logout","Account")" class="logout-link" title="Đăng xuất"><i class="bi bi-box-arrow-right"></i></a>
    </div>
</nav>

<div class="dashboard-container">
    <div class="welcome-banner">
        <div class="row align-items-center">
            <div class="col-md-9">
                <h1>Xin chào, Đại diện BGH</h1>
                <p class="mb-0 opacity-75">Hôm nay là @DateTime.Now.ToString("dddd, dd/MM/yyyy")</p>
            </div>
            <div class="col-md-3 text-end">
                <div class="bg-white d-inline-block px-4 py-2 rounded-pill shadow-sm">
                    <strong>@DateTime.Now.ToString("HH:mm")</strong>
                </div>
            </div>
        </div>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <span class="label text-primary">Tổng thiết bị</span>
            <span class="val text-primary">@Model.TongThietBi</span>
        </div>
        <div class="stat-card">
            <span class="label text-success">Hoạt động</span>
            <span class="val text-success">@Model.HoatDong</span>
        </div>
        <div class="stat-card">
            <span class="label text-warning">Bảo trì</span>
            <span class="val text-warning">@Model.BaoTri</span>
        </div>
        <div class="stat-card">
            <span class="label text-danger">Hỏng</span>
            <span class="val text-danger">@Model.Hong</span>
        </div>
    </div>

    <div class="action-grid">
        <a href="@Url.Action("XetDuyetYeuCau","BGH")" class="action-card shadow-sm">
            <i class="bi bi-file-earmark-check"></i>
            <h5 class="fw-bold">Xét duyệt</h5>
            <p class="small text-muted mb-0">@Model.ChoDeXuatDuyet yêu cầu chờ duyệt</p>
        </a>
        <a href="@Url.Action("ThongKeTaiSan","BGH")" class="action-card shadow-sm">
            <i class="bi bi-bar-chart-line"></i>
            <h5 class="fw-bold">Thống kê</h5>
            <p class="small text-muted mb-0">Dữ liệu tài sản toàn trường</p>
        </a>
        <a href="@Url.Action("TheoDoi","BGH")" class="action-card shadow-sm">
            <i class="bi bi-search"></i>
            <h5 class="fw-bold">Theo dõi</h5>
            <p class="small text-muted mb-0">Tình trạng thiết bị thời gian thực</p>
        </a>
    </div>
</div>