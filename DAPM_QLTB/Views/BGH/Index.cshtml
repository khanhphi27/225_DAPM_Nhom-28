@model QLTB.Models.BGHDashboardViewModel
@{
    ViewBag.Title = "Dashboard BGH";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Hệ Thống Quản Lý - Ban Giám Hiệu</h2>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-3">
                <p class="text-muted small mb-1">Tổng thiết bị</p>
                <h3 class="text-primary fw-bold">@Model.TongThietBi</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-3">
                <p class="text-muted small mb-1">Hoạt động</p>
                <h3 class="text-success fw-bold">@Model.HoatDong</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-3">
                <p class="text-muted small mb-1">Bảo trì</p>
                <h3 class="text-warning fw-bold">@Model.BaoTri</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-3">
                <p class="text-muted small mb-1">Hỏng</p>
                <h3 class="text-danger fw-bold">@Model.Hong</h3>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow border-0 text-center p-4">
                <i class="bi bi-file-earmark-check fs-1 text-primary mb-3"></i>
                <a href="@Url.Action("XetDuyetYeuCau","BGH")" class="btn btn-outline-primary btn-lg">Xét Duyệt Yêu Cầu</a>
                <p class="text-muted small mt-2 mb-0">@Model.ChoDeXuatDuyet yêu cầu chờ duyệt</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow border-0 text-center p-4">
                <i class="bi bi-bar-chart-line fs-1 text-success mb-3"></i>
                <a href="@Url.Action("ThongKeTaiSan","BGH")" class="btn btn-outline-success btn-lg">Thống Kê Tài Sản</a>
                <p class="text-muted small mt-2 mb-0">Dữ liệu tài sản toàn trường</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow border-0 text-center p-4">
                <i class="bi bi-search fs-1 text-danger mb-3"></i>
                <a href="@Url.Action("TheoDoi","BGH")" class="btn btn-outline-danger btn-lg">Theo Dõi Thiết Bị</a>
                <p class="text-muted small mt-2 mb-0">Tình trạng thiết bị thời gian thực</p>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
