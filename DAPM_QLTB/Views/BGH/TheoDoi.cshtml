@{
    ViewBag.Title = "Theo Dõi Tình Trạng Thiết Bị";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canChuY = ViewBag.CanChuY as List<QLTB.Models.TheDoiThietBiViewModel> ?? new List<QLTB.Models.TheDoiThietBiViewModel>();
    var hoatDong = ViewBag.HoatDong as List<QLTB.Models.TheDoiThietBiViewModel> ?? new List<QLTB.Models.TheDoiThietBiViewModel>();
    int baoTri = canChuY.FindAll(x => x.TrangThaiTB == "Bảo trì").Count;
    int hong = canChuY.FindAll(x => x.TrangThaiTB == "Hỏng").Count;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">🔍 Theo Dõi Tình Trạng Thiết Bị</h2>
            <small class="text-muted">Cập nhật lúc: @DateTime.Now.ToString("HH:mm dd/MM/yyyy")</small>
        </div>
        <a href="@Url.Action("Index","BGH")" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-chevron-left"></i> Quay lại
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-warning">⚠️ @ViewBag.Error</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">Hoạt động tốt</p>
                <h3 class="text-success fw-bold">@hoatDong.Count</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">Đang bảo trì</p>
                <h3 class="text-warning fw-bold">@baoTri</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">Hỏng / Chờ xử lý</p>
                <h3 class="text-danger fw-bold">@hong</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">Cần chú ý</p>
                <h3 class="text-primary fw-bold">@canChuY.Count</h3>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 pt-3">
            <h5 class="fw-bold text-danger mb-0">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>Thiết Bị Cần Chú Ý (@canChuY.Count)
            </h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã TB</th>
                            <th>Tên thiết bị</th>
                            <th>Khoa / Vị trí</th>
                            <th>Phòng</th>
                            <th>Tình trạng</th>
                            <th>Ngày báo</th>
                            <th>Mô tả hỏng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!canChuY.Any())
                        {
                            <tr><td colspan="7" class="text-center py-4 text-muted">Mọi thứ đều ổn định 🎉</td></tr>
                        }
                        else
                        {
                            foreach (var tb in canChuY)
                            {
                                <tr>
                                    <td class="fw-bold text-primary">#@tb.ID_ThietBi</td>
                                    <td class="fw-semibold">@tb.TenTB</td>
                                    <td><span class="badge bg-light text-dark">@tb.KhoaPhongBan</span></td>
                                    <td>@(string.IsNullOrEmpty(tb.Phong) ? "—" : tb.Phong)</td>
                                    <td>
                                        @if (tb.TrangThaiTB == "Hỏng")
                                        {
                                            <span class="badge bg-danger">@tb.TrangThaiTB</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">@tb.TrangThaiTB</span>
                                        }
                                    </td>
                                    <td class="text-muted">@(tb.NgayBaoHong.HasValue ? tb.NgayBaoHong.Value.ToString("dd/MM/yyyy") : "—")</td>
                                    <td class="small">@(string.IsNullOrEmpty(tb.MoTaHong) ? "—" : tb.MoTaHong)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3">
            <h5 class="fw-bold text-success mb-0">
                <i class="bi bi-check-circle-fill me-2"></i>Hoạt Động Bình Thường (@hoatDong.Count)
            </h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã TB</th>
                            <th>Tên thiết bị</th>
                            <th>Khoa / Đơn vị</th>
                            <th>Phòng</th>
                            <th>Danh mục</th>
                            <th>Nhà cung cấp</th>
                            <th class="text-end">Tình trạng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tb in hoatDong)
                        {
                            <tr>
                                <td class="fw-bold">#@tb.ID_ThietBi</td>
                                <td>@tb.TenTB</td>
                                <td>@tb.KhoaPhongBan</td>
                                <td>@(string.IsNullOrEmpty(tb.Phong) ? "—" : tb.Phong)</td>
                                <td class="text-muted small">@tb.TenDanhMuc</td>
                                <td class="small">@(string.IsNullOrEmpty(tb.NhaCungCap) ? "—" : tb.NhaCungCap)</td>
                                <td class="text-end"><span class="badge bg-success">✅ Tốt</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
