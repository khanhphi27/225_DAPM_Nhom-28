@model QLTB.Models.ThongKeTaiSanViewModel
@{
    ViewBag.Title = "Thống Kê Tài Sản";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int maxSL = Model.TheoDanhMuc != null && Model.TheoDanhMuc.Count > 0 ? Model.TheoDanhMuc[0].SoLuong : 1;
    int tong = Model.TongThietBi > 0 ? Model.TongThietBi : 1;
    int pHD = (int)Math.Round((double)Model.HoatDong / tong * 100);
    int pBT = (int)Math.Round((double)Model.BaoTri / tong * 100);
    int pH  = (int)Math.Round((double)Model.Hong / tong * 100);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">📊 Thống Kê Tài Sản</h2>
        <a href="@Url.Action("Index","BGH")" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-chevron-left"></i> Quay lại
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">📦 Tổng thiết bị</p>
                <h3 class="text-primary fw-bold">@Model.TongThietBi</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">💰 Tổng giá trị (VNĐ)</p>
                <h5 class="text-success fw-bold">@Model.TongGiaTri.ToString("N0")</h5>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">🏫 Số khoa / đơn vị</p>
                <h3 class="text-info fw-bold">@(Model.TheoKhoa?.Count ?? 0)</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">📅 Lần kiểm kê</p>
                <h3 class="text-warning fw-bold">@(Model.LichSuKiemKe?.Count ?? 0)</h3>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-4">📈 Tình Trạng Hiện Tại</h5>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1"><span>Đang hoạt động tốt</span><span>@pHD%</span></div>
                        <div class="progress" style="height:10px"><div class="progress-bar bg-success" style="width:@pHD%"></div></div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1"><span>Đang bảo trì</span><span>@pBT%</span></div>
                        <div class="progress" style="height:10px"><div class="progress-bar bg-warning" style="width:@pBT%"></div></div>
                    </div>
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-1"><span>Hỏng / Thanh lý</span><span>@pH%</span></div>
                        <div class="progress" style="height:10px"><div class="progress-bar bg-danger" style="width:@pH%"></div></div>
                    </div>

                    <hr />
                    <h6 class="fw-bold mb-3">📂 Phân loại theo Danh mục</h6>
                    @foreach (var dm in Model.TheoDanhMuc)
                    {
                        int pct = (int)Math.Round((double)dm.SoLuong / maxSL * 100);
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1"><span class="small">@dm.TenDanhMuc</span><span class="small fw-bold">@dm.SoLuong</span></div>
                            <div class="progress" style="height:6px"><div class="progress-bar bg-primary" style="width:@pct%"></div></div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-4">🏫 Thống Kê Chi Tiết Đơn Vị</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Đơn vị</th>
                                    <th class="text-center">Tổng</th>
                                    <th class="text-center text-success">Tốt</th>
                                    <th class="text-center text-danger">Hỏng</th>
                                    <th>Giá trị</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var k in Model.TheoKhoa)
                                {
                                    <tr>
                                        <td class="fw-semibold">@k.TenKhoa</td>
                                        <td class="text-center">@k.Tong</td>
                                        <td class="text-center fw-bold text-success">@k.HoatDong</td>
                                        <td class="text-center text-danger">@k.Hong</td>
                                        <td class="small">@k.TongGia.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0">📅 Lịch Sử Kiểm Kê Tài Sản</h5>
            <span class="badge bg-light text-dark">Dữ liệu lưu trữ</span>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã KK</th>
                            <th>Ngày thực hiện</th>
                            <th>Người phụ trách</th>
                            <th>Số lượng TB</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kk in Model.LichSuKiemKe)
                        {
                            <tr>
                                <td class="fw-bold text-primary">#@kk.ID_KiemKe</td>
                                <td>@kk.NgayKiemKe.ToString("dd/MM/yyyy")</td>
                                <td>@kk.NguoiThucHien</td>
                                <td class="fw-bold">@kk.TongThietBiKK</td>
                                <td>
                                    @if (kk.TrangThai == "Hoàn thành")
                                    {
                                        <span class="badge bg-success">@kk.TrangThai</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">@kk.TrangThai</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
