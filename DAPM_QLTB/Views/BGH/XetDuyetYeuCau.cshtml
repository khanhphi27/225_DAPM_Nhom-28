@{
    ViewBag.Title = "Xét Duyệt Yêu Cầu Lần Cuối";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var choDuyet = ViewBag.ChoDuyet as List<QLTB.Models.DeXuatViewModel> ?? new List<QLTB.Models.DeXuatViewModel>();
    var lichSu = ViewBag.LichSu as List<QLTB.Models.DeXuatViewModel> ?? new List<QLTB.Models.DeXuatViewModel>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">✅ Xét Duyệt Yêu Cầu</h2>
        <a href="@Url.Action("Index","BGH")" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-chevron-left"></i> Quay lại
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-warning">⚠️ @ViewBag.Error</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">⏳ Chờ duyệt</p>
                <h3 class="text-warning fw-bold">@choDuyet.Count</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">✅ Đã duyệt</p>
                <h3 class="text-success fw-bold">@lichSu.FindAll(x => x.TrangThai == "Đã duyệt").Count</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">❌ Từ chối</p>
                <h3 class="text-danger fw-bold">@lichSu.FindAll(x => x.TrangThai.Contains("Từ chối")).Count</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <p class="text-muted small mb-1">📋 Tổng cộng</p>
                <h3 class="text-primary fw-bold">@(choDuyet.Count + lichSu.Count)</h3>
            </div>
        </div>
    </div>

    <div class="card shadow border-0 mb-4">
        <div class="card-header bg-white border-0 pt-3">
            <h5 class="fw-bold text-warning mb-0"><i class="bi bi-clock-history me-2"></i>Danh Sách Chờ Phê Duyệt</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã ĐX</th>
                            <th>Nội dung</th>
                            <th>Đơn vị</th>
                            <th>Ngân sách</th>
                            <th>Ngày gửi</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!choDuyet.Any())
                        {
                            <tr><td colspan="6" class="text-center py-4 text-muted">Hiện tại không có yêu cầu nào cần xử lý.</td></tr>
                        }
                        else
                        {
                            foreach (var dx in choDuyet)
                            {
                                <tr>
                                    <td class="fw-bold text-primary">#@dx.ID_DeXuat</td>
                                    <td>@dx.MoTa</td>
                                    <td><span class="badge bg-light text-dark">@dx.KhoaPhongBan</span></td>
                                    <td class="fw-bold">@dx.TongGiaDuKien.ToString("N0") đ</td>
                                    <td class="text-muted">@dx.NgayDeXuat.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-success me-1" onclick="showModal('@dx.ID_DeXuat','@dx.MoTa','duyet')">Duyệt</button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="showModal('@dx.ID_DeXuat','@dx.MoTa','tuchoi')">Từ chối</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-white border-0 pt-3">
            <h5 class="fw-bold text-primary mb-0"><i class="bi bi-journal-check me-2"></i>Lịch Sử Đã Xử Lý</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã ĐX</th>
                            <th>Nội dung</th>
                            <th>Ngân sách</th>
                            <th>Kết quả</th>
                            <th>Ngày xử lý</th>
                            <th>Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dx in lichSu)
                        {
                            <tr>
                                <td class="fw-bold">#@dx.ID_DeXuat</td>
                                <td>@dx.MoTa <br><small class="text-muted">@dx.KhoaPhongBan</small></td>
                                <td class="small">@dx.TongGiaDuKien.ToString("N0")</td>
                                <td>
                                    @if (dx.TrangThai == "Đã duyệt")
                                    {
                                        <span class="badge bg-success">@dx.TrangThai</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@dx.TrangThai</span>
                                    }
                                </td>
                                <td class="text-muted small">@dx.NgayDeXuat.ToString("dd/MM/yyyy")</td>
                                <td class="small text-muted">@(string.IsNullOrEmpty(dx.LyDoTuChoi) ? "—" : dx.LyDoTuChoi)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal xác nhận -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="fw-bold" id="modalTitle">Xác nhận</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="modalBody" class="mb-3"></p>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Ghi chú hoặc lý do:</label>
                    <textarea class="form-control" id="modalNote" rows="3" placeholder="Nhập tại đây..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="modalConfirmBtn" onclick="confirmAction()">Xác nhận</button>
            </div>
        </div>
    </div>
</div>

<div class="position-fixed bottom-0 end-0 p-4" style="z-index:9999">
    <div id="toastMsg" class="toast align-items-center text-white border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body fw-bold" id="toastText"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section scripts {
<script>
    var currentId = '', currentAction = '';

    function showModal(id, name, action) {
        currentId = id; currentAction = action;
        var btn = document.getElementById('modalConfirmBtn');
        var title = document.getElementById('modalTitle');
        if (action === 'duyet') {
            title.innerHTML = '<i class="bi bi-check-circle-fill text-success me-2"></i>Phê Duyệt Đề Xuất';
            document.getElementById('modalBody').innerHTML = 'Bạn chắc chắn muốn phê duyệt đề xuất <b>#' + id + '</b>?';
            btn.className = 'btn btn-success'; btn.textContent = 'Xác nhận Duyệt';
        } else {
            title.innerHTML = '<i class="bi bi-x-circle-fill text-danger me-2"></i>Từ Chối Đề Xuất';
            document.getElementById('modalBody').innerHTML = 'Xác nhận từ chối đề xuất <b>#' + id + '</b>?';
            btn.className = 'btn btn-danger'; btn.textContent = 'Xác nhận Từ chối';
        }
        new bootstrap.Modal(document.getElementById('confirmModal')).show();
    }

    function confirmAction() {
        var note = document.getElementById('modalNote').value;
        bootstrap.Modal.getInstance(document.getElementById('confirmModal')).hide();
        $.post('@Url.Action("DuyetDeXuat","BGH")',
            { id: currentId, action: currentAction, ghiChu: note },
            function (res) {
                if (res.ok) {
                    showToast(currentAction === 'duyet' ? '✅ Đã phê duyệt thành công!' : '❌ Đã từ chối đề xuất!',
                        currentAction === 'duyet' ? 'success' : 'danger');
                    setTimeout(function () { location.reload(); }, 1200);
                } else {
                    showToast('⚠️ Lỗi: ' + (res.msg || 'Không xác định'), 'warning');
                }
            });
    }

    function showToast(msg, type) {
        var el = document.getElementById('toastMsg');
        el.className = 'toast align-items-center text-white border-0 bg-' + type;
        document.getElementById('toastText').textContent = msg;
        new bootstrap.Toast(el, { delay: 3000 }).show();
    }
</script>
}
