<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Quản Lý Thiết Bị SPKT</title>
    @Styles.Render("~/Content/css")
    <link href="~/Content/Site.css" rel="stylesheet" />
    @RenderSection("styles", required: false)
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    @{
        int role = Session["UserRole"] != null ? (int)Session["UserRole"] : 0;
        string[] roleNames  = { "", "Trưởng Khoa", "Phòng CSVC", "Phòng KHTC", "BGH" };
        string   roleName   = role > 0 && role <= 4 ? roleNames[role] : "Người dùng";
    }

    <!-- Navbar -->
    <nav class="navbar navbar-expand-md navbar-dark">
        <div class="container-fluid px-3">
            <a class="navbar-brand text-white" href="@Url.Action("Index", "Home")">
                🏫 QLTB - ĐH SPKT
            </a>
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">🏠 Trang chủ</a>
                    </li>
                    @if (role == 1)
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("DanhSachThietBi", "TruongKhoa")">📦 Thiết bị</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("DeXuatMuaSam", "TruongKhoa")">📋 Đề xuất</a></li>
                    }
                    @if (role == 2)
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("QuanLyThietBi", "CSVC")">📦 Thiết bị</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("PheDuyetDeXuat", "CSVC")">📋 Phê duyệt</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("LapKeHoachBaoTri", "CSVC")">🔧 Bảo trì</a></li>
                    }
                    @if (role == 3)
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "KHTC")">💰 Kinh phí</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("PheDuyetNganSach", "KHTC")">📋 Phê duyệt NS</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("BaoCaoTaiSan", "KHTC")">📊 Báo cáo</a></li>
                    }
                    @if (role == 4)
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "BGH")">📊 Báo cáo</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("XetDuyetYeuCau", "BGH")">✅ Xét duyệt</a></li>
                    }
                </ul>

                @if (Session["UserName"] != null)
                {
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item me-2">
                            <a class="nav-link" href="@Url.Action("Notifications", "Account")" title="Thông báo">
                                🔔<span class="badge-notify">3</span>
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#"
                               id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                👤 @Session["UserName"]
                                <span class="badge bg-warning text-dark role-badge">@roleName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Profile", "Account")">
                                        👤 Thông tin cá nhân
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")">
                                        🚪 Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                }
                else
                {
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login", "Account")">🔐 Đăng nhập</a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <!-- Body -->
    <div class="container-fluid">
        <div class="row">
            @if (Session["UserName"] != null)
            {
                <!-- Sidebar -->
                <div class="col-md-2 d-none d-md-block sidebar p-0">
                    <nav class="nav flex-column pt-2">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">🏠 Trang chủ</a>
                        @if (role == 1)
                        {
                            <a class="nav-link" href="@Url.Action("DanhSachThietBi", "TruongKhoa")">📦 Quản lý thiết bị</a>
                            <a class="nav-link" href="@Url.Action("DeXuatMuaSam", "TruongKhoa")">📋 Đề xuất mua sắm</a>
                        }
                        @if (role == 2)
                        {
                            <a class="nav-link" href="@Url.Action("QuanLyThietBi", "CSVC")">📦 Quản lý thiết bị</a>
                            <a class="nav-link" href="@Url.Action("PheDuyetDeXuat", "CSVC")">📋 Phê duyệt đề xuất</a>
                            <a class="nav-link" href="@Url.Action("LapKeHoachBaoTri", "CSVC")">🔧 Bảo trì / Sửa chữa</a>
                            <a class="nav-link" href="@Url.Action("GhiNhanSuaChua", "CSVC")">📤 Ghi nhận sửa chữa</a>
                            <a class="nav-link" href="@Url.Action("KiemKeTaiSan", "CSVC")">📋 Kiểm kê tài sản</a>
                        }
                        @if (role == 3)
                        {
                            <a class="nav-link" href="@Url.Action("Index", "KHTC")">💰 Dashboard KHTC</a>
                            <a class="nav-link" href="@Url.Action("PheDuyetNganSach", "KHTC")">📋 Phê duyệt ngân sách</a>
                            <a class="nav-link" href="@Url.Action("BaoCaoTaiSan", "KHTC")">📊 Báo cáo tài sản</a>
                            <a class="nav-link" href="@Url.Action("QuanLyChiPhi", "KHTC")">💵 Quản lý chi phí</a>
                        }
                        @if (role == 4)
                        {
                            <a class="nav-link" href="@Url.Action("Index", "BGH")">📊 Dashboard BGH</a>
                            <a class="nav-link" href="@Url.Action("XetDuyetYeuCau", "BGH")">✅ Xét duyệt yêu cầu</a>
                            <a class="nav-link" href="@Url.Action("ThongKeTaiSan", "BGH")">📈 Thống kê tài sản</a>
                            <a class="nav-link" href="@Url.Action("TheoDoi", "BGH")">👁 Theo dõi thiết bị</a>
                        }
                        <hr style="margin: 8px 16px;" />
                        <a class="nav-link" href="@Url.Action("Notifications", "Account")">
                            🔔 Thông báo <span class="badge bg-danger ms-1">3</span>
                        </a>
                        <a class="nav-link" href="@Url.Action("Profile", "Account")">👤 Thông tin cá nhân</a>
                        <a class="nav-link text-danger" href="@Url.Action("Logout", "Account")">🚪 Đăng xuất</a>
                    </nav>
                </div>
                <div class="col-md-10 main-content">
                    @RenderBody()
                </div>
            }
            else
            {
                <div class="col-12">
                    @RenderBody()
                </div>
            }
        </div>
    </div>

    <footer class="text-center">
        <p class="mb-0">© @DateTime.Now.Year Hệ Thống Quản Lý Thiết Bị - Trường ĐH Sư Phạm Kỹ Thuật</p>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
