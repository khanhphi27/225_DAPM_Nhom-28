<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - QLTB SPKT</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    @Styles.Render("~/Content/css")
    @RenderSection("styles", required: false)

    <style>
        :root {
            --primary-color: #4e73df;
            --sidebar-bg: #ffffff;
            --main-bg: #f8f9fc;
            --text-dark: #1e293b;
            --nav-height: 65px;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--main-bg);
            color: var(--text-dark);
            margin: 0;
        }

        /* --- Navbar Tối Giản --- */
        .navbar {
            height: var(--nav-height);
            background: #ffffff !important;
            border-bottom: 1px solid #e3e6f0;
            z-index: 1030;
            padding: 0 1.5rem;
        }

        .navbar-brand {
            font-weight: 800;
            color: var(--primary-color) !important;
            letter-spacing: -0.5px;
        }

        /* --- Profile Dropdown --- */
        .custom-profile-trigger {
            padding: 5px 12px;
            border-radius: 12px;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

            .custom-profile-trigger:hover {
                background-color: #f1f5f9;
            }

        .avatar-circle {
            width: 38px;
            height: 38px;
            background-color: #4e73df;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.85rem;
        }

        .badge-role {
            background-color: #fff3cd;
            color: #856404;
            font-size: 0.7rem;
            padding: 2px 10px;
            border-radius: 50px;
            font-weight: 700;
        }

        .custom-dropdown-menu {
            border-radius: 12px !important;
            border: none !important;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
            min-width: 200px;
        }

        /* --- Sidebar --- */
        .sidebar {
            background-color: var(--sidebar-bg);
            min-height: calc(100vh - var(--nav-height));
            border-right: 1px solid #e3e6f0;
            padding: 1.5rem 0.8rem;
            position: sticky;
            top: var(--nav-height);
        }

        .nav-category {
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            color: #94a3b8;
            margin: 1.5rem 0 0.5rem 1rem;
            letter-spacing: 1px;
        }

        .sidebar .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 15px;
            color: #475569;
            text-decoration: none;
            font-weight: 500;
            border-radius: 10px;
            transition: 0.2s;
            margin-bottom: 2px;
        }

            .sidebar .nav-link:hover {
                background-color: #f1f5f9;
                color: var(--primary-color);
            }

            .sidebar .nav-link.active {
                background-color: #eff6ff;
                color: var(--primary-color);
                font-weight: 700;
            }

        .main-content {
            padding: 2rem;
        }

        footer {
            background: white;
            border-top: 1px solid #e3e6f0;
            padding: 15px 0;
        }
    </style>
</head>
<body>
    @{
        int role = Session["UserRole"] != null ? (int)Session["UserRole"] : 0;
        string[] roleNames = { "", "Trưởng Khoa", "Phòng CSVC", "Phòng KHTC", "BGH" };
        string roleName = role > 0 && role <= 4 ? roleNames[role] : "Khách";
    }

    <nav class="navbar navbar-expand navbar-light sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                QLTB SPKT
            </a>

            <div class="ms-auto d-flex align-items-center">
                @if (Session["UserName"] != null)
                {
                    <div class="dropdown">
                        <div class="custom-profile-trigger dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown">
                            <div class="avatar-circle">QK</div>
                            <div class="d-none d-lg-block text-start">
                                <div class="small fw-bold lh-1">@Session["UserName"]</div>
                                <span class="badge-role mt-1">@roleName</span>
                            </div>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end custom-dropdown-menu shadow">
                            <li><a class="dropdown-item py-2" href="@Url.Action("Profile", "Account")">Hồ sơ cá nhân</a></li>
                            <li><a class="dropdown-item py-2" href="@Url.Action("Notifications", "Account")">Thông báo</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 text-danger fw-bold" href="@Url.Action("Logout", "Account")">Đăng xuất</a></li>
                        </ul>
                    </div>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary btn-sm px-3 fw-bold rounded-pill">Đăng nhập</a>
                }
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            @if (Session["UserName"] != null)
            {
                <aside class="col-md-2 sidebar d-none d-md-block">
                    <nav class="nav flex-column">
                        <div class="nav-category">Hệ thống</div>
                        <a class="nav-link" href="@Url.Action("Index", "Home")"><i class="bi bi-house-door"></i> Trang chủ</a>

                        @if (role == 1)
                        {
                            <div class="nav-category">Khoa</div>
                            <a class="nav-link" href="@Url.Action("DanhSachThietBi", "TruongKhoa")"><i class="bi bi-laptop"></i> Thiết bị</a>
                            <a class="nav-link" href="@Url.Action("DeXuatMuaSam", "TruongKhoa")"><i class="bi bi-file-earmark-plus"></i> Đề xuất</a>
                        }

                        @if (role == 2)
                        {
                            <div class="nav-category">Cơ sở vật chất</div>
                            <a class="nav-link" href="@Url.Action("QuanLyThietBi", "CSVC")"><i class="bi bi-pc-display"></i> Thiết bị</a>
                            <a class="nav-link" href="@Url.Action("QuanLyNhaCungCap", "CSVC")"><i class="bi bi-truck"></i> Nhà cung cấp</a>
                            <a class="nav-link" href="@Url.Action("QuanLyDanhMuc", "CSVC")"><i class="bi bi-folder2-open"></i> Danh mục</a>
                            <a class="nav-link" href="@Url.Action("PheDuyetDeXuat", "CSVC")"><i class="bi bi-clipboard-check"></i> Phê duyệt</a>
                            <a class="nav-link" href="@Url.Action("LapKeHoachBaoTri", "CSVC")"><i class="bi bi-wrench-adjustable"></i> Bảo trì</a>
                            <a class="nav-link" href="@Url.Action("GhiNhanSuaChua", "CSVC")"><i class="bi bi-clipboard2-pulse"></i> Ghi nhận</a>
                            <a class="nav-link" href="@Url.Action("KiemKeTaiSan", "CSVC")"><i class="bi bi-journal-check"></i> Kiểm kê</a>
                        }

                        @if (role == 3)
                        {
                            <div class="nav-category">Tài chính</div>
                            <a class="nav-link" href="@Url.Action("Index", "KHTC")"><i class="bi bi-speedometer2"></i> Dashboard</a>
                            <a class="nav-link" href="@Url.Action("PheDuyetNganSach", "KHTC")"><i class="bi bi-cash-stack"></i> Phê duyệt NS</a>
                            <a class="nav-link" href="@Url.Action("BaoCaoTaiSan", "KHTC")"><i class="bi bi-graph-up"></i> Báo cáo tài sản</a>
                        }

                        @if (role == 4)
                        {
                            <div class="nav-category">Ban giám hiệu</div>
                            <a class="nav-link" href="@Url.Action("Index", "BGH")"><i class="bi bi-bar-chart-line"></i> Dashboard</a>
                            <a class="nav-link" href="@Url.Action("XetDuyetYeuCau", "BGH")"><i class="bi bi-shield-fill-check"></i> Xét duyệt</a>
                            <a class="nav-link" href="@Url.Action("ThongKeTaiSan", "BGH")"><i class="bi bi-graph-up-arrow"></i> Thống kê</a>
                            <a class="nav-link" href="@Url.Action("TheoDoi", "BGH")"><i class="bi bi-eye"></i> Theo dõi TB</a>
                            <a class="nav-link" href="@Url.Action("QuanLyNguoiDung", "BGH")"><i class="bi bi-people-fill"></i> Người dùng</a>
                            <a class="nav-link" href="@Url.Action("QuanLyKhoa", "BGH")"><i class="bi bi-building"></i> Khoa / Phòng ban</a>
                        }
                    </nav>
                </aside>
                <main class="col-md-10 main-content">@RenderBody()</main>
            }
            else
            {
                <main class="col-12 main-content">@RenderBody()</main>
            }
        </div>
    </div>

    <footer class="text-center mt-auto">
        <p class="text-muted small mb-0 py-3">© @DateTime.Now.Year - <b>QLTB SPKT</b> - Trường ĐH Sư Phạm Kỹ Thuật Đà Nẵng</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>