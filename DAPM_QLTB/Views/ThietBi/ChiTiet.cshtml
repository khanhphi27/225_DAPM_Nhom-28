@model QLTB.Models.ThietBiViewModel
@{
    ViewBag.Title = "Chi tiết thiết bị";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0"><i class="fa fa-info-circle text-primary"></i> Chi Tiết Thiết Bị</h3>
        <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("QuanLy", "ThietBi")">← Quay lại danh sách</a>
    </div>

    @if (ViewBag.TenKhoaPhongBan != null && !string.IsNullOrWhiteSpace(ViewBag.TenKhoaPhongBan.ToString()))
    {
        <div class="alert alert-info py-2">Đơn vị: <strong>@ViewBag.TenKhoaPhongBan</strong></div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger py-2">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-2">@TempData["Success"]</div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div><strong>Mã thiết bị:</strong> @Model.ID_ThietBi</div>
                </div>
                <div class="col-md-6">
                    <div><strong>Tên thiết bị:</strong> @Model.TenTB</div>
                </div>
                <div class="col-md-6">
                    <div><strong>Danh mục:</strong> @Model.TenDanhMuc</div>
                </div>
                <div class="col-md-6">
                    <div><strong>Trạng thái:</strong> @Model.TrangThaiTB</div>
                </div>
                <div class="col-md-6">
                    <div><strong>Giá trị:</strong> @(Model.Gia.HasValue ? string.Format("{0:N0} đ", Model.Gia.Value) : "—")</div>
                </div>
                <div class="col-md-6">
                    <div><strong>Số seri:</strong> @(Model.SoSeri.HasValue ? Model.SoSeri.ToString() : "—")</div>
                </div>
                <div class="col-md-6">
                    <div><strong>Nhà cung cấp:</strong> @(string.IsNullOrWhiteSpace(Model.TenNhaCungCap) ? "—" : Model.TenNhaCungCap)</div>
                </div>
                <div class="col-md-6">
                    <div><strong>Khoa/Phòng ban:</strong> @(string.IsNullOrWhiteSpace(Model.TenKhoaPhongBan) ? "—" : Model.TenKhoaPhongBan)</div>
                </div>
                <div class="col-12">
                    <div><strong>Vị trí đặt:</strong></div>
                    <div class="border rounded p-2 bg-light">
                        @(string.IsNullOrWhiteSpace(Model.TenPhong) ? "Chưa bố trí phòng" : $"{Model.TenPhong} ({Model.TenKhuVuc} - {Model.TenCoSo})")
                    </div>
                </div>
                <div class="col-12">
                    <div><strong>Thông số kỹ thuật:</strong></div>
                    <div class="border rounded p-2 bg-light">
                        @(string.IsNullOrWhiteSpace(Model.ThongSoKT) ? "Không có thông số kỹ thuật" : Model.ThongSoKT)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white py-2">
            <strong>Báo hỏng thiết bị</strong>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("BaoHong", "TruongKhoa", FormMethod.Post))
            {
                <input type="hidden" name="id" value="@Model.ID_ThietBi" />
                <input type="hidden" name="fromDetail" value="true" />

                <div class="mb-3">
                    <label class="form-label">Mô tả hư hỏng *</label>
                    <textarea name="mota" class="form-control" rows="3" placeholder="Nhập mô tả chi tiết lỗi của thiết bị..." required></textarea>
                </div>

                <button type="submit" class="btn btn-danger">Gửi báo hỏng</button>
            }
        </div>
    </div>
</div>
