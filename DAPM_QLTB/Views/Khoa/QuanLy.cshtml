@model IEnumerable<QLTB.Models.KhoaPhongBanViewModel>
@{
    ViewBag.Title = "Quản Lý Khoa / Phòng Ban";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .page-header { margin-bottom: 24px; }
    .page-header h2 { color: #1a237e; font-weight: 700; font-size: 22px; margin: 0; }
    .page-header p  { color: #666; font-size: 13px; margin: 4px 0 0; }

    .card-table {
        background: #fff; border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.07); overflow: hidden;
    }
    .card-table table { width: 100%; border-collapse: collapse; }
    .card-table thead th {
        background: #e8eaf6; color: #1a237e;
        font-size: 12px; font-weight: 700;
        text-transform: uppercase; letter-spacing: .4px;
        padding: 12px 14px; white-space: nowrap;
    }
    .card-table tbody td {
        padding: 11px 14px; font-size: 13px;
        color: #333; border-bottom: 1px solid #f0f2f8;
        vertical-align: middle;
    }
    .card-table tbody tr:last-child td { border-bottom: none; }
    .card-table tbody tr:hover td { background: #f5f6ff; }

    .badge-count {
        display: inline-block; padding: 3px 10px;
        border-radius: 20px; font-size: 11px; font-weight: 700;
    }
    .badge-count.nd { background: #e3f2fd; color: #1565c0; }
    .badge-count.tb { background: #e8f5e9; color: #2e7d32; }

    .btn-icon {
        border: none; background: transparent;
        padding: 5px 8px; border-radius: 6px;
        cursor: pointer; font-size: 15px; transition: .15s;
    }
    .btn-icon.edit { color: #1a237e; }
    .btn-icon.edit:hover { background: #e8eaf6; }
    .btn-icon.del  { color: #e53935; }
    .btn-icon.del:hover  { background: #fce4ec; }

    .modal-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,.45); z-index: 1050;
        align-items: center; justify-content: center;
    }
    .modal-overlay.active { display: flex; }
    .modal-box {
        background: #fff; border-radius: 14px;
        padding: 28px 30px; width: 440px; max-width: 95vw;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
    }
    .modal-title { font-size: 18px; font-weight: 700; color: #1a237e; margin-bottom: 18px; }
    .form-lbl { font-size: 12px; font-weight: 600; color: #555; margin-bottom: 4px; display: block; }
    .form-inp {
        width: 100%; padding: 9px 12px;
        border: 1px solid #d0d5e8; border-radius: 8px;
        font-size: 13px; background: #f8f9fe;
        box-sizing: border-box; margin-bottom: 12px;
    }
    .form-inp:focus { border-color: #3949ab; outline: none; }
    .modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 6px; }
    .btn-cancel { background: #f5f5f5; color: #555; border: none; border-radius: 8px; padding: 9px 20px; font-size: 13px; font-weight: 600; cursor: pointer; }
    .btn-save   { background: #1a237e; color: #fff; border: none; border-radius: 8px; padding: 9px 24px; font-size: 13px; font-weight: 600; cursor: pointer; }
    .btn-danger { background: #e53935; color: #fff; border: none; border-radius: 8px; padding: 9px 24px; font-size: 13px; font-weight: 600; cursor: pointer; }

    .alert-box { padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 16px; display: none; }
    .alert-box.success { background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
    .alert-box.error   { background: #fce4ec; color: #c62828; border: 1px solid #ef9a9a; }
</style>

<div class="page-header">
    <h2>🏢 Quản Lý Khoa / Phòng Ban</h2>
    <p>Thêm, chỉnh sửa và xóa các khoa, phòng ban trong hệ thống</p>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<div id="alertBox" class="alert-box"></div>

<!-- Toolbar -->
<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
    <span style="font-size:13px; color:#666;">
        Tổng: <strong id="lblTong">@Model.Count()</strong> khoa / phòng ban
        <span id="lblLoc" style="color:#1a237e; display:none;"> – lọc ra: <strong id="lblLocSo">0</strong></span>
    </span>
    <button onclick="openCreate()" style="background:#1a237e;color:#fff;border:none;border-radius:8px;padding:9px 18px;font-size:13px;font-weight:600;cursor:pointer;">
        <i class="bi bi-plus-circle-fill"></i> Thêm khoa mới
    </button>
</div>

<!-- Thanh tìm kiếm -->
<div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;align-items:center;">
    <input type="text" id="searchKeyword" oninput="applyFilter()" placeholder="🔍 Tìm theo mã hoặc tên..."
           style="padding:8px 12px;border:1px solid #d0d5e8;border-radius:8px;font-size:13px;background:#fff;min-width:260px;" />
    <button onclick="resetFilter()" style="padding:8px 14px;border:1px solid #d0d5e8;border-radius:8px;font-size:13px;background:#f5f5f5;color:#555;cursor:pointer;">
        ✕ Bỏ lọc
    </button>
</div>

<!-- Bảng danh sách -->
<div class="card-table">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>ID Khoa</th>
                <th>Tên khoa / phòng ban</th>
                <th style="text-align:center">Người dùng</th>
                <th style="text-align:center">Thiết bị</th>
                <th style="text-align:center">Thao tác</th>
            </tr>
        </thead>
        <tbody id="tbodyKhoa">
            @{ int stt = 0; }
            @foreach (var kp in Model)
            {
                stt++;
                <tr data-id="@kp.ID_KhoaPhongBan.ToLower()" data-ten="@kp.TenPhongBanKhoa.ToLower()">
                    <td style="color:#999">@stt</td>
                    <td><code style="font-size:11px;background:#f0f2f8;padding:2px 7px;border-radius:4px;">@kp.ID_KhoaPhongBan</code></td>
                    <td><strong style="cursor:pointer;color:#1a237e;text-decoration:underline dotted;" onclick="openChiTiet('@kp.ID_KhoaPhongBan', '@Html.Raw(kp.TenPhongBanKhoa.Replace("'", "\\'"))')">@kp.TenPhongBanKhoa</strong></td>
                    <td style="text-align:center">
                        <span class="badge-count nd">👤 @kp.SoNguoiDung</span>
                    </td>
                    <td style="text-align:center">
                        <span class="badge-count tb">💻 @kp.SoThietBi</span>
                    </td>
                    <td style="text-align:center; white-space:nowrap;">
                        <button class="btn-icon edit" title="Sửa"
                                onclick="openEdit('@kp.ID_KhoaPhongBan')">
                            <i class="bi bi-pencil-fill"></i>
                        </button>
                        <button class="btn-icon del" title="Xóa"
                                onclick="openDelete('@kp.ID_KhoaPhongBan', '@Html.Raw(kp.TenPhongBanKhoa.Replace("'", "\\'"))')">
                            <i class="bi bi-trash3-fill"></i>
                        </button>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="6" style="text-align:center;color:#999;padding:30px;">Chưa có khoa nào.</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- ===== MODAL TẠO ===== -->
<div class="modal-overlay" id="modalCreate">
    <div class="modal-box">
        <div class="modal-title">➕ Thêm Khoa / Phòng Ban Mới</div>

        <label class="form-lbl">ID Khoa <span style="color:red">*</span></label>
        <input type="text" id="c_id" class="form-inp" placeholder="VD: KH001" style="font-family:monospace;" />

        <label class="form-lbl">Tên khoa / phòng ban <span style="color:red">*</span></label>
        <input type="text" id="c_ten" class="form-inp" placeholder="VD: Khoa Công nghệ thông tin" />

        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeAll()">Hủy</button>
            <button class="btn-save" onclick="submitCreate()">💾 Thêm</button>
        </div>
    </div>
</div>

<!-- ===== MODAL SỬA ===== -->
<div class="modal-overlay" id="modalEdit">
    <div class="modal-box">
        <div class="modal-title">✏️ Chỉnh Sửa Khoa / Phòng Ban</div>
        <input type="hidden" id="e_id" />

        <label class="form-lbl">ID Khoa</label>
        <input type="text" id="e_id_display" class="form-inp" readonly
               style="font-family:monospace;background:#f0f2f8;color:#555;cursor:not-allowed;" />

        <label class="form-lbl">Tên khoa / phòng ban <span style="color:red">*</span></label>
        <input type="text" id="e_ten" class="form-inp" />

        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeAll()">Hủy</button>
            <button class="btn-save" onclick="submitEdit()">💾 Lưu thay đổi</button>
        </div>
    </div>
</div>

<!-- ===== MODAL XÓA ===== -->
<div class="modal-overlay" id="modalDelete">
    <div class="modal-box" style="width:400px;">
        <div class="modal-title">🗑️ Xác Nhận Xóa</div>
        <input type="hidden" id="d_id" />
        <p style="font-size:14px;color:#444;margin-bottom:20px;">
            Bạn có chắc muốn xóa khoa <strong id="d_ten"></strong>?<br>
            <span style="color:#e53935;font-size:12px;">Chỉ xóa được khi không còn người dùng và thiết bị thuộc khoa này.</span>
        </p>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeAll()">Hủy</button>
            <button class="btn-danger" onclick="submitDelete()">🗑️ Xóa</button>
        </div>
    </div>
</div>

<!-- ===== MODAL CHI TIẾT KHOA ===== -->
<div class="modal-overlay" id="modalChiTiet">
    <div class="modal-box" style="width:720px;max-height:85vh;overflow-y:auto;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div class="modal-title" style="margin:0;">🏢 Chi Tiết Khoa — <span id="ct_ten" style="color:#3949ab;"></span></div>
            <button onclick="closeAll()" style="background:none;border:none;font-size:20px;cursor:pointer;color:#888;">✕</button>
        </div>

        <!-- Tab -->
        <div style="display:flex;gap:4px;margin-bottom:16px;border-bottom:2px solid #e8eaf6;padding-bottom:0;">
            <button id="tabNDBtn" onclick="switchTab('nd')"
                style="padding:8px 18px;border:none;background:transparent;font-size:13px;font-weight:600;color:#1a237e;border-bottom:2px solid #1a237e;cursor:pointer;margin-bottom:-2px;">
                👤 Người dùng (<span id="ct_soND">0</span>)
            </button>
            <button id="tabTBBtn" onclick="switchTab('tb')"
                style="padding:8px 18px;border:none;background:transparent;font-size:13px;font-weight:600;color:#888;border-bottom:2px solid transparent;cursor:pointer;margin-bottom:-2px;">
                💻 Thiết bị (<span id="ct_soTB">0</span>)
            </button>
        </div>

        <!-- Tab người dùng -->
        <div id="tabND">
            <div id="ct_nd_loading" style="text-align:center;padding:20px;color:#aaa;">Đang tải...</div>
            <table id="ct_nd_table" style="width:100%;border-collapse:collapse;display:none;">
                <thead>
                    <tr style="background:#e8eaf6;">
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:left;">#</th>
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:left;">ID</th>
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:left;">Họ tên</th>
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:left;">Email</th>
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:left;">Vai trò</th>
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:center;">Trạng thái</th>
                    </tr>
                </thead>
                <tbody id="ct_nd_body"></tbody>
            </table>
            <div id="ct_nd_empty" style="text-align:center;padding:24px;color:#aaa;display:none;">Chưa có người dùng nào.</div>
        </div>

        <!-- Tab thiết bị -->
        <div id="tabTB" style="display:none;">
            <div id="ct_tb_loading" style="text-align:center;padding:20px;color:#aaa;">Đang tải...</div>
            <table id="ct_tb_table" style="width:100%;border-collapse:collapse;display:none;">
                <thead>
                    <tr style="background:#e8eaf6;">
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:left;">#</th>
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:left;">Mã TB</th>
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:left;">Tên thiết bị</th>
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:left;">Danh mục</th>
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:right;">Giá trị</th>
                        <th style="padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#1a237e;text-align:center;">Trạng thái</th>
                    </tr>
                </thead>
                <tbody id="ct_tb_body"></tbody>
            </table>
            <div id="ct_tb_empty" style="text-align:center;padding:24px;color:#aaa;display:none;">Chưa có thiết bị nào.</div>
        </div>
    </div>
</div>

@section scripts {
<script>
    function showAlert(msg, type) {
        var box = document.getElementById('alertBox');
        box.textContent = msg;
        box.className = 'alert-box ' + type;
        box.style.display = 'block';
        setTimeout(function () { box.style.display = 'none'; }, 4000);
    }
    function closeAll() {
        document.querySelectorAll('.modal-overlay').forEach(function (m) { m.classList.remove('active'); });
    }
    document.querySelectorAll('.modal-overlay').forEach(function (m) {
        m.addEventListener('click', function (e) { if (e.target === m) closeAll(); });
    });

    // ── Tìm kiếm ─────────────────────────────────────────────
    function applyFilter() {
        var keyword = (document.getElementById('searchKeyword').value || '').trim().toLowerCase();
        var rows = document.querySelectorAll('#tbodyKhoa tr');
        var visible = 0;
        rows.forEach(function (row) {
            var rId  = row.getAttribute('data-id')  || '';
            var rTen = row.getAttribute('data-ten') || '';
            var ok = !keyword || rId.includes(keyword) || rTen.includes(keyword);
            row.style.display = ok ? '' : 'none';
            if (ok) visible++;
        });
        var isFiltering = !!keyword;
        document.getElementById('lblLoc').style.display = isFiltering ? '' : 'none';
        document.getElementById('lblLocSo').textContent = visible;
    }
    function resetFilter() {
        document.getElementById('searchKeyword').value = '';
        applyFilter();
    }

    // ── Tạo ──────────────────────────────────────────────────
    function openCreate() {
        document.getElementById('c_id').value  = '';
        document.getElementById('c_ten').value = '';
        document.getElementById('modalCreate').classList.add('active');
        setTimeout(function () { document.getElementById('c_id').focus(); }, 100);
    }
    function submitCreate() {
        var id  = document.getElementById('c_id').value.trim();
        var ten = document.getElementById('c_ten').value.trim();
        if (!id)  { showAlert('Vui lòng nhập ID khoa.', 'error'); return; }
        if (!ten) { showAlert('Vui lòng nhập tên khoa.', 'error'); return; }

        $.post('@Url.Action("TaoKhoa", "Khoa")', { id: id, ten: ten }, function (res) {
            if (res.ok) { showAlert(res.msg, 'success'); closeAll(); setTimeout(function () { location.reload(); }, 1200); }
            else showAlert(res.msg, 'error');
        });
    }

    // ── Sửa ──────────────────────────────────────────────────
    function openEdit(id) {
        $.get('@Url.Action("GetKhoa", "Khoa")', { id: id }, function (res) {
            if (!res.ok) { showAlert(res.msg, 'error'); return; }
            document.getElementById('e_id').value         = res.data.id;
            document.getElementById('e_id_display').value = res.data.id;
            document.getElementById('e_ten').value        = res.data.ten;
            document.getElementById('modalEdit').classList.add('active');
            setTimeout(function () { document.getElementById('e_ten').focus(); }, 100);
        });
    }
    function submitEdit() {
        var ten = document.getElementById('e_ten').value.trim();
        if (!ten) { showAlert('Tên khoa không được để trống.', 'error'); return; }

        $.post('@Url.Action("SuaKhoa", "Khoa")', {
            id:  document.getElementById('e_id').value,
            ten: ten
        }, function (res) {
            if (res.ok) { showAlert(res.msg, 'success'); closeAll(); setTimeout(function () { location.reload(); }, 1200); }
            else showAlert(res.msg, 'error');
        });
    }

    // ── Chi tiết khoa ─────────────────────────────────────────
    var _chiTietData = null;

    function openChiTiet(id, ten) {
        document.getElementById('ct_ten').textContent = ten;
        document.getElementById('ct_nd_loading').style.display = '';
        document.getElementById('ct_tb_loading').style.display = '';
        document.getElementById('ct_nd_table').style.display = 'none';
        document.getElementById('ct_tb_table').style.display = 'none';
        document.getElementById('ct_nd_empty').style.display = 'none';
        document.getElementById('ct_tb_empty').style.display = 'none';
        switchTab('nd');
        document.getElementById('modalChiTiet').classList.add('active');

        $.get('@Url.Action("GetChiTiet","Khoa")', { id: id }, function(res) {
            if (!res.ok) { showAlert('Lỗi tải chi tiết: ' + res.msg, 'error'); return; }
            _chiTietData = res.data;

            // Người dùng
            var nd = res.data.nguoiDung || [];
            document.getElementById('ct_soND').textContent = nd.length;
            document.getElementById('ct_nd_loading').style.display = 'none';
            if (nd.length === 0) {
                document.getElementById('ct_nd_empty').style.display = '';
            } else {
                var vaiTroMap = { 'VT_TK':'Trưởng Khoa','VT_CSVC':'Quản lý CSVC','VT_KHTC':'Quản lý KHTC','VT_BGH':'Ban Giám Hiệu' };
                var html = nd.map(function(u, i) {
                    var vt = vaiTroMap[u.vaiTro] || (u.vaiTro || '—');
                    var ttCls = u.trangThai === 'Hoạt động' ? 'color:#2e7d32;background:#e8f5e9' : 'color:#c62828;background:#fce4ec';
                    return '<tr style="border-bottom:1px solid #f0f2f8;">'
                        + '<td style="padding:9px 12px;color:#999;">' + (i+1) + '</td>'
                        + '<td style="padding:9px 12px;"><code style="font-size:11px;background:#f0f2f8;padding:2px 6px;border-radius:4px;">' + u.id + '</code></td>'
                        + '<td style="padding:9px 12px;font-weight:600;">' + u.hoTen + '</td>'
                        + '<td style="padding:9px 12px;color:#666;font-size:12px;">' + (u.email || '—') + '</td>'
                        + '<td style="padding:9px 12px;font-size:12px;">' + vt + '</td>'
                        + '<td style="padding:9px 12px;text-align:center;"><span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;' + ttCls + '">' + u.trangThai + '</span></td>'
                        + '</tr>';
                }).join('');
                document.getElementById('ct_nd_body').innerHTML = html;
                document.getElementById('ct_nd_table').style.display = '';
            }

            // Thiết bị
            var tb = res.data.thietBi || [];
            document.getElementById('ct_soTB').textContent = tb.length;
            document.getElementById('ct_tb_loading').style.display = 'none';
            if (tb.length === 0) {
                document.getElementById('ct_tb_empty').style.display = '';
            } else {
                var html2 = tb.map(function(t, i) {
                    var ttCls2 = t.trangThai === 'Đang sử dụng' ? 'color:#2e7d32;background:#e8f5e9'
                               : t.trangThai === 'Báo hỏng'     ? 'color:#c62828;background:#fce4ec'
                               : 'color:#e65100;background:#fff3e0';
                    return '<tr style="border-bottom:1px solid #f0f2f8;">'
                        + '<td style="padding:9px 12px;color:#999;">' + (i+1) + '</td>'
                        + '<td style="padding:9px 12px;"><code style="font-size:11px;background:#f0f2f8;padding:2px 6px;border-radius:4px;">' + t.id + '</code></td>'
                        + '<td style="padding:9px 12px;font-weight:600;">' + t.tenTB + '</td>'
                        + '<td style="padding:9px 12px;color:#666;font-size:12px;">' + (t.danhMuc || '—') + '</td>'
                        + '<td style="padding:9px 12px;text-align:right;font-size:12px;">' + Number(t.gia).toLocaleString('vi-VN') + ' đ</td>'
                        + '<td style="padding:9px 12px;text-align:center;"><span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;' + ttCls2 + '">' + (t.trangThai || '—') + '</span></td>'
                        + '</tr>';
                }).join('');
                document.getElementById('ct_tb_body').innerHTML = html2;
                document.getElementById('ct_tb_table').style.display = '';
            }
        }).fail(function() { showAlert('Lỗi kết nối khi tải chi tiết.', 'error'); });
    }

    function switchTab(tab) {
        document.getElementById('tabND').style.display = tab === 'nd' ? '' : 'none';
        document.getElementById('tabTB').style.display = tab === 'tb' ? '' : 'none';
        document.getElementById('tabNDBtn').style.color = tab === 'nd' ? '#1a237e' : '#888';
        document.getElementById('tabNDBtn').style.borderBottomColor = tab === 'nd' ? '#1a237e' : 'transparent';
        document.getElementById('tabTBBtn').style.color = tab === 'tb' ? '#1a237e' : '#888';
        document.getElementById('tabTBBtn').style.borderBottomColor = tab === 'tb' ? '#1a237e' : 'transparent';
    }

    // ── Xóa ──────────────────────────────────────────────────
    function openDelete(id, ten) {
        document.getElementById('d_id').value = id;
        document.getElementById('d_ten').textContent = ten;
        document.getElementById('modalDelete').classList.add('active');
    }
    function submitDelete() {
        $.post('@Url.Action("XoaKhoa", "Khoa")', {
            id: document.getElementById('d_id').value
        }, function (res) {
            if (res.ok) { showAlert('Đã xóa khoa.', 'success'); closeAll(); setTimeout(function () { location.reload(); }, 1200); }
            else showAlert(res.msg, 'error');
        });
    }
</script>
}
