@{ ViewBag.Title = "Lập Kế Hoạch Bảo Trì - Phòng CSVC"; }

<style>
    .page-hdr {
        margin-bottom: 20px;
    }

        .page-hdr h2 {
            color: #1a237e;
            font-weight: 700;
            font-size: 22px;
            margin: 0 0 4px;
        }

        .page-hdr p {
            color: #666;
            font-size: 13px;
            margin: 0;
        }

    .layout-2col {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 18px;
        align-items: start;
    }

    /* Alert báo hỏng chờ */
    .alert-box {
        background: #fff8e1;
        border: 1px solid #ffe082;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 18px;
    }

        .alert-box h4 {
            color: #e65100;
            font-size: 13px;
            font-weight: 700;
            margin: 0 0 8px;
        }

    .alert-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #fff3e0;
        font-size: 12px;
    }

        .alert-item:last-child {
            border: none;
        }

        .alert-item strong {
            color: #333;
        }

    .btn-tao-kh {
        background: #e65100;
        color: #fff;
        border: none;
        border-radius: 5px;
        padding: 4px 10px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-tao-kh:hover {
            background: #bf360c;
        }

    /* Panel chung */
    .panel {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        overflow: hidden;
        margin-bottom: 18px;
    }

    .panel-header {
        padding: 14px 18px;
        border-bottom: 1px solid #f0f2f8;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .panel-header h3 {
            font-size: 14px;
            font-weight: 700;
            color: #1a237e;
            margin: 0;
        }

    /* Tabs lọc */
    .tab-bar {
        display: flex;
        gap: 4px;
        padding: 12px 18px 0;
        border-bottom: 1px solid #f0f2f8;
    }

    .tab-btn {
        padding: 7px 16px;
        border: none;
        background: transparent;
        font-size: 12px;
        font-weight: 600;
        color: #888;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
    }

        .tab-btn.active {
            color: #1a237e;
            border-color: #1a237e;
        }

    /* Danh sách kế hoạch */
    .plan-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 13px 18px;
        border-bottom: 1px solid #f0f2f8;
        cursor: pointer;
        transition: background .15s;
    }

        .plan-item:hover {
            background: #f8f9ff;
        }

        .plan-item.selected {
            background: #eef0fb;
        }

        .plan-item:last-child {
            border: none;
        }

    .plan-date {
        text-align: center;
        min-width: 38px;
    }

        .plan-date .day {
            font-size: 20px;
            font-weight: 800;
            color: #1a237e;
            line-height: 1;
        }

        .plan-date .month {
            font-size: 10px;
            color: #888;
        }

    .plan-info {
        flex: 1;
    }

    .plan-name {
        font-size: 13px;
        font-weight: 600;
        color: #222;
        margin-bottom: 4px;
    }

    .plan-sub {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        font-size: 11px;
        color: #888;
    }

        .plan-sub span {
            display: flex;
            align-items: center;
            gap: 3px;
        }

    .badge-type {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 10px;
        font-weight: 700;
    }

        .badge-type.routine {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .badge-type.urgent {
            background: #fce4ec;
            color: #c62828;
        }

        .badge-type.inspect {
            background: #e3f2fd;
            color: #1565c0;
        }

        .badge-type.overhaul {
            background: #f3e5f5;
            color: #6a1b9a;
        }

    .plan-status {
        font-size: 11px;
        font-weight: 700;
        min-width: 70px;
        text-align: center;
    }

        .plan-status.pending {
            color: #fb8c00;
        }

        .plan-status.todo {
            color: #1a237e;
        }

        .plan-status.done {
            color: #43a047;
        }

        .plan-status.urgent-s {
            color: #e53935;
        }

    .btn-sm {
        border: none;
        border-radius: 6px;
        padding: 5px 10px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
    }

        .btn-sm.start {
            background: #1a237e;
            color: #fff;
        }

        .btn-sm.edit {
            background: #e8eaf6;
            color: #1a237e;
        }

        .btn-sm.done {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .btn-sm.urgent {
            background: #fce4ec;
            color: #c62828;
        }

    /* Detail panel */
    .detail-panel {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        padding: 20px;
    }

        .detail-panel h3 {
            font-size: 14px;
            font-weight: 700;
            color: #1a237e;
            margin: 0 0 16px;
        }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 16px;
    }

    .detail-item label {
        font-size: 11px;
        color: #888;
        font-weight: 600;
        display: block;
        margin-bottom: 2px;
    }

    .detail-item p {
        font-size: 13px;
        color: #333;
        font-weight: 600;
        margin: 0;
    }

    .detail-item.full {
        grid-column: 1/-1;
    }

    .section-sep {
        font-size: 11px;
        font-weight: 700;
        color: #1a237e;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: 10px 0 6px;
        border-bottom: 1px solid #e8eaf6;
        margin: 14px 0 10px;
        grid-column: 1/-1;
    }

    .device-list-sm {
        font-size: 12px;
    }

        .device-list-sm li {
            padding: 5px 0;
            border-bottom: 1px solid #f0f2f8;
            display: flex;
            gap: 8px;
            align-items: center;
        }

            .device-list-sm li:last-child {
                border: none;
            }

    .action-row {
        display: flex;
        gap: 8px;
        margin-top: 16px;
        justify-content: flex-end;
    }

    .btn-primary {
        background: #1a237e;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-secondary {
        background: #e8eaf6;
        color: #1a237e;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-success {
        background: #43a047;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    /* Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.45);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

        .modal-overlay.active {
            display: flex;
        }

    .modal-box {
        background: #fff;
        border-radius: 14px;
        padding: 28px 32px;
        width: 640px;
        max-width: 95vw;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    }

    .modal-title {
        font-size: 18px;
        font-weight: 700;
        color: #1a237e;
        margin-bottom: 4px;
    }

    .modal-sub {
        font-size: 12px;
        color: #888;
        margin-bottom: 18px;
    }

    .modal-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

        .modal-grid .full {
            grid-column: 1/-1;
        }

    .form-lbl {
        font-size: 12px;
        font-weight: 600;
        color: #555;
        margin-bottom: 4px;
        display: block;
    }

    .form-inp {
        width: 100%;
        padding: 9px 12px;
        border: 1px solid #d0d5e8;
        border-radius: 8px;
        font-size: 13px;
        background: #f8f9fe;
        box-sizing: border-box;
    }

        .form-inp:focus {
            border-color: #3949ab;
            outline: none;
            box-shadow: 0 0 0 3px rgba(57,73,171,0.1);
        }

    .modal-footer {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 22px;
    }

    .btn-cancel {
        background: #f5f5f5;
        color: #555;
        border: none;
        border-radius: 8px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-save {
        background: #1a237e;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 24px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-save.urgent {
            background: #e53935;
        }

    .highlight-box {
        background: #fff8e1;
        border: 1px solid #ffe082;
        border-radius: 8px;
        padding: 12px 14px;
        font-size: 12px;
        color: #795548;
        margin-bottom: 14px;
        grid-column: 1/-1;
    }

        .highlight-box strong {
            color: #e65100;
        }

    .field-section {
        font-size: 11px;
        font-weight: 700;
        color: #1a237e;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding-top: 6px;
        border-top: 1px solid #e8eaf6;
        grid-column: 1/-1;
        margin-top: 6px;
    }
</style>

<!-- Header -->
<div class="page-hdr">
    <h2>📅 Lập Kế Hoạch Bảo Trì</h2>
</div>

<!-- Alert: báo hỏng chờ lập kế hoạch -->
<div class="alert-box">
    <h4>⚠️ Có 3 thiết bị báo hỏng </h4>
    @{ var pendingBH = new[] {
            new { id="BH-2024-041", tb="TB005 - Oscilloscope Rigol DS1054Z", ngay="08/04/2024", mucdo="🔴 Khẩn" },
            new { id="BH-2024-039", tb="TB002 - Máy chiếu Epson EB-X51",    ngay="06/04/2024", mucdo="🟡 Vừa"  },
            new { id="BH-2024-037", tb="TB003 - Máy tính B201-PC05",         ngay="05/04/2024", mucdo="🟡 Vừa"  },
        }; }
    @foreach (var bh in pendingBH)
    {
<div class="alert-item">
    <div>
        <strong>@bh.id</strong> — @bh.tb
        <span style="color:#888;margin-left:8px">📅 @bh.ngay &nbsp; @bh.mucdo</span>
    </div>
    <button class="btn-tao-kh" onclick="openUrgentModal('@bh.id', '@bh.tb')">+ Lập KH sửa chữa đột xuất</button>
</div>}
</div>

<div class="layout-2col">
    <!-- Cột trái: Danh sách kế hoạch -->
    <div>
        <div class="panel">
            <div class="panel-header">
                <h3>📋 Danh sách kế hoạch </h3>
                <button class="btn-sm start" onclick="openCreateModal()">+ Tạo mới</button>
            </div>
            <div class="tab-bar">
                <button class="tab-btn active">Tất cả</button>
                <button class="tab-btn">Chờ thực hiện</button>
                <button class="tab-btn">Đang thực hiện</button>
                <button class="tab-btn">Hoàn thành</button>
            </div>
            @{ var plans = new[] {
                    new { id="KH-2024-018", day="08", month="Th.4", name="Sửa chữa đột xuất — Oscilloscope Rigol DS1054Z", unit="Khoa Công nghệ thông tin", loai="urgent",  trangThai="urgent-s", trangThaiTxt="🔴 Đột xuất", chiPhi="2,500,000", btnCls="urgent", btnTxt="▶ Bắt đầu" },
                    new { id="KH-2024-017", day="11", month="Th.4", name="Bảo trì định kỳ máy tính phòng B201",           unit="Khoa Công nghệ thông tin", loai="routine", trangThai="todo",     trangThaiTxt="📅 Sắp tới",  chiPhi="1,800,000", btnCls="edit",   btnTxt="✏️ Sửa"    },
                    new { id="KH-2024-016", day="15", month="Th.4", name="Kiểm tra máy chiếu 8 phòng học",                unit="Toàn trường",              loai="inspect", trangThai="todo",     trangThaiTxt="📅 Sắp tới",  chiPhi="500,000",   btnCls="edit",   btnTxt="✏️ Sửa"    },
                    new { id="KH-2024-015", day="19", month="Th.4", name="Sửa chữa đột xuất — Máy chiếu Epson EB-X51",   unit="Khoa Công nghệ thông tin", loai="urgent",  trangThai="todo",     trangThaiTxt="📅 Sắp tới",  chiPhi="3,000,000", btnCls="edit",   btnTxt="✏️ Sửa"    },
                    new { id="KH-2024-014", day="22", month="Th.4", name="Vệ sinh và kiểm tra UPS phòng Server",          unit="Trung tâm CNTT",           loai="routine", trangThai="done",     trangThaiTxt="✅ Hoàn thành", chiPhi="800,000",  btnCls="done",   btnTxt="📋 Xem BC"  },
                }; }
            @foreach (var p in plans)
            {
                var badgeType = p.loai == "urgent" ? "urgent" : p.loai == "routine" ? "routine" : p.loai == "inspect" ? "inspect" : "overhaul";
                var badgeTxt2 = p.loai == "urgent" ? "Đột xuất" : p.loai == "routine" ? "Định kỳ" : p.loai == "inspect" ? "Kiểm tra" : "Đại tu";
<div class="plan-item" onclick="selectPlan(this, '@p.id')">
    <div class="plan-date">
        <div class="day">@p.day</div>
        <div class="month">@p.month</div>
    </div>
    <div class="plan-info">
        <div class="plan-name">@p.name</div>
        <div class="plan-sub">
            <span>🏢 @p.unit</span>
            <span class="badge-type @badgeType">@badgeTxt2</span>
            <span>💰 @p.chiPhi đ</span>
        </div>
    </div>
    <div class="plan-status @p.trangThai">@p.trangThaiTxt</div>
    <button class="btn-sm @p.btnCls">@p.btnTxt</button>
</div>            }
        </div>
    </div>

    <!-- Cột phải: Chi tiết kế hoạch đang chọn -->
    <div class="detail-panel">
        <h3>🔍 Chi tiết kế hoạch: KH-2024-018</h3>
        <div class="detail-grid">
            <div class="detail-item">
                <label>ID Kế hoạch</label>
                <p>KH-2024-018</p>
            </div>
            <div class="detail-item">
                <label>Loại bảo trì</label>
                <p><span class="badge-type urgent">Sửa chữa đột xuất</span></p>
            </div>
            <div class="detail-item">
                <label>Ngày lập </label>
                <p>08/04/2024</p>
            </div>
            <div class="detail-item">
                <label>Ngày dự kiến HT</label>
                <p>12/04/2024</p>
            </div>
            <div class="detail-item">
                <label>Người lập </label>
                <p>csvc — Quản lý CSVC</p>
            </div>
            <div class="detail-item">
                <label>Đơn vị thực hiện </label>
                <p>Khoa Công nghệ thông tin</p>
            </div>
            <div class="detail-item">
                <label>Chi phí dự kiến </label>
                <p>2,500,000 VNĐ</p>
            </div>
            <div class="detail-item">
                <label>Trạng thái </label>
                <p style="color:#e53935;font-weight:700">Chờ thực hiện</p>
            </div>
            <div class="detail-item full">
                <p style="color:#e65100">BH-2024-041 — TB005 Oscilloscope Rigol DS1054Z, Khoa Điện - Điện tử</p>
            </div>
            <div class="detail-item full">
                <label>Ghi chú </label>
                <p>Kênh 1 không hiển thị tín hiệu, cần thay IC khuếch đại OPA2134 và probe đầu đo.</p>
            </div>

            <div class="section-sep">Thiết bị trong kế hoạch</div>
            <div class="detail-item full">
                <ul class="device-list-sm" style="padding-left:0;list-style:none;margin:0">
                    <li>📦 <strong>TB005</strong> — Oscilloscope Rigol DS1054Z <span class="badge-type urgent">Hư hỏng kênh 1</span></li>
                </ul>
            </div>
        </div>

        <div class="action-row">
            <button class="btn-secondary" onclick="openCreateModal()">✏️ Chỉnh sửa kế hoạch</button>
            <button class="btn-success" onclick="alert('Chuyển sang Ghi Nhận Sửa Chữa để ghi kết quả!')">📝 Ghi nhận kết quả</button>
            <button class="btn-primary" style="background:#e53935" onclick="alert('Bắt đầu thực hiện kế hoạch!')">▶ Bắt đầu</button>
        </div>
    </div>
</div>

<!-- Modal Tạo KH Bảo Trì Thông Thường -->
<div class="modal-overlay" id="createModal">
    <div class="modal-box">
        <div class="modal-title">🔧 Tạo Kế Hoạch Bảo Trì Mới</div>
        <div class="modal-sub">Tạo bản ghi vào bảng <strong>KEHOACH_BAOTRI</strong></div>
        <div class="modal-grid">
            <div>
                <label class="form-lbl">ID Kế hoạch </label>
                <input type="text" class="form-inp" placeholder="VD: KH-2024-019" />
            </div>
            <div>
                <label class="form-lbl">Loại bảo trì </label>
                <select class="form-inp">
                    <option value="Bảo trì định kỳ">Bảo trì định kỳ</option>
                    <option value="Kiểm tra tình trạng">Kiểm tra tình trạng</option>
                    <option value="Đại tu">Đại tu</option>
                </select>
            </div>
            <div>
                <label class="form-lbl">Ngày lập </label>
                <input type="date" class="form-inp" />
            </div>
            <div>
                <label class="form-lbl">Ngày dự kiến HT </label>
                <input type="date" class="form-inp" />
            </div>
            <div>
                <label class="form-lbl">Đơn vị thực hiện</label>
                <select class="form-inp">
                    <option>Khoa Công nghệ thông tin</option>
                    <option>Phòng Cơ sở vật chất</option>
                    <option>Toàn trường</option>
                    <option>Đơn vị bên ngoài</option>
                </select>
            </div>
            <div>
                <label class="form-lbl">Chi phí dự kiến </label>
                <input type="text" class="form-inp" placeholder="VD: 2,500,000" />
            </div>
            <div class="full">
                <label class="form-lbl">Thiết bị cần bảo trì </label>
                <select class="form-inp">
                    <option>-- Chọn thiết bị --</option>
                    <option>TB001 — Macbook Pro M3</option>
                    <option>TB002 — Máy chiếu Epson EB-X51</option>
                    <option>TB003 — Bộ thực hành PLC Siemens S7</option>
                    <option>TB004 — Máy in HP LaserJet Pro M404n</option>
                    <option>TB007 — Màn hình Samsung 27" 4K</option>
                </select>
            </div>
            <div class="full">
                <label class="form-lbl">Ghi chú (GhiChu)</label>
                <textarea class="form-inp" rows="3" placeholder="Mô tả công việc cần thực hiện, vật tư dự kiến..."></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('createModal')">Hủy</button>
            <button class="btn-save" onclick="closeModal('createModal')">💾 Lưu kế hoạch</button>
        </div>
    </div>
</div>

<!-- Modal Tạo KH Sửa Chữa Đột Xuất (từ BAOHONG_THIETBI) -->
<div class="modal-overlay" id="urgentModal">
    <div class="modal-box">
        <div class="modal-title" style="color:#e53935">⚡ Lập Kế Hoạch Sửa Chữa Đột Xuất</div>
        <div class="modal-sub">Tạo bản ghi <strong>KEHOACH_BAOTRI</strong> với loại "Sửa chữa đột xuất" từ phiếu báo hỏng</div>
        <div class="modal-grid">
            <div class="highlight-box">
                <strong>Nguồn báo hỏng (BAOHONG_THIETBI):</strong>
                <span id="urgentBHInfo">BH-2024-041 — TB005 Oscilloscope Rigol DS1054Z</span>
            </div>
            <div>
                <label class="form-lbl">ID Kế hoạch mới</label>
                <input type="text" class="form-inp" id="urgentKHId" placeholder="VD: KH-2024-019" />
            </div>
            <div>
                <label class="form-lbl">Loại (TrangThai)</label>
                <input type="text" class="form-inp" value="Sửa chữa đột xuất" readonly style="background:#fce4ec;color:#c62828;font-weight:700" />
            </div>
            <div>
                <label class="form-lbl">Ngày lập (NgayLap)</label>
                <input type="date" class="form-inp" id="urgentNgayLap" />
            </div>
            <div>
                <label class="form-lbl">Ngày dự kiến HT (NgayDuKienHT)</label>
                <input type="date" class="form-inp" />
            </div>
            <div>
                <label class="form-lbl">Đơn vị thực hiện (DonViThucHien)</label>
                <select class="form-inp">
                    <option>Phòng Cơ sở vật chất</option>
                    <option>Đơn vị bên ngoài</option>
                    <option>Nhà sản xuất bảo hành</option>
                </select>
            </div>
            <div>
                <label class="form-lbl">Chi phí dự kiến (ChiPhiDuKien — VNĐ)</label>
                <input type="text" class="form-inp" placeholder="VD: 2,500,000" />
            </div>
            <div class="full">
                <label class="form-lbl">Ghi chú (GhiChu)</label>
                <textarea class="form-inp" rows="3" placeholder="Nguyên nhân sơ bộ, công việc dự kiến..."></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('urgentModal')">Hủy</button>
            <button class="btn-save urgent" onclick="closeModal('urgentModal')">⚡ Tạo kế hoạch đột xuất</button>
        </div>
    </div>
</div>

<script>
    function openCreateModal() { document.getElementById('createModal').classList.add('active'); }
    function openUrgentModal(bhId, bhTb) {
        document.getElementById('urgentBHInfo').textContent = bhId + ' — ' + bhTb;
        document.getElementById('urgentKHId').value = 'KH-2024-0' + Math.floor(Math.random() * 90 + 10);
        document.getElementById('urgentNgayLap').value = new Date().toISOString().split('T')[0];
        document.getElementById('urgentModal').classList.add('active');
    }
    function closeModal(id) { document.getElementById(id).classList.remove('active'); }
    function selectPlan(el, id) {
        document.querySelectorAll('.plan-item').forEach(function (i) { i.classList.remove('selected'); });
        el.classList.add('selected');
    }
    document.querySelectorAll('.modal-overlay').forEach(function (m) {
        m.addEventListener('click', function (e) { if (e.target === m) m.classList.remove('active'); });
    });
</script>
