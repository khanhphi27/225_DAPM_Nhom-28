@model QLTB.Models.LapKeHoachPageViewModel
@{ ViewBag.Title = "Lập Kế Hoạch Bảo Trì - Phòng CSVC"; }

<style>
    .page-hdr h2 {
        color: #1a237e;
        font-weight: 700;
        font-size: 22px;
        margin: 0 0 4px
    }

    .page-hdr p {
        color: #666;
        font-size: 13px;
        margin: 0 0 16px
    }

    .layout-2col {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 18px;
        align-items: start
    }

    .alert-box {
        background: #fff8e1;
        border: 1px solid #ffe082;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 18px
    }

        .alert-box h4 {
            color: #e65100;
            font-size: 13px;
            font-weight: 700;
            margin: 0 0 8px
        }

    .alert-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #fff3e0;
        font-size: 12px
    }

        .alert-item:last-child {
            border: none
        }

    .badge-mucdo {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 10px;
        font-weight: 700
    }

        .badge-mucdo.khan {
            background: #fce4ec;
            color: #c62828
        }

        .badge-mucdo.cao {
            background: #ffe0b2;
            color: #e65100
        }

        .badge-mucdo.tb {
            background: #fff9c4;
            color: #f57f17
        }

        .badge-mucdo.thap {
            background: #e8f5e9;
            color: #2e7d32
        }

    .btn-tao-kh {
        background: #e65100;
        color: #fff;
        border: none;
        border-radius: 5px;
        padding: 4px 10px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer
    }

        .btn-tao-kh:hover {
            background: #bf360c
        }

    .panel {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        overflow: hidden;
        margin-bottom: 18px
    }

    .panel-header {
        padding: 14px 18px;
        border-bottom: 1px solid #f0f2f8;
        display: flex;
        justify-content: space-between;
        align-items: center
    }

        .panel-header h3 {
            font-size: 14px;
            font-weight: 700;
            color: #1a237e;
            margin: 0
        }

    .tab-bar {
        display: flex;
        gap: 4px;
        padding: 12px 18px 0;
        border-bottom: 1px solid #f0f2f8
    }

    .tab-btn {
        padding: 7px 16px;
        border: none;
        background: transparent;
        font-size: 12px;
        font-weight: 600;
        color: #888;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px
    }

        .tab-btn.active {
            color: #1a237e;
            border-color: #1a237e
        }

    .plan-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 18px;
        border-bottom: 1px solid #f0f2f8;
        cursor: pointer;
        transition: background .15s
    }

        .plan-item:hover {
            background: #f8f9ff
        }

        .plan-item.selected {
            background: #eef0fb
        }

    .plan-date {
        text-align: center;
        min-width: 36px
    }

        .plan-date .day {
            font-size: 20px;
            font-weight: 800;
            color: #1a237e;
            line-height: 1
        }

        .plan-date .month {
            font-size: 10px;
            color: #888
        }

    .plan-info {
        flex: 1
    }

    .plan-name {
        font-size: 13px;
        font-weight: 600;
        color: #222;
        margin-bottom: 3px
    }

    .plan-sub {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        font-size: 11px;
        color: #888
    }

    .badge-loai {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 10px;
        font-weight: 700
    }

        .badge-loai.suachua {
            background: #fce4ec;
            color: #c62828
        }

        .badge-loai.dinky {
            background: #e8f5e9;
            color: #2e7d32
        }

    .plan-status {
        font-size: 11px;
        font-weight: 700;
        min-width: 80px;
        text-align: right
    }

        .plan-status.cho {
            color: #fb8c00
        }

        .plan-status.dang {
            color: #1a237e
        }

        .plan-status.hoan {
            color: #43a047
        }

    .detail-panel {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        padding: 20px
    }

        .detail-panel h3 {
            font-size: 14px;
            font-weight: 700;
            color: #1a237e;
            margin: 0 0 16px
        }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 14px
    }

    .detail-item label {
        font-size: 11px;
        color: #888;
        font-weight: 600;
        display: block;
        margin-bottom: 2px
    }

    .detail-item p {
        font-size: 13px;
        color: #333;
        font-weight: 600;
        margin: 0
    }

    .detail-item.full {
        grid-column: 1/-1
    }

    .section-sep {
        font-size: 11px;
        font-weight: 700;
        color: #1a237e;
        text-transform: uppercase;
        padding: 8px 0 5px;
        border-bottom: 1px solid #e8eaf6;
        margin: 12px 0 8px;
        grid-column: 1/-1
    }

    .device-row {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 0;
        border-bottom: 1px solid #f0f2f8;
        font-size: 12px
    }

        .device-row:last-child {
            border: none
        }

    .action-row {
        display: flex;
        gap: 8px;
        margin-top: 16px;
        justify-content: flex-end
    }

    .btn-primary {
        background: #1a237e;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer
    }

    .btn-secondary {
        background: #e8eaf6;
        color: #1a237e;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer
    }

    .btn-danger {
        background: #fce4ec;
        color: #c62828;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer
    }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 1000;
        align-items: center;
        justify-content: center
    }

        .modal-overlay.active {
            display: flex
        }

    .modal-box {
        background: #fff;
        border-radius: 14px;
        padding: 26px 30px;
        width: 660px;
        max-width: 95vw;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0,0,0,.25)
    }

    .modal-title {
        font-size: 17px;
        font-weight: 700;
        color: #1a237e;
        margin-bottom: 4px
    }

    .modal-sub {
        font-size: 12px;
        color: #888;
        margin-bottom: 16px
    }

    .modal-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px
    }

        .modal-grid .full {
            grid-column: 1/-1
        }

    .form-lbl {
        font-size: 12px;
        font-weight: 600;
        color: #555;
        margin-bottom: 4px;
        display: block
    }

    .form-inp {
        width: 100%;
        padding: 9px 12px;
        border: 1px solid #d0d5e8;
        border-radius: 8px;
        font-size: 13px;
        background: #f8f9fe;
        box-sizing: border-box
    }

        .form-inp:focus {
            border-color: #3949ab;
            outline: none;
            box-shadow: 0 0 0 3px rgba(57,73,171,.1)
        }

    .field-sep {
        font-size: 11px;
        font-weight: 700;
        color: #1a237e;
        text-transform: uppercase;
        padding-top: 6px;
        border-top: 1px solid #e8eaf6;
        grid-column: 1/-1;
        margin-top: 6px
    }

    .highlight-bh {
        background: #fff8e1;
        border: 1px solid #ffe082;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 12px;
        color: #795548;
        grid-column: 1/-1
    }

        .highlight-bh strong {
            color: #e65100
        }

    .tb-select-list {
        border: 1px solid #d0d5e8;
        border-radius: 8px;
        padding: 8px;
        background: #f8f9fe;
        max-height: 180px;
        overflow-y: auto
    }

    .tb-check-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 5px 4px;
        font-size: 12px;
        border-bottom: 1px solid #f0f2f8
    }

        .tb-check-item:last-child {
            border: none
        }

    .modal-footer {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 20px
    }

    .btn-cancel {
        background: #f5f5f5;
        color: #555;
        border: none;
        border-radius: 8px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer
    }

    .btn-save {
        background: #1a237e;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 24px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer
    }

        .btn-save.sc {
            background: #e53935
        }

    .empty-state {
        padding: 32px;
        text-align: center;
        color: #aaa;
        font-size: 13px
    }

    .toast {
        position: fixed;
        bottom: 28px;
        right: 28px;
        background: #333;
        color: #fff;
        padding: 12px 20px;
        border-radius: 10px;
        font-size: 13px;
        z-index: 9999;
        display: none
    }

        .toast.ok {
            background: #2e7d32
        }

        .toast.err {
            background: #c62828
        }
</style>

<div class="page-hdr">
    <h2>📅 Lập Kế Hoạch Bảo Trì</h2>
    <p>Quản lý kế hoạch bảo trì định kỳ và sửa chữa từ báo hỏng theo cấu trúc <strong>KEHOACH_BAOTRI → CHITIET_KEHOACH → THIETBI / BAOHONG_THIETBI</strong></p>
</div>

@if (ViewBag.Error != null)
{
<div style="background:#fce4ec;border:1px solid #e57373;border-radius:8px;padding:12px 16px;margin-bottom:16px;color:#c62828;font-size:13px">
    ⚠️ Lỗi: @ViewBag.Error
</div> } @* ══ Alert: báo hỏng chờ lập kế hoạch ══ *@
@if (Model.BaoHongChoCho.Count > 0)
{
<div class="alert-box">
    <h4>⚠️ Có @Model.BaoHongChoCho.Count báo hỏng đang chờ xử lý — cần lập kế hoạch sửa chữa
        <span class="badge badge-danger" style="font-size:13px;margin-left:6px;vertical-align:middle">@ViewBag.SoBaoHongChoXuLy</span>
    </h4>
    @foreach (var bh in Model.BaoHongChoCho)
    {
        var mdCls = bh.MucDoUuTien == "Khẩn cấp" ? "khan" : bh.MucDoUuTien == "Cao" ? "cao" : bh.MucDoUuTien == "Trung bình" ? "tb" : "thap";
        var mdIcon = bh.MucDoUuTien == "Khẩn cấp" ? "🔴" : bh.MucDoUuTien == "Cao" ? "🟠" : bh.MucDoUuTien == "Trung bình" ? "🟡" : "🟢";
<div class="alert-item">
    <div>
        <strong>@bh.ID_BaoHong</strong> — @bh.TenTB
        <span class="badge-mucdo @mdCls" style="margin-left:6px">@mdIcon @bh.MucDoUuTien</span>
        <span style="color:#888;margin-left:8px;font-size:11px">📅 @bh.NgayBao.ToString("dd/MM/yyyy") &nbsp;|&nbsp; 👤 @bh.HoTenNguoiBao</span>
        <div style="color:#795548;font-size:11px;margin-top:2px">💬 @bh.MoTaHong</div>
    </div>
    <button class="btn-tao-kh" onclick="openSuaChuaModal('@bh.ID_BaoHong','@Html.Raw(bh.TenTB.Replace("'","\\\'"))','@bh.ThietBiNo','@Html.Raw(bh.MoTaHong.Replace("'","\\\'"))')">
        ⚡ Lập KH sửa chữa
    </button>
</div>}
</div> }
            else
            {
<div style="background:#e8f5e9;border:1px solid #a5d6a7;border-radius:8px;padding:10px 16px;margin-bottom:16px;font-size:13px;color:#2e7d32">
    ✅ Không có báo hỏng nào đang chờ xử lý
</div>}

<div class="layout-2col">
    @* ── Cột trái: Danh sách kế hoạch ── *@
    <div>
        <div class="panel">
            <div class="panel-header">
                <h3>📋 Danh sách kế hoạch (@Model.DanhSachKeHoach.Count)</h3>
                <button class="btn-primary" style="padding:6px 14px;font-size:12px" onclick="openDinhKyModal()">+ Định kỳ mới</button>
            </div>
            <div class="tab-bar">
                <button class="tab-btn active" onclick="filterKH(this,'tat-ca')">Tất cả</button>
                <button class="tab-btn" onclick="filterKH(this,'cho')">Chờ TH</button>
                <button class="tab-btn" onclick="filterKH(this,'dang')">Đang TH</button>
                <button class="tab-btn" onclick="filterKH(this,'hoan')">Hoàn thành</button>
            </div>
            <div id="khList">
                @if (Model.DanhSachKeHoach.Count == 0)
                {
    <div class="empty-state">Chưa có kế hoạch nào</div>            }
                @foreach (var kh in Model.DanhSachKeHoach)
                {
                    var loaiCls = kh.LoaiKeHoach == "Sửa chữa" ? "suachua" : "dinky";
                    var loaiTxt = kh.LoaiKeHoach == "Sửa chữa" ? "🔧 Sửa chữa" : "📅 Định kỳ";
                    var stCls = kh.TrangThai.Contains("Chờ") ? "cho" : kh.TrangThai.Contains("Đang") ? "dang" : "hoan";
                    var stFilter = kh.TrangThai.Contains("Chờ") ? "cho" : kh.TrangThai.Contains("Đang") ? "dang" : "hoan";
                    var soTB = kh.ChiTiet.Count;
    <div class="plan-item" data-tt="@stFilter" onclick="selectKH(this,'@kh.ID_KeHoach')">
        <div class="plan-date">
            <div class="day">@kh.NgayLap.ToString("dd")</div>
            <div class="month">Th.@kh.NgayLap.ToString("M")</div>
        </div>
        <div class="plan-info">
            <div class="plan-name">@kh.ID_KeHoach — @(kh.GhiChu.Length>50 ? kh.GhiChu.Substring(0,50)+"…" : kh.GhiChu)</div>
            <div class="plan-sub">
                <span>🏢 @kh.DonViThucHien</span>
                <span class="badge-loai @loaiCls">@loaiTxt</span>
                <span>📦 @soTB thiết bị</span>
                @if (kh.ChiPhiDuKien.HasValue)
                {<span>💰 @kh.ChiPhiDuKien.Value.ToString("N0") đ</span>}
            </div>
        </div>
        <div class="plan-status @stCls">@kh.TrangThai</div>
    </div>            }
            </div>
        </div>
    </div>

    @* ── Cột phải: Chi tiết kế hoạch ── *@
    <div class="detail-panel" id="detailPanel">
        <h3>🔍 Chi tiết kế hoạch</h3>
        <div id="detailContent" style="color:#aaa;font-size:13px;text-align:center;padding:40px 0">
            Chọn một kế hoạch ở danh sách bên trái để xem chi tiết
        </div>
    </div>
</div>

@* ── Modal Lập KH sửa chữa (từ báo hỏng) ── *@
<div class="modal-overlay" id="scModal">
    <div class="modal-box">
        <div class="modal-title" style="color:#e53935">⚡ Lập Kế Hoạch Sửa Chữa</div>
        <div class="modal-sub">Tạo kế hoạch từ phiếu báo hỏng → bản ghi <strong>KEHOACH_BAOTRI</strong> + <strong>CHITIET_KEHOACH</strong></div>
        <div class="modal-grid">
            <div class="highlight-bh full">
                <strong>📎 Nguồn báo hỏng (BAOHONG_THIETBI):</strong>
                <span id="scBHInfo">—</span>
                <div id="scMoTa" style="color:#795548;margin-top:4px"></div>
            </div>
            <input type="hidden" id="scBHId" />
            <input type="hidden" id="scTBId" />
            <div>
                <label class="form-lbl">ID Kế hoạch *</label>
                <input type="text" class="form-inp" id="scKHId" placeholder="VD: KH_019" />
            </div>
            <div>
                <label class="form-lbl">Loại</label>
                <input type="text" class="form-inp" value="Sửa chữa" readonly style="background:#fce4ec;color:#c62828;font-weight:700" />
            </div>
            <div>
                <label class="form-lbl">Ngày lập *</label>
                <input type="date" class="form-inp" id="scNgayLap" />
            </div>
            <div>
                <label class="form-lbl">Ngày dự kiến HT</label>
                <input type="date" class="form-inp" id="scNgayHT" />
            </div>
            <div class="full">
                <label class="form-lbl">Đơn vị thực hiện</label>
                <input type="text" class="form-inp" id="scDonVi" placeholder="VD: Công ty CP Máy tính AMC" />
            </div>
            <div>
                <label class="form-lbl">Chi phí dự kiến (VNĐ)</label>
                <input type="text" class="form-inp" id="scChiPhi" placeholder="VD: 2500000" />
            </div>
            <div class="full">
                <label class="form-lbl">Ghi chú / Mô tả công việc</label>
                <textarea class="form-inp" id="scGhiChu" rows="2" placeholder="Mô tả công việc dự kiến..."></textarea>
            </div>
            <div class="full">
                <label class="form-lbl">Thêm thiết bị khác vào cùng kế hoạch (tùy chọn)</label>
                <div class="tb-select-list" id="scTBExtra">
                    @foreach (var tb in Model.DanhSachThietBi)
                    {
                        var mdIcon = tb.MucDoUuTienBaoHong == "Khẩn cấp" ? "🔴" : tb.MucDoUuTienBaoHong == "Cao" ? "🟠" : tb.MucDoUuTienBaoHong == "Trung bình" ? "🟡" : "🟢";
        <div class="tb-check-item">
            <input type="checkbox" class="sc-extra-tb" value="@tb.ID_ThietBi" id="sctb_@tb.ID_ThietBi" data-bh-id="@tb.BaoHongNo" />
            <label for="sctb_@tb.ID_ThietBi" style="cursor:pointer">
                <strong>@tb.ID_ThietBi</strong> — @tb.TenTB
                <span style="color:#888;font-size:11px">[@tb.DanhMuc]</span>
                @if (tb.DangBaoHong)
                {<span style="background:#fff3e0;color:#e65100;padding:1px 6px;border-radius:4px;font-size:10px;margin-left:4px">📎 @tb.BaoHongNo @mdIcon @tb.MucDoUuTienBaoHong</span>}
            </label>
            <textarea class="form-inp" id="scnote_@tb.ID_ThietBi" rows="2" style="margin-top:6px" placeholder="Ghi chú chi tiết cho thiết bị này (tùy chọn)"></textarea>
        </div>}
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('scModal')">Hủy</button>
            <button class="btn-save sc" onclick="luuKHSuaChua()">⚡ Tạo kế hoạch sửa chữa</button>
        </div>
    </div>
</div>

@* ── Modal Lập KH Định Kỳ ── *@
<div class="modal-overlay" id="dkModal">
    <div class="modal-box">
        <div class="modal-title">📅 Lập Kế Hoạch Bảo Trì Định Kỳ</div>
        <div class="modal-sub">Tạo kế hoạch không cần báo hỏng → <strong>CHITIET_KEHOACH.BaoHongNo = NULL</strong></div>
        <div class="modal-grid">
            <div>
                <label class="form-lbl">ID Kế hoạch *</label>
                <input type="text" class="form-inp" id="dkKHId" placeholder="VD: KH_020" />
            </div>
            <div>
                <label class="form-lbl">Loại</label>
                <input type="text" class="form-inp" value="Định kỳ" readonly style="background:#e8f5e9;color:#2e7d32;font-weight:700" />
            </div>
            <div>
                <label class="form-lbl">Ngày lập *</label>
                <input type="date" class="form-inp" id="dkNgayLap" />
            </div>
            <div>
                <label class="form-lbl">Ngày dự kiến HT</label>
                <input type="date" class="form-inp" id="dkNgayHT" />
            </div>
            <div class="full">
                <label class="form-lbl">Đơn vị thực hiện</label>
                <input type="text" class="form-inp" id="dkDonVi" placeholder="VD: Đội Kỹ thuật Trường" />
            </div>
            <div>
                <label class="form-lbl">Chi phí dự kiến (VNĐ)</label>
                <input type="text" class="form-inp" id="dkChiPhi" placeholder="VD: 5000000" />
            </div>
            <div class="full">
                <label class="form-lbl">Ghi chú</label>
                <textarea class="form-inp" id="dkGhiChu" rows="2" placeholder="Mô tả nội dung bảo trì định kỳ..."></textarea>
            </div>
            <div class="field-sep">Chọn thiết bị cần bảo trì *</div>
            <div class="full">
                <div class="tb-select-list" id="dkTBList">
                    @foreach (var tb in Model.DanhSachThietBi)
                    {
                        var mdIcon = tb.MucDoUuTienBaoHong == "Khẩn cấp" ? "🔴" : tb.MucDoUuTienBaoHong == "Cao" ? "🟠" : tb.MucDoUuTienBaoHong == "Trung bình" ? "🟡" : "🟢";
        <div class="tb-check-item">
            <input type="checkbox" class="dk-tb" value="@tb.ID_ThietBi" id="dktb_@tb.ID_ThietBi" />
            <label for="dktb_@tb.ID_ThietBi" style="cursor:pointer">
                <strong>@tb.ID_ThietBi</strong> — @tb.TenTB
                <span style="color:#888;font-size:11px">[@tb.DanhMuc | @tb.TrangThai]</span>
                @if (tb.DangBaoHong)
                {<span style="background:#fff3e0;color:#e65100;padding:1px 6px;border-radius:4px;font-size:10px;margin-left:4px">📎 @tb.BaoHongNo @mdIcon @tb.MucDoUuTienBaoHong</span>}
            </label>
            <textarea class="form-inp" id="dknote_@tb.ID_ThietBi" rows="2" style="margin-top:6px" placeholder="Ghi chú chi tiết cho thiết bị này (tùy chọn)"></textarea>
        </div>}
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('dkModal')">Hủy</button>
            <button class="btn-save" onclick="luuKHDinhKy()">💾 Lưu kế hoạch định kỳ</button>
        </div>
    </div>
</div>

<div class="toast" id="toast"></div>

<script>
    var currentKHId = null;

    // ── Tab filter ──
    function filterKH(btn, type) {
        document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');
        document.querySelectorAll('.plan-item').forEach(function (item) {
            item.style.display = (type === 'tat-ca' || item.dataset.tt === type) ? '' : 'none';
        });
    }

    // ── Chọn kế hoạch → load chi tiết ──
    function selectKH(el, id) {
        document.querySelectorAll('.plan-item').forEach(function (i) { i.classList.remove('selected'); });
        el.classList.add('selected');
        currentKHId = id;
        document.getElementById('detailContent').innerHTML = '<div style="padding:20px;text-align:center;color:#888">Đang tải...</div>';
        fetch('/CSVC/GetKeHoachDetail?id=' + encodeURIComponent(id))
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data.ok) { showToast('Lỗi: ' + data.msg, false); return; }
                var kh = data.keHoach;
                var ct = data.chiTiet;
                var ls = data.lichSu || [];
                var loaiCls = kh.LoaiKeHoach === 'Sửa chữa' ? 'suachua' : 'dinky';
                var ctHtml = ct.length === 0 ? '<div style="color:#aaa;font-size:12px;padding:8px 0">Chưa có thiết bị</div>' :
                    ct.map(function (c) {
                        var src = c.BaoHongNo
                            ? '<span style="background:#fff3e0;color:#e65100;padding:2px 6px;border-radius:6px;font-size:10px">📎 ' + c.BaoHongNo + '</span>'
                            : '<span style="background:#e8f5e9;color:#2e7d32;padding:2px 6px;border-radius:6px;font-size:10px">📅 Định kỳ</span>';
                        return '<div class="device-row">📦 <strong>' + c.ThietBiNo + '</strong> — ' + c.TenTB +
                            ' <span style="color:#888;font-size:11px">[' + c.TenDanhMuc + ']</span> ' + src +
                            (c.GhiChuChiTiet ? '<span style="color:#888;font-size:11px"> — ' + c.GhiChuChiTiet + '</span>' : '') + '</div>';
                    }).join('');
                var lsHtml = ls.length === 0 ? '<div style="color:#aaa;font-size:12px;padding:8px 0">Chưa có ghi nhận sửa chữa</div>' :
                    ls.map(function (g) {
                        var ttCls = (g.TrangThaiSauSua || '').indexOf('Hoạt động tốt') >= 0 ? 'ok' : (g.TrangThaiSauSua || '').indexOf('Tạm thời') >= 0 ? 'warn' : 'bad';
                        var tien = g.ChiPhiThucTe > 0 ? Number(g.ChiPhiThucTe).toLocaleString('vi-VN') + ' đ' : '—';
                        return '<div class="history-item" style="padding:10px 0">' +
                            '<div class="hi-head"><span class="hi-name">' + g.ID_GhiNhan + '</span><span class="hi-date">' + g.NgayThucHien + '</span></div>' +
                            '<div class="hi-detail"><span>📦 ' + (g.TenTB || g.ThietBiNo || '—') + '</span>' +
                            (g.BaoHongNo ? '<span style="color:#e65100">📎 ' + g.BaoHongNo + '</span>' : '') +
                            '</div>' +
                            '<div class="hi-detail" style="margin-top:3px"><span class="badge-tt ' + ttCls + '">' + (g.TrangThaiSauSua || '—') + '</span>' +
                            '<span style="margin-left:8px">💰 ' + tien + '</span></div>' +
                            (g.KetQua ? '<div style="font-size:12px;color:#666;margin-top:4px">' + g.KetQua + '</div>' : '') +
                            '</div>';
                    }).join('');
                document.getElementById('detailContent').innerHTML =
                    '<div class="detail-grid">' +
                    '<div class="detail-item"><label>ID Kế hoạch</label><p>' + kh.ID_KeHoach + '</p></div>' +
                    '<div class="detail-item"><label>Loại bảo trì</label><p><span class="badge-loai ' + loaiCls + '">' + kh.LoaiKeHoach + '</span></p></div>' +
                    '<div class="detail-item"><label>Ngày lập</label><p>' + kh.NgayLap + '</p></div>' +
                    '<div class="detail-item"><label>Ngày dự kiến HT</label><p>' + (kh.NgayDuKienHT || '—') + '</p></div>' +
                    '<div class="detail-item"><label>Người lập</label><p>' + kh.HoTen + '</p></div>' +
                    '<div class="detail-item"><label>Đơn vị thực hiện</label><p>' + (kh.DonViThucHien || '—') + '</p></div>' +
                    '<div class="detail-item"><label>Chi phí dự kiến</label><p>' + (kh.ChiPhiDuKien > 0 ? Number(kh.ChiPhiDuKien).toLocaleString('vi-VN') + ' đ' : '—') + '</p></div>' +
                    '<div class="detail-item"><label>Trạng thái</label><p style="color:#1a237e;font-weight:700">' + kh.TrangThai + '</p></div>' +
                    (kh.GhiChu ? '<div class="detail-item full"><label>Ghi chú</label><p>' + kh.GhiChu + '</p></div>' : '') +
                    '<div class="section-sep">Thiết bị trong kế hoạch (' + ct.length + ')</div>' +
                    '<div class="full">' + ctHtml + '</div>' +
                    '<div class="section-sep">Lịch sử ghi nhận (' + ls.length + ')</div>' +
                    '<div class="full">' + lsHtml + '</div>' +
                    '</div>' +
                    '<div class="action-row">' +
                    (kh.TrangThai === 'Chờ thực hiện' ? '<button class="btn-danger" onclick="xoaKH(\'' + kh.ID_KeHoach + '\')">🗑 Xóa</button>' : '') +
                    '<a href="/CSVC/GhiNhanSuaChua" class="btn-primary" style="text-decoration:none;display:inline-block">📝 Ghi nhận kết quả</a>' +
                    '</div>';
            })
            .catch(function (e) { showToast('Lỗi kết nối: ' + e.message, false); });
    }

    // ── Modal sửa chữa (từ BH) ──
    function openSuaChuaModal(bhId, tbName, tbId, moTa) {
        document.getElementById('scBHId').value = bhId;
        document.getElementById('scTBId').value = tbId;
        document.getElementById('scBHInfo').textContent = bhId + ' — ' + tbName;
        document.getElementById('scMoTa').textContent = '💬 ' + moTa;
        document.getElementById('scKHId').value = 'KH_' + Date.now().toString().slice(-5);
        document.getElementById('scNgayLap').value = new Date().toISOString().split('T')[0];
        // Reset danh sách chọn và ưu tiên check sẵn thiết bị từ báo hỏng vừa bấm
        document.querySelectorAll('.sc-extra-tb').forEach(function (cb) {
            cb.checked = false;
        });
        document.querySelectorAll('[id^="scnote_"]').forEach(function (n) {
            n.value = '';
        });
        var mainCb = document.getElementById('sctb_' + tbId);
        if (mainCb) {
            mainCb.checked = true;
        }
        document.getElementById('scModal').classList.add('active');
    }

    // ── Modal định kỳ ──
    function openDinhKyModal() {
        document.getElementById('dkKHId').value = 'KH_' + Date.now().toString().slice(-5);
        document.getElementById('dkNgayLap').value = new Date().toISOString().split('T')[0];
        document.querySelectorAll('.dk-tb').forEach(function (cb) { cb.checked = false; });
        document.querySelectorAll('[id^="dknote_"]').forEach(function (n) { n.value = ''; });
        document.getElementById('dkModal').classList.add('active');
    }

    function closeModal(id) { document.getElementById(id).classList.remove('active'); }

    // ── Lưu KH sửa chữa ──
    function luuKHSuaChua() {
        var id = document.getElementById('scKHId').value.trim();
        if (!id) { showToast('Vui lòng nhập ID kế hoạch', false); return; }
        var checked = document.querySelectorAll('.sc-extra-tb:checked');
        if (checked.length === 0) { showToast('Vui lòng chọn ít nhất 1 thiết bị', false); return; }

        var thietBiIds = [];
        var baoHongIds = [];
        var ghiChuCTs = [];
        checked.forEach(function (cb) {
            thietBiIds.push(cb.value);
            baoHongIds.push(cb.getAttribute('data-bh-id') || '');
            var note = document.getElementById('scnote_' + cb.value);
            ghiChuCTs.push(note ? note.value : '');
        });

        var params = new URLSearchParams({
            idKeHoach: id,
            loaiKeHoach: 'Sửa chữa',
            ngayLap: document.getElementById('scNgayLap').value,
            ngayDuKienHT: document.getElementById('scNgayHT').value,
            donViThucHien: document.getElementById('scDonVi').value,
            chiPhiDuKien: document.getElementById('scChiPhi').value,
            ghiChu: document.getElementById('scGhiChu').value
        });
        thietBiIds.forEach(function (v, i) { params.append('thietBiIds[' + i + ']', v); });
        baoHongIds.forEach(function (v, i) { params.append('baoHongIds[' + i + ']', v); });
        ghiChuCTs.forEach(function (v, i) { params.append('ghiChuChiTiets[' + i + ']', v); });

        postAction('/CSVC/LuuKeHoach', params, function (data) {
            if (data.ok) { showToast(data.msg, true); closeModal('scModal'); setTimeout(function () { location.reload(); }, 1200); }
            else showToast(data.msg, false);
        });
    }

    // ── Lưu KH định kỳ ──
    function luuKHDinhKy() {
        var id = document.getElementById('dkKHId').value.trim();
        var checked = document.querySelectorAll('.dk-tb:checked');
        if (!id) { showToast('Vui lòng nhập ID kế hoạch', false); return; }
        if (checked.length === 0) { showToast('Vui lòng chọn ít nhất 1 thiết bị', false); return; }

        var params = new URLSearchParams({
            idKeHoach: id,
            loaiKeHoach: 'Định kỳ',
            ngayLap: document.getElementById('dkNgayLap').value,
            ngayDuKienHT: document.getElementById('dkNgayHT').value,
            donViThucHien: document.getElementById('dkDonVi').value,
            chiPhiDuKien: document.getElementById('dkChiPhi').value,
            ghiChu: document.getElementById('dkGhiChu').value
        });
        checked.forEach(function (cb, i) {
            params.append('thietBiIds[' + i + ']', cb.value);
            params.append('baoHongIds[' + i + ']', '');
            var note = document.getElementById('dknote_' + cb.value);
            params.append('ghiChuChiTiets[' + i + ']', note ? note.value : '');
        });

        postAction('/CSVC/LuuKeHoach', params, function (data) {
            if (data.ok) { showToast(data.msg, true); closeModal('dkModal'); setTimeout(function () { location.reload(); }, 1200); }
            else showToast(data.msg, false);
        });
    }

    // ── Xóa kế hoạch ──
    function xoaKH(id) {
        if (!confirm('Xóa kế hoạch ' + id + '? Các báo hỏng liên quan sẽ trở lại Chờ xử lý.')) return;
        var params = new URLSearchParams({ id: id });
        postAction('/CSVC/XoaKeHoach', params, function (data) {
            if (data.ok) { showToast('Đã xóa kế hoạch', true); setTimeout(function () { location.reload(); }, 1000); }
            else showToast(data.msg, false);
        });
    }

    // ── Helpers ──
    function postAction(url, params, cb) {
        fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString() })
            .then(function (r) { return r.json(); }).then(cb)
            .catch(function (e) { showToast('Lỗi kết nối: ' + e.message, false); });
    }

    function showToast(msg, ok) {
        var t = document.getElementById('toast');
        t.textContent = msg;
        t.className = 'toast ' + (ok ? 'ok' : 'err');
        t.style.display = 'block';
        setTimeout(function () { t.style.display = 'none'; }, 3000);
    }

    document.querySelectorAll('.modal-overlay').forEach(function (m) {
        m.addEventListener('click', function (e) { if (e.target === m) m.classList.remove('active'); });
    });
</script>
