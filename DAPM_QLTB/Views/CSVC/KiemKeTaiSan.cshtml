@model QLTB.Models.KiemKeTaiSanViewModel
@using System.Linq
@{
    ViewBag.Title = "Kiểm Kê Tài Sản - Phòng CSVC";
    int phanTram = Model.TongThietBi > 0 ? (int)((double)Model.DaKiemKe / Model.TongThietBi * 100) : 0;
}

<style>
    body, td, th, select, input, button, a { font-size: 15px; }

    .page-hdr h2 { color:#1a237e; font-weight:700; font-size:24px; margin:0; }
    .page-hdr p  { color:#666; font-size:14px; margin:3px 0 0; }

    .kk-progress-card {
        background:#fff; border-radius:12px;
        box-shadow:0 2px 10px rgba(0,0,0,.07);
        padding:22px 26px; margin-bottom:20px;
    }
    .kk-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:18px; }
    .kk-stat { text-align:center; }
    .kk-stat .num { font-size:32px; font-weight:800; }
    .kk-stat .lbl { font-size:13px; color:#888; font-weight:600; margin-top:3px; }
    .kk-stat.total .num   { color:#1a237e; }
    .kk-stat.done .num    { color:#43a047; }
    .kk-stat.pending .num { color:#fb8c00; }

    .progress-bar-wrap { background:#f0f2f8; border-radius:8px; height:12px; overflow:hidden; }
    .progress-bar { height:100%; background:linear-gradient(90deg,#43a047,#66bb6a); border-radius:8px; transition:width .6s; }
    .progress-label { display:flex; justify-content:space-between; font-size:13px; color:#888; margin-top:7px; }

    .toolbar { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; flex-wrap:wrap; gap:10px; }
    .btn-primary   { background:#1a237e; color:#fff; border:none; border-radius:8px; padding:10px 20px; font-size:14px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-block; }
    .btn-secondary { background:#e8eaf6; color:#1a237e; border:none; border-radius:8px; padding:10px 20px; font-size:14px; font-weight:600; cursor:pointer; }

    .card-table { background:#fff; border-radius:12px; box-shadow:0 2px 10px rgba(0,0,0,.07); overflow:hidden; }
    .card-table table { width:100%; border-collapse:collapse; }
    .card-table thead th {
        background:#e8eaf6; color:#1a237e; font-size:13px; font-weight:700;
        text-transform:uppercase; letter-spacing:.4px; padding:14px 16px;
        border:none; white-space:nowrap;
    }
    .card-table tbody td { padding:13px 16px; font-size:14px; color:#333; border-bottom:1px solid #f0f2f8; vertical-align:middle; }
    .card-table tbody tr:last-child td { border-bottom:none; }
    .card-table tbody tr:hover td { background:#f5f6ff; }

    .group-header td { background:#f0f2ff; padding:10px 16px; font-size:13px; font-weight:700; color:#1a237e; }

    .kk-status { display:inline-flex; align-items:center; gap:5px; padding:5px 12px; border-radius:20px; font-size:12px; font-weight:700; }
    .kk-status.done    { background:#e8f5e9; color:#2e7d32; }
    .kk-status.pending { background:#fff3e0; color:#e65100; }

    .tb-status { display:inline-block; padding:4px 10px; border-radius:12px; font-size:12px; font-weight:600; }
    .tb-status.hoatdong { background:#e8f5e9; color:#2e7d32; }
    .tb-status.baotri   { background:#fff3e0; color:#e65100; }
    .tb-status.hong     { background:#fce4ec; color:#c62828; }
    .tb-status.other    { background:#f5f5f5; color:#555; }

    .alert-error { background:#fce4ec; border:1px solid #ef9a9a; border-radius:10px; padding:14px 18px; color:#c62828; font-size:14px; margin-bottom:16px; }

    .sl-cell { text-align:center; font-size:15px; font-weight:700; }
    .sl-he-thong { color:#1a237e; }
    .sl-thuc-te  { color:#43a047; }
</style>

<div class="page-hdr" style="margin-bottom:22px">
    <h2>📊 Kiểm Kê Tài Sản Thiết Bị</h2>
    <p>Xem tình trạng kiểm kê toàn bộ thiết bị trong hệ thống</p>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert-error">⚠️ @ViewBag.Error</div>
}

<div class="kk-progress-card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px">
        <div style="font-size:16px;font-weight:700;color:#1a237e">📋 Tổng quan kiểm kê tài sản</div>
        <div style="font-size:13px;color:#888">Cập nhật: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
    </div>
    <div class="kk-stats">
        <div class="kk-stat total">
            <div class="num">@Model.TongThietBi</div>
            <div class="lbl">Tổng thiết bị</div>
        </div>
        <div class="kk-stat done">
            <div class="num">@Model.DaKiemKe</div>
            <div class="lbl">Đã kiểm kê</div>
        </div>
        <div class="kk-stat pending">
            <div class="num">@Model.ChuaKiemKe</div>
            <div class="lbl">Chưa kiểm kê</div>
        </div>
    </div>
    <div class="progress-bar-wrap">
        <div class="progress-bar" style="width:@(phanTram)%"></div>
    </div>
    <div class="progress-label">
        <span>Tiến độ: <strong>@phanTram%</strong> (@Model.DaKiemKe/@Model.TongThietBi thiết bị)</span>
        <span>Còn lại: <strong>@Model.ChuaKiemKe thiết bị</strong></span>
    </div>
</div>

<div class="toolbar">
    <div style="font-size:15px;color:#555">
        Danh sách <strong>@Model.TongThietBi</strong> thiết bị trong hệ thống
    </div>
    <div style="display:flex;gap:10px">
        @if (Model.ChuaKiemKe > 0)
        {
            <a href="@Url.Action("TaoPhieuKiemKe","CSVC")" class="btn-primary">📝 Tạo phiếu kiểm kê (@Model.ChuaKiemKe chưa kiểm)</a>
        }
        else
        {
            <button class="btn-secondary" disabled>✅ Tất cả đã kiểm kê</button>
        }
    </div>
</div>

<div class="card-table">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Mã TB</th>
                <th>Tên thiết bị</th>
                <th>Danh mục</th>
                <th>Đơn vị quản lý</th>
                <th>Trạng thái TB</th>
                <th>SL Sổ sách</th>
                <th>SL Thực tế</th>
                <th>Tình trạng KK</th>
                <th>Ngày kiểm kê</th>
                <th>Ghi chú</th>
                <th>KQ Kiểm kê</th>
            </tr>
        </thead>
        <tbody>
            @{
                string currentKhoa = null;
                int stt = 0;
            }
            @foreach (var tb in Model.DanhSachThietBi)
            {
                if (tb.TenKhoa != currentKhoa)
                {
                    currentKhoa = tb.TenKhoa;
                    int soTBKhoa  = Model.DanhSachThietBi.Count(x => x.TenKhoa == currentKhoa);
                    int daKKKhoa  = Model.DanhSachThietBi.Count(x => x.TenKhoa == currentKhoa && x.NgayKiemKe.HasValue);
                    <tr class="group-header">
                        <td colspan="12">🏢 @currentKhoa — @soTBKhoa thiết bị (đã kiểm @daKKKhoa/@soTBKhoa)</td>
                    </tr>
                }
                stt++;
                string trangThaiClass = tb.TrangThaiTB == "Hoạt động" ? "hoatdong"
                                      : tb.TrangThaiTB == "Bảo trì"   ? "baotri"
                                      : tb.TrangThaiTB == "Hỏng"      ? "hong" : "other";
                <tr>
                    <td style="color:#aaa;font-size:13px">@stt</td>
                    <td><strong style="color:#1a237e">@tb.ID_ThietBi</strong></td>
                    <td>@tb.TenTB</td>
                    <td style="color:#666">@tb.TenDanhMuc</td>
                    <td>@tb.TenKhoa</td>
                    <td><span class="tb-status @trangThaiClass">@tb.TrangThaiTB</span></td>
                    <td class="sl-cell">
                        <span class="sl-he-thong">@tb.SoLuongHeThong</span>
                    </td>
                    <td class="sl-cell">
                        @if (tb.SoLuongThucTe.HasValue)
                        { <span class="sl-thuc-te">@tb.SoLuongThucTe</span> }
                        else
                        { <span style="color:#aaa">—</span> }
                    </td>
                    <td style="color:#555">@(tb.TinhTrangThucTe ?? "—")</td>
                    <td style="color:#666">
                        @if (tb.NgayKiemKe.HasValue)
                        { @tb.NgayKiemKe.Value.ToString("dd/MM/yyyy") }
                        else
                        { <span style="color:#aaa">—</span> }
                    </td>
                    <td style="color:#666;max-width:160px">@(tb.GhiChu ?? "")</td>
                    <td>
                        @if (tb.NgayKiemKe.HasValue)
                        { <span class="kk-status done">✅ Đã kiểm</span> }
                        else
                        { <span class="kk-status pending">⏳ Chưa kiểm</span> }
                    </td>
                </tr>
            }
            @if (!Model.DanhSachThietBi.Any())
            {
                <tr><td colspan="12" style="text-align:center;padding:30px;color:#aaa">Chưa có thiết bị nào trong hệ thống</td></tr>
            }
        </tbody>
    </table>
</div>
