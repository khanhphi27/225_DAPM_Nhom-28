@{ ViewBag.Title = "Ghi Nhận Sửa Chữa - Phòng CSVC"; }

<style>
    .page-hdr {
        margin-bottom: 18px;
    }

        .page-hdr h2 {
            color: #1a237e;
            font-weight: 700;
            font-size: 22px;
            margin: 0 0 4px;
        }

        .page-hdr p {
            color: #666;
            font-size: 13px;
            margin: 0;
        }

    .two-col {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 18px;
        align-items: start;
    }

    /* Panel */
    .panel {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        overflow: hidden;
        margin-bottom: 16px;
    }

    .panel-header {
        padding: 13px 18px;
        border-bottom: 1px solid #f0f2f8;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .panel-header h3 {
            font-size: 14px;
            font-weight: 700;
            color: #1a237e;
            margin: 0;
        }

        .panel-header span {
            font-size: 11px;
            color: #888;
        }

    /* Tab mini */
    .tab-mini {
        display: flex;
        gap: 4px;
        padding: 10px 16px 0;
        border-bottom: 1px solid #f0f2f8;
    }

    .tab-mini-btn {
        padding: 5px 14px;
        border-radius: 6px 6px 0 0;
        border: none;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        background: transparent;
        color: #888;
        border-bottom: 2px solid transparent;
    }

        .tab-mini-btn.active {
            background: #e8eaf6;
            color: #1a237e;
            border-color: #1a237e;
        }

    /* Danh sách báo hỏng / kế hoạch hoàn thành */
    .report-item {
        padding: 11px 16px;
        border-bottom: 1px solid #f0f2f8;
        cursor: pointer;
        transition: background .12s;
    }

        .report-item:hover {
            background: #f8f9ff;
        }

        .report-item.selected {
            background: #eef0fb;
            border-left: 3px solid #1a237e;
        }

        .report-item:last-child {
            border-bottom: none;
        }

    .ri-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 4px;
    }

    .ri-code {
        font-size: 12px;
        font-weight: 700;
        color: #1a237e;
    }

    .ri-name {
        font-size: 12px;
        color: #333;
        font-weight: 600;
        margin-bottom: 3px;
    }

    .ri-meta {
        font-size: 11px;
        color: #888;
    }

    .ri-kh {
        font-size: 11px;
        color: #1a237e;
        margin-top: 2px;
        font-weight: 600;
    }

    .badge-urg {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 10px;
        font-weight: 700;
    }

        .badge-urg.high {
            background: #fce4ec;
            color: #c62828;
        }

        .badge-urg.medium {
            background: #fff3e0;
            color: #e65100;
        }

        .badge-urg.low {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .badge-urg.kh {
            background: #e8eaf6;
            color: #1a237e;
        }

    /* Form ghi nhận */
    .repair-form {
        padding: 18px;
    }

    .device-info-box {
        background: #f8f9fe;
        border: 1px solid #e8eaf6;
        border-radius: 8px;
        padding: 14px;
        margin-bottom: 14px;
    }

        .device-info-box h5 {
            font-size: 12px;
            font-weight: 700;
            color: #1a237e;
            margin: 0 0 10px;
        }

    .di-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .di-item label {
        font-size: 10px;
        color: #888;
        font-weight: 600;
        display: block;
        margin-bottom: 2px;
    }

    .di-item p {
        font-size: 12px;
        color: #333;
        font-weight: 600;
        margin: 0;
    }

    .di-item.full {
        grid-column: 1/-1;
    }

    .bh-source {
        background: #fff3e0;
        border: 1px solid #ffe082;
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 11px;
        color: #795548;
        margin-bottom: 4px;
    }

        .bh-source strong {
            color: #e65100;
        }

    .section-title {
        font-size: 11px;
        font-weight: 700;
        color: #1a237e;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: 10px 0 6px;
        border-bottom: 1px solid #e8eaf6;
        margin: 12px 0 10px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 12px;
    }

        .form-row.single {
            grid-template-columns: 1fr;
        }

    .form-lbl {
        font-size: 12px;
        font-weight: 600;
        color: #555;
        margin-bottom: 4px;
        display: block;
    }

    .form-inp {
        width: 100%;
        padding: 8px 11px;
        border: 1px solid #d0d5e8;
        border-radius: 7px;
        font-size: 13px;
        background: #f8f9fe;
        box-sizing: border-box;
    }

        .form-inp:focus {
            border-color: #3949ab;
            outline: none;
        }

        .form-inp[readonly] {
            background: #f0f0f0;
            color: #888;
        }

    /* Bảng vật tư */
    .parts-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
        margin-bottom: 8px;
    }

        .parts-table th {
            background: #e8eaf6;
            color: #1a237e;
            padding: 7px 10px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
        }

        .parts-table td {
            padding: 6px 8px;
            border-bottom: 1px solid #f0f2f8;
            vertical-align: middle;
        }

            .parts-table td input {
                border: 1px solid #d0d5e8;
                border-radius: 4px;
                padding: 4px 6px;
                font-size: 12px;
                width: 100%;
                box-sizing: border-box;
                background: #f8f9fe;
            }

        .parts-table tfoot td {
            font-weight: 700;
            color: #1a237e;
            padding: 8px 10px;
            background: #f8f9fe;
        }

    .btn-add-part {
        background: #e8eaf6;
        color: #1a237e;
        border: none;
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        margin-bottom: 12px;
    }

    /* Trạng thái sau sửa */
    .status-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

    .status-opt {
        padding: 8px 14px;
        border-radius: 8px;
        border: 2px solid #e0e0e0;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        background: #fff;
        color: #666;
        transition: all .15s;
    }

        .status-opt.selected.ok {
            border-color: #43a047;
            background: #e8f5e9;
            color: #2e7d32;
        }

        .status-opt.selected.repair {
            border-color: #fb8c00;
            background: #fff3e0;
            color: #e65100;
        }

        .status-opt.selected.broken {
            border-color: #e53935;
            background: #fce4ec;
            color: #c62828;
        }

    .form-footer {
        margin-top: 16px;
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

    .btn-save {
        background: #1a237e;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 24px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-cancel {
        background: #f5f5f5;
        color: #555;
        border: none;
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    /* Lịch sử tab -->*/
    .history-item {
        padding: 12px 18px;
        border-bottom: 1px solid #f0f2f8;
    }

        .history-item:last-child {
            border: none;
        }

    .hi-head {
        display: flex;
        justify-content: space-between;
        margin-bottom: 4px;
    }

    .hi-name {
        font-size: 13px;
        font-weight: 700;
        color: #333;
    }

    .hi-date {
        font-size: 11px;
        color: #888;
    }

    .hi-detail {
        font-size: 12px;
        color: #666;
    }

        .hi-detail span {
            margin-right: 12px;
        }
</style>

<div class="page-hdr">
    <h2>🛠️ Ghi Nhận Sửa Chữa Thiết Bị</h2>
    <p>Ghi kết quả vào bảng <strong>GHINHAN_SUA_CHUA</strong> dựa trên kế hoạch <strong>KEHOACH_BAOTRI</strong> đã được lập (kể cả sửa chữa đột xuất từ <strong>BAOHONG_THIETBI</strong>)</p>
</div>

<div class="two-col">
    <!-- Cột trái -->
    <div>
        <!-- Danh sách kế hoạch chờ ghi nhận -->
        <div class="panel">
            <div class="panel-header">
                <h3>📋 Kế hoạch chờ ghi nhận (KEHOACH_BAOTRI)</h3>
                <span style="color:#e65100;font-weight:700">5 chưa ghi nhận</span>
            </div>
            <div class="tab-mini">
                <button class="tab-mini-btn active">Chờ ghi nhận</button>
                <button class="tab-mini-btn">Đang thực hiện</button>
                <button class="tab-mini-btn">Đã ghi nhận</button>
            </div>
            <div style="padding:8px 0">
                @{ var items = new[] {
                        new { khId="KH-2024-018", bhId="BH-2024-041", tbCode="TB005", tbName="Oscilloscope Rigol DS1054Z",  moTa="Kênh 1 không hiển thị tín hiệu",     don="Khoa Công nghệ thông tin", ngay="08/04/2024", urgency="high",   urgTxt="🔴 Đột xuất", selected=true  },
                        new { khId="KH-2024-015", bhId="BH-2024-039", tbCode="TB002", tbName="Máy chiếu Epson EB-X51",       moTa="Đèn yếu, hình mờ khi chiếu",        don="Khoa Công nghệ thông tin", ngay="06/04/2024", urgency="medium", urgTxt="🟡 Đột xuất", selected=false },
                        new { khId="KH-2024-017", bhId="",            tbCode="TB001", tbName="Macbook Pro M3",                moTa="Bảo trì định kỳ theo lịch",          don="Khoa Công nghệ thông tin", ngay="11/04/2024", urgency="low",    urgTxt="🟢 Định kỳ",  selected=false },
                        new { khId="KH-2024-016", bhId="",            tbCode="",      tbName="Kiểm tra 8 máy chiếu phòng học",moTa="Kiểm tra tình trạng định kỳ quý 2", don="Toàn trường",              ngay="15/04/2024", urgency="low",    urgTxt="🟢 Kiểm tra", selected=false },
                        new { khId="KH-2024-013", bhId="BH-2024-037", tbCode="TB003", tbName="Máy tính B201-PC05",            moTa="Không khởi động được",               don="Khoa Công nghệ thông tin", ngay="05/04/2024", urgency="medium", urgTxt="🟡 Đột xuất", selected=false },
                    }; }
                @foreach (var item in items)
                {
                    var selCls = item.selected ? "report-item selected" : "report-item";
    <div class="@selCls" onclick="selectItem(this, '@item.khId', '@item.bhId', '@item.tbCode', '@item.tbName', '@item.moTa', '@item.don', '@item.ngay')">
        <div class="ri-head">
            <div class="ri-code">@item.khId</div>
            <span class="badge-urg @item.urgency">@item.urgTxt</span>
        </div>
        <div class="ri-name">@item.tbName</div>
        <div class="ri-meta">📅 @item.ngay &nbsp;|&nbsp; 🏢 @item.don</div>
        @if (!string.IsNullOrEmpty(item.bhId))
        {
<div class="ri-kh">📎 Từ báo hỏng: @item.bhId</div>}
    </div>}
            </div>
        </div>

        <!-- Lịch sử ghi nhận -->
        <div class="panel">
            <div class="panel-header">
                <h3>📜 Đã ghi nhận (GHINHAN_SUA_CHUA)</h3>
            </div>
            @{ var history = new[] {
                    new { gnId="GN-2024-022", khId="KH-2024-014", tb="TB006 — Laptop Lenovo ThinkPad", ngay="22/04/2024", ketQua="Hoạt động tốt", chiPhi="850,000" },
                    new { gnId="GN-2024-021", khId="KH-2024-012", tb="TB004 — Máy in HP LaserJet",    ngay="18/04/2024", ketQua="Tạm thời hoạt động", chiPhi="320,000" },
                }; }
            @foreach (var h in history)
            {
<div class="history-item">
    <div class="hi-head">
        <span class="hi-name">@h.gnId</span>
        <span class="hi-date">@h.ngay</span>
    </div>
    <div class="hi-detail">
        <span>📦 @h.tb</span>
        <span>📋 @h.khId</span>
    </div>
    <div class="hi-detail" style="margin-top:3px">
        <span>✅ @h.ketQua</span>
        <span>💰 @h.chiPhi VNĐ</span>
    </div>
</div>            }
        </div>
    </div>

    <!-- Cột phải: Form ghi nhận kết quả -->
    <div class="panel">
        <div class="panel-header">
            <h3>📝 Ghi Nhận Kết Quả Sửa Chữa</h3>
            <span id="formKHId">KH-2024-018</span>
        </div>
        <div class="repair-form">

            <!-- Thông tin kế hoạch & báo hỏng nguồn -->
            <div class="device-info-box">
                <h5>📋 Thông tin kế hoạch (KEHOACH_BAOTRI)</h5>
                <div class="bh-source" id="bhSourceBox">
                    <strong>📎 Nguồn báo hỏng (BAOHONG_THIETBI):</strong> BH-2024-041 — Kênh 1 không hiển thị tín hiệu
                </div>
                <div class="di-grid">
                    <div class="di-item"><label>ID Kế hoạch (KeHoachNo)</label><p id="infoKH">KH-2024-018</p></div>
                    <div class="di-item"><label>Loại</label><p style="color:#e53935">Sửa chữa đột xuất</p></div>
                    <div class="di-item"><label>Thiết bị (ThietBiNo)</label><p id="infoTB">TB005 — Oscilloscope Rigol DS1054Z</p></div>
                    <div class="di-item"><label>Đơn vị</label><p id="infoDon">Khoa Công nghệ thông tin</p></div>
                    <div class="di-item full"><label>Mô tả hư hỏng (MoTaHong từ BAOHONG)</label><p id="infoMoTa">Kênh 1 không hiển thị tín hiệu, màn hình nhấp nháy</p></div>
                </div>
            </div>

            <!-- ID Ghi nhận -->
            <div class="section-title">Thông tin ghi nhận (GHINHAN_SUA_CHUA)</div>
            <div class="form-row">
                <div>
                    <label class="form-lbl">ID Ghi nhận (ID_GhiNhan) *</label>
                    <input type="text" class="form-inp" value="GN-2024-023" placeholder="VD: GN-2024-023" />
                </div>
                <div>
                    <label class="form-lbl">Ngày thực hiện (NgayThucHien) *</label>
                    <input type="date" class="form-inp" value="2024-04-09" />
                </div>
            </div>

            <!-- Kết quả -->
            <div class="section-title">Kết quả & Chi phí</div>
            <div class="form-row single">
                <div>
                    <label class="form-lbl">Kết quả sửa chữa (KetQua) *</label>
                    <textarea class="form-inp" rows="3" placeholder="Mô tả chi tiết công việc đã thực hiện, nguyên nhân, giải pháp...">Thay IC khuếch đại OPA2134 và probe đầu đo. Kiểm tra lại toàn bộ 4 kênh, hoạt động bình thường sau khi thay linh kiện.</textarea>
                </div>
            </div>
            <div class="form-row">
                <div>
                    <label class="form-lbl">Chi phí thực tế (ChiPhiThucTe — VNĐ)</label>
                    <input type="text" class="form-inp" value="750,000" placeholder="VD: 750,000" />
                </div>
                <div>
                    <label class="form-lbl">Hình ảnh sau sửa (HinhAnhSau)</label>
                    <input type="file" class="form-inp" accept="image/*" />
                </div>
            </div>

            <!-- Vật tư -->
            <div class="section-title">Vật tư / Linh kiện thay thế</div>
            <table class="parts-table">
                <thead>
                    <tr>
                        <th>Tên vật tư</th>
                        <th style="width:50px">SL</th>
                        <th style="width:110px">Đơn giá</th>
                        <th style="width:110px">Thành tiền</th>
                        <th style="width:30px"></th>
                    </tr>
                </thead>
                <tbody id="partsBody">
                    <tr>
                        <td><input type="text" value="IC khuếch đại OPA2134" /></td>
                        <td><input type="number" value="2" style="width:45px" /></td>
                        <td><input type="text" value="150,000" /></td>
                        <td><input type="text" value="300,000" readonly /></td>
                        <td><button onclick="removeRow(this)" style="background:none;border:none;color:#e53935;cursor:pointer">✕</button></td>
                    </tr>
                    <tr>
                        <td><input type="text" value="Probe đầu đo 10:1" /></td>
                        <td><input type="number" value="1" style="width:45px" /></td>
                        <td><input type="text" value="450,000" /></td>
                        <td><input type="text" value="450,000" readonly /></td>
                        <td><button onclick="removeRow(this)" style="background:none;border:none;color:#e53935;cursor:pointer">✕</button></td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" style="text-align:right;padding-right:10px">Tổng chi phí vật tư:</td>
                        <td>750,000 VNĐ</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
            <button class="btn-add-part" onclick="addPart()">+ Thêm vật tư</button>

            <!-- Tình trạng sau sửa -->
            <div class="section-title">Tình trạng thiết bị sau sửa chữa (TrangThaiSauSua)</div>
            <div class="status-group">
                <div class="status-opt selected ok" onclick="selectStatus(this,'ok')">✅ Hoạt động tốt</div>
                <div class="status-opt" onclick="selectStatus(this,'repair')">⚠️ Tạm thời hoạt động</div>
                <div class="status-opt" onclick="selectStatus(this,'broken')">❌ Không thể sửa / Đề xuất thanh lý</div>
            </div>

            <div class="form-footer">
                <button class="btn-cancel">Hủy</button>
                <button class="btn-save">💾 Lưu kết quả sửa chữa</button>
            </div>
        </div>
    </div>
</div>

<script>
    function selectItem(el, khId, bhId, tbCode, tbName, moTa, don, ngay) {
        document.querySelectorAll('.report-item').forEach(function (i) { i.classList.remove('selected'); });
        el.classList.add('selected');

        document.getElementById('formKHId').textContent = khId;
        document.getElementById('infoKH').textContent = khId;
        document.getElementById('infoTB').textContent = tbCode ? tbCode + ' — ' + tbName : tbName;
        document.getElementById('infoDon').textContent = don;
        document.getElementById('infoMoTa').textContent = moTa;

        var bhBox = document.getElementById('bhSourceBox');
        if (bhId && bhId !== '') {
            bhBox.style.display = 'block';
            bhBox.innerHTML = '<strong>📎 Nguồn báo hỏng (BAOHONG_THIETBI):</strong> ' + bhId + ' — ' + moTa;
        } else {
            bhBox.style.display = 'none';
        }
    }

    function selectStatus(el, type) {
        document.querySelectorAll('.status-opt').forEach(function (o) {
            o.classList.remove('selected', 'ok', 'repair', 'broken');
        });
        el.classList.add('selected', type);
    }

    function addPart() {
        var tbody = document.getElementById('partsBody');
        var tr = document.createElement('tr');
        tr.innerHTML = '<td><input type="text" placeholder="Tên vật tư" /></td>' +
            '<td><input type="number" value="1" style="width:45px" /></td>' +
            '<td><input type="text" placeholder="Đơn giá" /></td>' +
            '<td><input type="text" placeholder="Thành tiền" readonly /></td>' +
            '<td><button onclick="removeRow(this)" style="background:none;border:none;color:#e53935;cursor:pointer">✕</button></td>';
        tbody.appendChild(tr);
    }

    function removeRow(btn) {
        btn.closest('tr').remove();
    }
</script>
