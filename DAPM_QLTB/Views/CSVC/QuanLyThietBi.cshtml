@{ ViewBag.Title = "Quản Lý Thiết Bị - Phòng CSVC"; }

<style>
    .tb-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

        .tb-header h2 {
            color: #1a237e;
            font-weight: 700;
            font-size: 22px;
            margin: 0;
        }

        .tb-header p {
            color: #666;
            font-size: 13px;
            margin: 2px 0 0;
        }

    .filter-bar {
        background: #fff;
        border-radius: 10px;
        padding: 16px 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        margin-bottom: 20px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: flex-end;
    }

        .filter-bar .form-group {
            margin: 0;
            flex: 1;
            min-width: 150px;
        }

        .filter-bar label {
            font-size: 12px;
            font-weight: 600;
            color: #555;
            margin-bottom: 4px;
            display: block;
        }

        .filter-bar .form-control, .filter-bar .form-select {
            font-size: 13px;
            border-radius: 7px;
            border: 1px solid #d0d5e8;
            padding: 7px 10px;
            background: #f8f9fe;
            width: 100%;
        }

    .btn-search {
        background: #1a237e;
        color: #fff;
        border: none;
        border-radius: 7px;
        padding: 8px 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-add {
        background: #43a047;
        color: #fff;
        border: none;
        border-radius: 7px;
        padding: 8px 18px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-add:hover {
            background: #2e7d32;
        }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 14px;
        margin-bottom: 20px;
    }

    .stat-box {
        background: #fff;
        border-radius: 10px;
        padding: 16px 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        border-left: 4px solid;
        display: flex;
        align-items: center;
        gap: 14px;
    }

        .stat-box.total {
            border-color: #1a237e;
        }

        .stat-box.active {
            border-color: #43a047;
        }

        .stat-box.repair {
            border-color: #fb8c00;
        }

        .stat-box.broken {
            border-color: #e53935;
        }

    .stat-icon {
        font-size: 28px;
    }

    .stat-num {
        font-size: 26px;
        font-weight: 700;
        color: #222;
    }

    .stat-lbl {
        font-size: 12px;
        color: #888;
    }

    .card-table {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        overflow: hidden;
    }

        .card-table table {
            width: 100%;
            border-collapse: collapse;
        }

        .card-table thead th {
            background: #e8eaf6;
            color: #1a237e;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            padding: 12px 14px;
            border: none;
            white-space: nowrap;
        }

        .card-table tbody td {
            padding: 11px 14px;
            font-size: 13px;
            color: #333;
            border-bottom: 1px solid #f0f2f8;
            vertical-align: middle;
        }

        .card-table tbody tr:last-child td {
            border-bottom: none;
        }

        .card-table tbody tr:hover td {
            background: #f5f6ff;
        }

    .badge-status {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
    }

        .badge-status.ok {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .badge-status.repair {
            background: #fff3e0;
            color: #e65100;
        }

        .badge-status.broken {
            background: #fce4ec;
            color: #c62828;
        }

        .badge-status.new {
            background: #e3f2fd;
            color: #1565c0;
        }

    .action-btns {
        display: flex;
        gap: 6px;
    }

    .btn-edit {
        background: #e8eaf6;
        color: #1a237e;
        border: none;
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-del {
        background: #fce4ec;
        color: #c62828;
        border: none;
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-report {
        background: #fff3e0;
        color: #e65100;
        border: none;
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
    }

    /* Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.45);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

        .modal-overlay.active {
            display: flex;
        }

    .modal-box {
        background: #fff;
        border-radius: 14px;
        padding: 28px 32px;
        width: 600px;
        max-width: 95vw;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    }

    .modal-title {
        font-size: 18px;
        font-weight: 700;
        color: #1a237e;
        margin-bottom: 20px;
    }

    .modal-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

        .modal-grid .full {
            grid-column: 1/-1;
        }

    .form-lbl {
        font-size: 12px;
        font-weight: 600;
        color: #555;
        margin-bottom: 4px;
        display: block;
    }

    .form-inp {
        width: 100%;
        padding: 9px 12px;
        border: 1px solid #d0d5e8;
        border-radius: 8px;
        font-size: 13px;
        background: #f8f9fe;
        box-sizing: border-box;
    }

        .form-inp:focus {
            border-color: #3949ab;
            outline: none;
            box-shadow: 0 0 0 3px rgba(57,73,171,0.1);
        }

    .modal-footer {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 22px;
    }

    .btn-cancel {
        background: #f5f5f5;
        color: #555;
        border: none;
        border-radius: 8px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-save {
        background: #1a237e;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 24px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    .section-label {
        font-size: 11px;
        font-weight: 700;
        color: #1a237e;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin: 16px 0 10px;
        padding-bottom: 6px;
        border-bottom: 1px solid #e8eaf6;
        grid-column: 1/-1;
    }

    .pagination {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
        padding: 14px 16px;
    }

    .pg-btn {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        background: #f0f2f8;
        color: #333;
    }

        .pg-btn.active {
            background: #1a237e;
            color: #fff;
        }
</style>

<!-- Header -->
<div class="tb-header">
    <div>
        <h2>📦 Quản Lý Thiết Bị</h2>
        <p>Xem, thêm, sửa thông tin thiết bị — dữ liệu từ bảng THIETBI, DANHMUC, KHOA_PHONGBAN, NHACUNGCAP</p>
    </div>
    <button class="btn-add" onclick="openModal('add')">+ Thêm Thiết Bị Mới</button>
</div>

<!-- Thống kê — ánh xạ TrangThaiTB trong THIETBI -->
<div class="stats-row">
    <div class="stat-box total">
        <div class="stat-icon">📦</div>
        <div><div class="stat-num">7</div><div class="stat-lbl">Tổng thiết bị</div></div>
    </div>
    <div class="stat-box active">
        <div class="stat-icon">✅</div>
        <div><div class="stat-num">4</div><div class="stat-lbl">Đang sử dụng</div></div>
    </div>
    <div class="stat-box repair">
        <div class="stat-icon">🔧</div>
        <div><div class="stat-num">2</div><div class="stat-lbl">Đang bảo trì</div></div>
    </div>
    <div class="stat-box broken">
        <div class="stat-icon">❌</div>
        <div><div class="stat-num">1</div><div class="stat-lbl">Hư hỏng</div></div>
    </div>
</div>

<!-- Bộ lọc -->
<div class="filter-bar">
    <div class="form-group">
        <label>Tìm kiếm</label>
        <input type="text" class="form-control" placeholder="Tên thiết bị, mã TB, số seri..." />
    </div>
    <div class="form-group">
        <label>Danh mục (DANHMUC)</label>
        <select class="form-select">
            <option value="">Tất cả danh mục</option>
            <option>Máy tính &amp; Laptop</option>
            <option>Máy chiếu</option>
            <option>Thiết bị thực hành</option>
            <option>Thiết bị văn phòng</option>
        </select>
    </div>
    <div class="form-group">
        <label>Khoa / Phòng ban (KHOA_PHONGBAN)</label>
        <select class="form-select">
            <option value="">Tất cả</option>
            <option>Khoa Công nghệ thông tin</option>
            <option>Phòng Cơ sở vật chất</option>
            <option>Phòng Kế hoạch tài chính</option>
            <option>Ban Giám Hiệu</option>
        </select>
    </div>
    <div class="form-group">
        <label>Tình trạng (TrangThaiTB)</label>
        <select class="form-select">
            <option value="">Tất cả</option>
            <option>Đang sử dụng</option>
            <option>Đang bảo trì</option>
            <option>Hư hỏng</option>
            <option>Mới nhập</option>
        </select>
    </div>
    <button class="btn-search">🔍 Tìm kiếm</button>
</div>

<!-- Bảng danh sách — các cột khớp với THIETBI -->
<div class="card-table">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>ID_ThietBi</th>
                <th>TenTB</th>
                <th>Danh mục</th>
                <th>Khoa / Phòng ban</th>
                <th>Nhà cung cấp</th>
                <th>Số Seri</th>
                <th>Giá (VNĐ)</th>
                <th>Tình trạng</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @{ var devices = new[] {
                    new { id=1, code="TB001", name="Macbook Pro M3",               cat="Máy tính & Laptop",    unit="Khoa Công nghệ thông tin", ncc="Apple Việt Nam",    seri=1001, price="45,000,000", status="ok"     },
                    new { id=2, code="TB002", name="Máy chiếu Epson EB-X51",       cat="Máy chiếu",            unit="Khoa Công nghệ thông tin", ncc="Epson Việt Nam",    seri=1002, price="12,000,000", status="repair" },
                    new { id=3, code="TB003", name="Bộ thực hành PLC Siemens S7",  cat="Thiết bị thực hành",   unit="Khoa Công nghệ thông tin", ncc="Siemens VN",        seri=1003, price="45,000,000", status="ok"     },
                    new { id=4, code="TB004", name="Máy in HP LaserJet Pro M404n", cat="Thiết bị văn phòng",   unit="Phòng Cơ sở vật chất",     ncc="HP Việt Nam",       seri=1004, price="5,800,000",  status="new"    },
                    new { id=5, code="TB005", name="Oscilloscope Rigol DS1054Z",   cat="Thiết bị thực hành",   unit="Khoa Công nghệ thông tin", ncc="Rigol Technologies",seri=1005, price="8,900,000",  status="broken" },
                    new { id=6, code="TB006", name="Laptop Lenovo ThinkPad E15",   cat="Máy tính & Laptop",    unit="Phòng Kế hoạch tài chính", ncc="Lenovo Việt Nam",   seri=1006, price="22,000,000", status="ok"     },
                    new { id=7, code="TB007", name="Màn hình Samsung 27\" 4K",    cat="Thiết bị văn phòng",   unit="Ban Giám Hiệu",             ncc="Samsung Việt Nam",  seri=1007, price="9,500,000",  status="repair" },
                }; }
            @foreach (var d in devices)
            {
                var badgeCls = d.status == "ok" ? "ok" : d.status == "repair" ? "repair" : d.status == "broken" ? "broken" : "new";
                var badgeTxt = d.status == "ok" ? "Đang sử dụng" : d.status == "repair" ? "Đang bảo trì" : d.status == "broken" ? "Hư hỏng" : "Mới nhập";
<tr>
    <td>@d.id</td>
    <td><strong>@d.code</strong></td>
    <td>@d.name</td>
    <td>@d.cat</td>
    <td>@d.unit</td>
    <td>@d.ncc</td>
    <td>@d.seri</td>
    <td>@d.price</td>
    <td><span class="badge-status @badgeCls">@badgeTxt</span></td>
    <td>
        <div class="action-btns">
            <button class="btn-edit" onclick="openModal('edit')">✏️ Sửa</button>
            @if (d.status == "ok" || d.status == "repair")
            {
<button class="btn-report" onclick="openBaoHong('@d.code', '@d.name')">⚠️ Báo hỏng</button>}
            <button class="btn-del">🗑️ Xóa</button>
        </div>
    </td>
</tr>            }
        </tbody>
    </table>
    <div class="pagination">
        <button class="pg-btn active">1</button>
        <button class="pg-btn">2</button>
        <button class="pg-btn">›</button>
    </div>
</div>

<!-- Modal Thêm / Sửa thiết bị — khớp cột THIETBI -->
<div class="modal-overlay" id="deviceModal">
    <div class="modal-box">
        <div class="modal-title" id="modalTitle">➕ Thêm Thiết Bị Mới</div>
        <div class="modal-grid">
            <div class="section-label">Thông tin cơ bản (THIETBI)</div>
            <div>
                <label class="form-lbl">ID_ThietBi *</label>
                <input type="text" class="form-inp" id="fCode" placeholder="VD: TB008" />
            </div>
            <div>
                <label class="form-lbl">Số Seri (SoSeri)</label>
                <input type="number" class="form-inp" id="fSeri" placeholder="VD: 1008" />
            </div>
            <div class="full">
                <label class="form-lbl">Tên thiết bị (TenTB) *</label>
                <input type="text" class="form-inp" id="fName" placeholder="Nhập tên thiết bị đầy đủ" />
            </div>
            <div>
                <label class="form-lbl">Danh mục (DanhMucNo → DANHMUC)</label>
                <select class="form-inp" id="fCat">
                    <option value="DM_MT">Máy tính &amp; Laptop</option>
                    <option value="DM_MC">Máy chiếu</option>
                    <option value="DM_TH">Thiết bị thực hành</option>
                    <option value="DM_VP">Thiết bị văn phòng</option>
                </select>
            </div>
            <div>
                <label class="form-lbl">Tình trạng (TrangThaiTB)</label>
                <select class="form-inp" id="fStatus">
                    <option value="Mới nhập">Mới nhập</option>
                    <option value="Đang sử dụng">Đang sử dụng</option>
                    <option value="Đang bảo trì">Đang bảo trì</option>
                    <option value="Hư hỏng">Hư hỏng</option>
                </select>
            </div>

            <div class="section-label">Phân bổ & Nguồn gốc</div>
            <div>
                <label class="form-lbl">Khoa / Phòng ban (KhoaPhongBan → KHOA_PHONGBAN)</label>
                <select class="form-inp" id="fUnit">
                    <option value="KHOA01">Khoa Công nghệ thông tin</option>
                    <option value="P_CSVC">Phòng Cơ sở vật chất</option>
                    <option value="P_KHTC">Phòng Kế hoạch tài chính</option>
                    <option value="BGH_DV">Ban Giám Hiệu</option>
                </select>
            </div>
            <div>
                <label class="form-lbl">Nhà cung cấp (NhaCCNo → NHACUNGCAP)</label>
                <select class="form-inp" id="fNcc">
                    <option value="NCC01">Apple Việt Nam</option>
                    <option value="NCC02">Epson Việt Nam</option>
                    <option value="NCC03">HP Việt Nam</option>
                    <option value="NCC04">Samsung Việt Nam</option>
                    <option value="NCC05">Lenovo Việt Nam</option>
                </select>
            </div>
            <div>
                <label class="form-lbl">Giá trị (Gia — VNĐ)</label>
                <input type="text" class="form-inp" id="fPrice" placeholder="VD: 15,000,000" />
            </div>
            <div class="full">
                <label class="form-lbl">Thông số kỹ thuật (ThongSoKT)</label>
                <textarea class="form-inp" id="fSpec" rows="2" placeholder="CPU, RAM, dung lượng, model..."></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('deviceModal')">Hủy</button>
            <button class="btn-save" onclick="closeModal('deviceModal')">💾 Lưu thiết bị</button>
        </div>
    </div>
</div>

<!-- Modal Báo hỏng — tạo bản ghi BAOHONG_THIETBI -->
<div class="modal-overlay" id="baoHongModal">
    <div class="modal-box">
        <div class="modal-title">⚠️ Báo Hỏng Thiết Bị</div>
        <p style="font-size:13px;color:#666;margin-bottom:16px">Tạo phiếu báo hỏng → lưu vào bảng <strong>BAOHONG_THIETBI</strong>. Phòng CSVC sẽ lập kế hoạch sửa chữa đột xuất.</p>
        <div class="modal-grid">
            <div>
                <label class="form-lbl">ID Báo hỏng (ID_BaoHong)</label>
                <input type="text" class="form-inp" id="bhCode" placeholder="VD: BH-2024-042" />
            </div>
            <div>
                <label class="form-lbl">Thiết bị (ThietBiNo)</label>
                <input type="text" class="form-inp" id="bhDevice" readonly />
            </div>
            <div>
                <label class="form-lbl">Ngày báo (NgayBao)</label>
                <input type="date" class="form-inp" id="bhDate" />
            </div>
            <div>
                <label class="form-lbl">Mức độ ưu tiên (MucDoUuTien)</label>
                <select class="form-inp" id="bhPriority">
                    <option value="Khẩn">🔴 Khẩn cấp</option>
                    <option value="Vừa">🟡 Vừa</option>
                    <option value="Thấp">🟢 Thấp</option>
                </select>
            </div>
            <div class="full">
                <label class="form-lbl">Mô tả hư hỏng (MoTaHong)</label>
                <textarea class="form-inp" id="bhDesc" rows="3" placeholder="Mô tả chi tiết tình trạng hư hỏng..."></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('baoHongModal')">Hủy</button>
            <button class="btn-save" style="background:#e65100" onclick="submitBaoHong()">⚠️ Gửi báo hỏng</button>
        </div>
    </div>
</div>

<script>
    function openModal(mode) {
        var m = document.getElementById('deviceModal');
        document.getElementById('modalTitle').textContent = mode === 'add' ? '➕ Thêm Thiết Bị Mới' : '✏️ Cập Nhật Thông Tin Thiết Bị';
        if (mode === 'edit') {
            document.getElementById('fCode').value = 'TB002';
            document.getElementById('fName').value = 'Máy chiếu Epson EB-X51';
            document.getElementById('fSeri').value = '1002';
            document.getElementById('fPrice').value = '12,000,000';
            document.getElementById('fStatus').value = 'Đang bảo trì';
        }
        m.classList.add('active');
    }
    function openBaoHong(code, name) {
        document.getElementById('bhCode').value = 'BH-2024-0' + Math.floor(Math.random() * 90 + 10);
        document.getElementById('bhDevice').value = code + ' - ' + name;
        document.getElementById('bhDate').value = new Date().toISOString().split('T')[0];
        document.getElementById('baoHongModal').classList.add('active');
    }
    function submitBaoHong() {
        alert('Phiếu báo hỏng đã được gửi!\nPhòng CSVC sẽ lập kế hoạch sửa chữa đột xuất.');
        closeModal('baoHongModal');
    }
    function closeModal(id) { document.getElementById(id).classList.remove('active'); }
    document.querySelectorAll('.modal-overlay').forEach(function (m) {
        m.addEventListener('click', function (e) { if (e.target === m) m.classList.remove('active'); });
    });
</script>
