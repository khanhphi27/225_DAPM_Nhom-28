<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .badge-tt { display:inline-block; padding:4px 10px; border-radius:20px; font-size:11px; font-weight:700; }
    .badge-tt.ok   { background:#e8f5e9; color:#2e7d32; }
    .badge-tt.warn { background:#fff3e0; color:#e65100; }
    .badge-tt.err  { background:#fce4ec; color:#c62828; }
    .btn-ls { background:#e8eaf6; color:#1a237e; border:none; border-radius:6px; padding:4px 10px; font-size:11px; font-weight:600; cursor:pointer; white-space:nowrap; }
    .btn-ls:hover { background:#c5cae9; }
    /* Modal */
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:2000; align-items:center; justify-content:center; }
    .modal-overlay.active { display:flex; }
    .modal-box { background:#fff; border-radius:14px; padding:28px 30px; width:560px; max-width:95vw; max-height:80vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,.3); }
    .modal-title { font-size:17px; font-weight:700; color:#1a237e; margin-bottom:16px; }
    /* Timeline */
    .ls-timeline { position:relative; padding-left:28px; }
    .ls-timeline::before { content:''; position:absolute; left:10px; top:0; bottom:0; width:2px; background:#e0e0e0; }
    .ls-item { position:relative; margin-bottom:18px; }
    .ls-dot { position:absolute; left:-22px; top:3px; width:16px; height:16px; border-radius:50%; background:#fff; border:2px solid #ccc; }
    .ls-dot.csvc   { background:#1e88e5; border-color:#1e88e5; }
    .ls-dot.khtc   { background:#6a1b9a; border-color:#6a1b9a; }
    .ls-dot.bgh    { background:#43a047; border-color:#43a047; }
    .ls-dot.reject { background:#e53935; border-color:#e53935; }
    .ls-cap  { font-size:10px; font-weight:700; text-transform:uppercase; color:#888; }
    .ls-name { font-size:13px; font-weight:600; color:#333; }
    .ls-time { font-size:11px; color:#aaa; }
    .ls-tt   { font-size:12px; margin-top:3px; }
    .ls-gc   { font-size:12px; color:#666; font-style:italic; }
</style>

