@{
    ViewBag.Title = "Thông Báo";
}

@section styles {
    <link href="~/Content/notifications.css" rel="stylesheet" />

    <style>
        /* Đồng bộ Font và Background chung */
        .notifications-wrapper {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            padding: 20px 0;
        }

        /* Header */
        .page-title {
            color: #2C4B70;
            font-weight: 700;
            letter-spacing: -0.5px;
            font-size: 24px;
            margin-bottom: 4px;
        }

        .page-subtitle {
            color: #6C849D;
            font-size: 14px;
        }

        /* Nút thao tác Header */
        .btn-action {
            background-color: #ffffff;
            border: 1px solid #DCE6F2;
            color: #4A637C;
            border-radius: 10px;
            padding: 8px 16px;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.2s ease;
            box-shadow: 0 2px 6px rgba(119, 142, 172, 0.05);
        }

            .btn-action:hover {
                background-color: #F4F8FC;
                border-color: #92BCE3;
                color: #2C4B70;
                transform: translateY(-1px);
            }

            .btn-action.danger:hover {
                border-color: #FFCDCD;
                color: #D32F2F;
                background-color: #FFF2F2;
            }

        /* Thẻ Thống Kê (Stats Cards) */
        .stats-card {
            background-color: #ffffff;
            border-radius: 16px;
            padding: 20px 15px;
            text-align: center;
            box-shadow: 0 8px 24px rgba(119, 142, 172, 0.06);
            border: 1px solid #E2EBF5;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            height: 100%;
        }

            .stats-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 12px 30px rgba(119, 142, 172, 0.12);
            }

        .stats-num {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        /* Màu sắc thống kê */
        .text-blue-main {
            color: #8EBAE5;
        }

        .text-red-soft {
            color: #E57373;
        }

        .text-green-soft {
            color: #81C784;
        }

        .text-orange-soft {
            color: #FFB74D;
        }

        /* Bộ lọc (Filters) */
        .filter-group {
            background-color: #ffffff;
            padding: 6px;
            border-radius: 14px;
            display: inline-flex;
            box-shadow: 0 4px 12px rgba(119, 142, 172, 0.05);
            border: 1px solid #E2EBF5;
        }

        .filter-btn {
            border: none;
            background: transparent;
            color: #6C849D;
            border-radius: 10px;
            padding: 8px 18px;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
        }

            .filter-btn:hover {
                color: #2C4B70;
                background-color: #F4F8FC;
            }

            .filter-btn.active {
                background-color: #8EBAE5;
                color: #ffffff;
                box-shadow: 0 4px 10px rgba(142, 186, 229, 0.3);
            }

        /* Danh sách thông báo */
        .notif-list-container {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .notif-item {
            background-color: #ffffff;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(119, 142, 172, 0.05);
            border: 1px solid #E2EBF5;
            transition: all 0.2s ease;
            position: relative;
            overflow: hidden;
        }

            .notif-item:hover {
                border-color: #D2DFEE;
                box-shadow: 0 8px 25px rgba(119, 142, 172, 0.1);
            }

            /* Trạng thái chưa đọc */
            .notif-item.unread {
                background-color: #F8FBFF;
            }

                .notif-item.unread::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 0;
                    bottom: 0;
                    width: 4px;
                    background-color: #8EBAE5;
                    border-top-left-radius: 16px;
                    border-bottom-left-radius: 16px;
                }

        .notif-icon-box {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        /* Màu nền nhạt cho Icon */
        .bg-icon-success {
            background-color: #E8F5E9;
            color: #4CAF50;
        }

        .bg-icon-warning {
            background-color: #FFF8E1;
            color: #FFC107;
        }

        .bg-icon-primary {
            background-color: #E3F2FD;
            color: #2196F3;
        }

        .bg-icon-danger {
            background-color: #FFEBEE;
            color: #F44336;
        }

        .bg-icon-info {
            background-color: #E0F7FA;
            color: #00BCD4;
        }

        .bg-icon-secondary {
            background-color: #F5F5F5;
            color: #9E9E9E;
        }

        .notif-content {
            flex-grow: 1;
        }

        .notif-title {
            color: #2C4B70;
            font-weight: 600;
            font-size: 15px;
            margin-bottom: 6px;
        }

        .notif-body {
            color: #556B82;
            font-size: 14px;
            margin-bottom: 10px;
            line-height: 1.5;
        }

            .notif-body strong {
                color: #3A5A7D;
                font-weight: 600;
            }

        .notif-time {
            color: #8BA3BC;
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* Nút xóa item */
        .btn-delete-notif {
            background: transparent;
            border: none;
            color: #B0BEC5;
            padding: 5px;
            border-radius: 8px;
            transition: all 0.2s;
        }

            .btn-delete-notif:hover {
                background-color: #FFF2F2;
                color: #D32F2F;
            }

        /* Badges Pastel phong cách Apple */
        .badge-apple {
            padding: 5px 10px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .badge-apple-success {
            background-color: #E8F5E9;
            color: #2E7D32;
        }

        .badge-apple-warning {
            background-color: #FFF3E0;
            color: #EF6C00;
        }

        .badge-apple-primary {
            background-color: #E3F2FD;
            color: #1565C0;
        }

        .badge-apple-danger {
            background-color: #FFEBEE;
            color: #C62828;
        }

        .badge-apple-info {
            background-color: #E1F5FE;
            color: #0277BD;
        }

        .badge-apple-secondary {
            background-color: #F5F5F5;
            color: #616161;
        }

        .notif-dot {
            width: 8px;
            height: 8px;
            background-color: #8EBAE5;
            border-radius: 50%;
            display: inline-block;
        }
    </style>
}

<div class="notifications-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="page-title">🔔 Thông Báo</h2>
            <p class="page-subtitle mb-0">Cập nhật tình hình thiết bị và hệ thống của bạn</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn-action" onclick="markAllRead()">
                <span class="me-1">✓</span> Đánh dấu đã đọc
            </button>
            <button class="btn-action danger" onclick="clearAll()">
                <span class="me-1">🗑</span> Xóa tất cả
            </button>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stats-card">
                <div class="stats-num text-blue-main" id="totalCount">8</div>
                <div class="text-muted" style="font-size:13px; font-weight: 500;">Tổng thông báo</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stats-card">
                <div class="stats-num text-red-soft" id="unreadCount">3</div>
                <div class="text-muted" style="font-size:13px; font-weight: 500;">Chưa đọc</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stats-card">
                <div class="stats-num text-green-soft">4</div>
                <div class="text-muted" style="font-size:13px; font-weight: 500;">Đã duyệt</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stats-card">
                <div class="stats-num text-orange-soft">1</div>
                <div class="text-muted" style="font-size:13px; font-weight: 500;">Cần xử lý</div>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <div class="filter-group flex-wrap">
            <button class="filter-btn active" onclick="filterNotif('all', this)">Tất cả</button>
            <button class="filter-btn" onclick="filterNotif('unread', this)">Chưa đọc</button>
            <button class="filter-btn" onclick="filterNotif('approved', this)">Đã duyệt</button>
            <button class="filter-btn" onclick="filterNotif('rejected', this)">Từ chối</button>
            <button class="filter-btn" onclick="filterNotif('system', this)">Hệ thống</button>
        </div>
    </div>

    <div class="notif-list-container" id="notifList">

        <div class="notif-item unread d-flex gap-3" data-type="approved">
            <div class="notif-icon-box bg-icon-success">✅</div>
            <div class="notif-content">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div class="notif-title">Đề xuất mua sắm đã được duyệt</div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge-apple badge-apple-success badge-type">Đã duyệt</span>
                        <span class="notif-dot"></span>
                    </div>
                </div>
                <div class="notif-body">Đề xuất <strong>#045 - Máy chiếu Epson EB-X51</strong> đã được Phòng CSVC phê duyệt.</div>
                <div class="notif-time"><span>🕒</span> Hôm nay, 09:15 · Phòng CSVC</div>
            </div>
            <button class="btn-delete-notif align-self-start" onclick="deleteNotif(this)" title="Xóa">✕</button>
        </div>

        <div class="notif-item unread d-flex gap-3" data-type="system">
            <div class="notif-icon-box bg-icon-warning">⚠️</div>
            <div class="notif-content">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div class="notif-title">Thiết bị sắp hết hạn bảo hành</div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge-apple badge-apple-warning badge-type">Cần xử lý</span>
                        <span class="notif-dot"></span>
                    </div>
                </div>
                <div class="notif-body">Máy tính <strong>PC-Lab302-05</strong> hết hạn bảo hành vào <strong>15/04/2026</strong>.</div>
                <div class="notif-time"><span>🕒</span> Hôm nay, 08:00 · Hệ thống</div>
            </div>
            <button class="btn-delete-notif align-self-start" onclick="deleteNotif(this)" title="Xóa">✕</button>
        </div>

        <div class="notif-item unread d-flex gap-3" data-type="approved">
            <div class="notif-icon-box bg-icon-primary">📋</div>
            <div class="notif-content">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div class="notif-title">Yêu cầu bảo trì được tiếp nhận</div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge-apple badge-apple-primary badge-type">Đang xử lý</span>
                        <span class="notif-dot"></span>
                    </div>
                </div>
                <div class="notif-body">Yêu cầu <strong>#BR-012 - Máy in HP LaserJet P1102</strong> tại B201 đã được tiếp nhận.</div>
                <div class="notif-time"><span>🕒</span> Hôm qua, 16:30 · Phòng CSVC</div>
            </div>
            <button class="btn-delete-notif align-self-start" onclick="deleteNotif(this)" title="Xóa">✕</button>
        </div>

        <div class="notif-item d-flex gap-3" data-type="approved">
            <div class="notif-icon-box bg-icon-success">✅</div>
            <div class="notif-content">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div class="notif-title">Đề xuất thanh lý được duyệt</div>
                    <span class="badge-apple badge-apple-success badge-type">Đã duyệt</span>
                </div>
                <div class="notif-body">Đề xuất <strong>#TL-008 - 5 máy tính cũ Lab101</strong> đã được BGH phê duyệt.</div>
                <div class="notif-time"><span>🕒</span> 05/04/2026, 10:00 · BGH</div>
            </div>
            <button class="btn-delete-notif align-self-start" onclick="deleteNotif(this)" title="Xóa">✕</button>
        </div>

        <div class="notif-item d-flex gap-3" data-type="rejected">
            <div class="notif-icon-box bg-icon-danger">❌</div>
            <div class="notif-content">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div class="notif-title">Đề xuất mua sắm bị từ chối</div>
                    <span class="badge-apple badge-apple-danger badge-type">Từ chối</span>
                </div>
                <div class="notif-body">Đề xuất <strong>#044 - Mua 10 bộ bàn phím cơ</strong> bị từ chối. Lý do: <em>Vượt ngân sách quý.</em></div>
                <div class="notif-time"><span>🕒</span> 04/04/2026, 14:00 · Phòng KHTC</div>
            </div>
            <button class="btn-delete-notif align-self-start" onclick="deleteNotif(this)" title="Xóa">✕</button>
        </div>

        <div class="notif-item d-flex gap-3" data-type="system">
            <div class="notif-icon-box bg-icon-info">ℹ️</div>
            <div class="notif-content">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div class="notif-title">Cập nhật hệ thống</div>
                    <span class="badge-apple badge-apple-info badge-type">Hệ thống</span>
                </div>
                <div class="notif-body">Hệ thống QLTB đã cập nhật lên phiên bản <strong>v2.1.0</strong>.</div>
                <div class="notif-time"><span>🕒</span> 01/04/2026, 07:00 · Quản trị hệ thống</div>
            </div>
            <button class="btn-delete-notif align-self-start" onclick="deleteNotif(this)" title="Xóa">✕</button>
        </div>

        <div class="notif-item d-flex gap-3" data-type="approved">
            <div class="notif-icon-box bg-icon-secondary">📅</div>
            <div class="notif-content">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div class="notif-title">Kiểm kê thiết bị định kỳ</div>
                    <span class="badge-apple badge-apple-secondary badge-type">Thông tin</span>
                </div>
                <div class="notif-body">Kiểm kê <strong>Quý II/2026</strong> diễn ra từ <strong>10/04 - 15/04/2026</strong>. Vui lòng chuẩn bị danh sách thiết bị.</div>
                <div class="notif-time"><span>🕒</span> 25/03/2026, 08:00 · Phòng CSVC</div>
            </div>
            <button class="btn-delete-notif align-self-start" onclick="deleteNotif(this)" title="Xóa">✕</button>
        </div>

        <div id="emptyState" class="text-center py-5 d-none">
            <div style="font-size:54px; opacity: 0.5;">🔕</div>
            <h4 class="mt-3" style="color: #2C4B70; font-weight: 600;">Bạn đã xem hết thông báo</h4>
            <p class="text-muted">Không có thông báo mới nào vào lúc này.</p>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/notifications.js"></script>
}