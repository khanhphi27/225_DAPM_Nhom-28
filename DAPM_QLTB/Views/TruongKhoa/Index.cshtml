@{
    ViewBag.Title = "Dashboard Trưởng Khoa";
}

<style>
    .header-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 30px;
        border-radius: 10px;
        margin-bottom: 25px;
    }

    .menu-btn {
        padding: 12px;
        border-radius: 8px;
        font-weight: 500;
        transition: 0.3s;
        border: none;
    }

        .menu-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .menu-btn.active {
            background-color: #764ba2 !important;
        }

    .card-custom {
        background: white;
        border-radius: 10px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        margin-bottom: 20px;
    }

    .title-section {
        font-weight: 600;
        margin-bottom: 20px;
        color: #333;
        border-bottom: 2px solid #667eea;
        padding-bottom: 8px;
    }

    .btn-main {
        background-color: #667eea;
        color: white;
        border-radius: 6px;
    }

        .btn-main:hover {
            background-color: #764ba2;
        }
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="header-section">
        <h2>🎓 Dashboard Trưởng Khoa</h2>
        <p>Quản lý đề xuất và thiết bị trong khoa</p>
    </div>

    <!-- MENU -->
    <div class="row mb-4">
        <div class="col-md-4">
            <button onclick="showSection('dexuat', this)" class="btn btn-primary w-100 menu-btn active">
                📦 Gửi đề xuất
            </button>
        </div>

        <div class="col-md-4">
            <button onclick="showSection('baohong', this)" class="btn btn-danger w-100 menu-btn">
                ⚠️ Báo hỏng
            </button>
        </div>

        <div class="col-md-4">
            <button onclick="showSection('xem', this)" class="btn btn-success w-100 menu-btn">
                📋 Xem đề xuất
            </button>
        </div>
    </div>

    <!-- GỬI ĐỀ XUẤT -->
    <div id="dexuat" class="section card-custom">
        <h4 class="title-section">📦 Gửi đề xuất mua sắm</h4>

        <form method="post">
            <div class="mb-3">
                <label>Tên thiết bị</label>
                <input type="text" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Số lượng</label>
                <input type="number" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Lý do</label>
                <textarea class="form-control"></textarea>
            </div>

            <button class="btn btn-main">Gửi đề xuất</button>
        </form>
    </div>

    <!-- BÁO HỎNG -->
    <div id="baohong" class="section card-custom" style="display:none;">
        <h4 class="title-section">⚠️ Báo hư hỏng thiết bị</h4>

        <form method="post">
            <div class="mb-3">
                <label>Tên thiết bị</label>
                <input type="text" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Mô tả lỗi</label>
                <textarea class="form-control"></textarea>
            </div>

            <button class="btn btn-danger">Báo hỏng</button>
        </form>
    </div>

    <!-- XEM ĐỀ XUẤT -->
    <div id="xem" class="section card-custom" style="display:none;">
        <h4 class="title-section">📋 Danh sách đề xuất</h4>

        <table class="table table-bordered text-center">
            <thead style="background-color:#667eea; color:white;">
                <tr>
                    <th>Tên thiết bị</th>
                    <th>Số lượng</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Máy chiếu</td>
                    <td>2</td>
                    <td>
                        <span class="badge bg-warning text-dark">
                            Đang chờ duyệt
                        </span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</div>

<script>
    function showSection(sectionId, btn) {
        var sections = document.getElementsByClassName("section");
        for (var i = 0; i < sections.length; i++) {
            sections[i].style.display = "none";
        }

        document.getElementById(sectionId).style.display = "block";

        var buttons = document.getElementsByClassName("menu-btn");
        for (var i = 0; i < buttons.length; i++) {
            buttons[i].classList.remove("active");
        }

        btn.classList.add("active");
    }
</script>