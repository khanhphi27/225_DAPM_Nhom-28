<script>
    // Thêm dòng thiết bị mới
    function themDong() {
        var tbody = document.getElementById('tbBody');
        var row = document.createElement('tr');
        row.className = 'tb-row';
        row.innerHTML = `
            <td><input type="text"   name="tenTB[]"   class="form-control" required placeholder="Tên thiết bị" /></td>
            <td><input type="number" name="soluong[]" class="form-control sl-input" required min="1" value="1" /></td>
            <td><input type="text"   name="donvi[]"   class="form-control" placeholder="Cái, bộ..." /></td>
            <td><input type="number" name="gia[]"     class="form-control gia-input" required min="0" value="0" /></td>
            <td class="thanh-tien" style="font-weight:600;color:#1a237e;font-size:13px;">0 đ</td>
            <td><button type="button" class="btn-del-row" onclick="xoaDong(this)" title="Xóa dòng">✕</button></td>`;
        tbody.appendChild(row);
        bindRowEvents(row);
    }

    // Xóa dòng (giữ ít nhất 1 dòng)
    function xoaDong(btn) {
        var rows = document.querySelectorAll('#tbBody .tb-row');
        if (rows.length <= 1) { alert('Phiếu đề xuất cần ít nhất 1 thiết bị.'); return; }
        btn.closest('tr').remove();
        tinhTong();
    }

    // Tính thành tiền từng dòng và tổng
    function tinhTong() {
        var tong = 0;
        document.querySelectorAll('#tbBody .tb-row').forEach(function(row) {
            var sl  = parseFloat(row.querySelector('.sl-input').value)  || 0;
            var gia = parseFloat(row.querySelector('.gia-input').value) || 0;
            var tt  = sl * gia;
            tong += tt;
            row.querySelector('.thanh-tien').textContent = tt.toLocaleString('vi-VN') + ' đ';
        });
        document.getElementById('tongGia').textContent = tong.toLocaleString('vi-VN');
    }

    function bindRowEvents(row) {
        row.querySelector('.sl-input').addEventListener('input', tinhTong);
        row.querySelector('.gia-input').addEventListener('input', tinhTong);
    }

    // Bind sự kiện cho dòng đầu tiên
    document.querySelectorAll('#tbBody .tb-row').forEach(bindRowEvents);

    // ===== CHỈNH SỬA =====
    function moFormEdit(id, mota, btn) {
        document.getElementById('editIdInput').value = id;
        document.getElementById('editIdLabel').textContent = id;
        document.getElementById('editMota').value = mota;
        document.getElementById('tbEditBody').innerHTML = '';

        // Load chi tiết thiết bị hiện tại qua Ajax
        $.get('@Url.Action("GetChiTietDeXuat","TruongKhoa")', { id: id }, function(res) {
            if (res.ok) {
                res.data.forEach(function(item) {
                    themDongEditData(item.Ten, item.SoLuong, item.DVT, item.Gia);
                });
                tinhTongEdit();
            }
        });

        document.getElementById('editFormCard').style.display = '';
        document.getElementById('editFormCard').scrollIntoView({ behavior: 'smooth' });
    }

    function dongFormEdit() {
        document.getElementById('editFormCard').style.display = 'none';
    }

    function themDongEdit() {
        themDongEditData('', 1, '', 0);
    }

    function themDongEditData(ten, sl, dvt, gia) {
        var tbody = document.getElementById('tbEditBody');
        var row = document.createElement('tr');
        row.className = 'tb-row';
        row.innerHTML = `
            <td><input type="text"   name="tenTB[]"   class="form-control" required value="${ten}" placeholder="Tên thiết bị" /></td>
            <td><input type="number" name="soluong[]" class="form-control sl-input" required min="1" value="${sl}" /></td>
            <td><input type="text"   name="donvi[]"   class="form-control" value="${dvt}" placeholder="Cái, bộ..." /></td>
            <td><input type="number" name="gia[]"     class="form-control gia-input" required min="0" value="${gia}" /></td>
            <td class="thanh-tien" style="font-weight:600;color:#1a237e;font-size:13px;">0 đ</td>
            <td><button type="button" class="btn-del-row" onclick="xoaDongEdit(this)">✕</button></td>`;
        tbody.appendChild(row);
        bindEditRowEvents(row);
        tinhTongEdit();
    }

    function xoaDongEdit(btn) {
        var rows = document.querySelectorAll('#tbEditBody .tb-row');
        if (rows.length <= 1) { alert('Cần ít nhất 1 thiết bị.'); return; }
        btn.closest('tr').remove();
        tinhTongEdit();
    }

    function tinhTongEdit() {
        var tong = 0;
        document.querySelectorAll('#tbEditBody .tb-row').forEach(function(row) {
            var sl  = parseFloat(row.querySelector('.sl-input').value)  || 0;
            var gia = parseFloat(row.querySelector('.gia-input').value) || 0;
            var tt  = sl * gia;
            tong += tt;
            row.querySelector('.thanh-tien').textContent = tt.toLocaleString('vi-VN') + ' đ';
        });
        document.getElementById('tongGiaEdit').textContent = tong.toLocaleString('vi-VN');
    }

    function bindEditRowEvents(row) {
        row.querySelector('.sl-input').addEventListener('input', tinhTongEdit);
        row.querySelector('.gia-input').addEventListener('input', tinhTongEdit);
    }
    function printPhieuMoi() {
        document.getElementById('outNgay').innerText = new Date().toLocaleDateString('vi-VN');
        document.getElementById('outMoTa').innerText = document.getElementById('newMota').value || "...";
        let html = "";
        document.querySelectorAll('#tbBody .tb-row').forEach((row, idx) => {
            const ten = row.querySelector('input[name="tenTB[]"]').value;
            const sl = row.querySelector('input[name="soluong[]"]').value;
            const gia = Number(row.querySelector('input[name="gia[]"]').value).toLocaleString();
            if(ten) html += `<tr><td align="center">${idx+1}</td><td>${ten}</td><td align="center">${sl}</td><td align="right">${gia} đ</td></tr>`;
        });
        document.getElementById('outBody').innerHTML = html;
        window.print();
    }

    function printLichSu(btn, mota, ngay) {
        document.getElementById('outNgay').innerText = ngay;
        document.getElementById('outMoTa').innerText = mota || "...";
        const rows = btn.closest('.dx-card').querySelectorAll('.dx-items tbody tr');
        let html = "";
        rows.forEach((row, idx) => {
            const cols = row.querySelectorAll('td');
            html += `<tr><td align="center">${idx+1}</td><td>${cols[0].innerText}</td><td align="center">${cols[1].innerText}</td><td align="right">${cols[2].innerText}</td></tr>`;
        });
        document.getElementById('outBody').innerHTML = html;
        window.print();
    }
    function printPhieuMoi() {
        // Cập nhật ngày tháng
        const d = new Date();
        document.getElementById('outNgay').innerText = d.getDate();
        document.getElementById('outMoTa').innerText = document.getElementById('newMota').value || "...................................................";

        let html = "";
        // Duyệt QUA TẤT CẢ các dòng có class .tb-row
        const rows = document.querySelectorAll('#tbBody tr.tb-row');
        rows.forEach((row, index) => {
            const ten = row.querySelector('input[name="tenTB[]"]')?.value;
            const sl = row.querySelector('input[name="soluong[]"]')?.value;
            const dv = row.querySelector('input[name="donvi[]"]')?.value || "Cái/Bộ";
            const giaVal = row.querySelector('input[name="gia[]"]')?.value;

            if (ten && ten.trim() !== "") {
                const giaStr = (Number(giaVal) || 0).toLocaleString('vi-VN');
                html += `<tr>
                 <td style="border: 1px solid black; text-align: center; padding: 5px;">${index + 1}</td>
                 <td style="border: 1px solid black; padding: 5px; font-weight: bold;">${ten}</td>
                 <td style="border: 1px solid black; text-align: center; padding: 5px;">${dv}</td>
                 <td style="border: 1px solid black; text-align: center; padding: 5px;">${sl}</td>
                 <td style="border: 1px solid black; text-align: right; padding: 5px;">${giaStr} đ</td>
             </tr>`;
            }
        });

        // Thêm ít nhất 3 dòng trống để đơn in nhìn "xịn" như mẫu thực tế
        for (let i = (rows.length || 0); i < 3; i++) {
            html += `<tr><td style="border: 1px solid black; height: 25px; text-align:center;">${i + 1}</td><td style="border: 1px solid black;"></td><td style="border: 1px solid black;"></td><td style="border: 1px solid black;"></td><td style="border: 1px solid black;"></td></tr>`;
        }

        document.getElementById('outBody').innerHTML = html;
        window.print();
    }

    function printLichSu(btn, mota, ngay) {
        document.getElementById('outNgay').innerText = ngay.split('/')[0];
        document.getElementById('outMoTa').innerText = mota || "...................................................";

        const card = btn.closest('.dx-card');
        const rows = card.querySelectorAll('.dx-items tbody tr');
        let html = "";

        rows.forEach((row, idx) => {
            const cols = row.querySelectorAll('td');
            html += `<tr>
             <td style="border: 1px solid black; text-align: center; padding: 5px;">${idx + 1}</td>
             <td style="border: 1px solid black; padding: 5px; font-weight: bold;">${cols[0].innerText}</td>
             <td style="border: 1px solid black; text-align: center; padding: 5px;">Cái/Bộ</td>
             <td style="border: 1px solid black; text-align: center; padding: 5px;">${cols[1].innerText}</td>
             <td style="border: 1px solid black; text-align: right; padding: 5px;">${cols[2].innerText}</td>
         </tr>`;
        });

        document.getElementById('outBody').innerHTML = html;
        window.print();
    }
</script>