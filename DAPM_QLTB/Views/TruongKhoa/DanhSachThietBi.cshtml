@model System.Data.DataTable
<div class="container mt-4">
    <h3 class="mb-4"><i class="fa fa-microscope text-secondary"></i> Danh Sách Thiết Bị Tại Khoa</h3>

    <table class="table table-hover shadow-sm bg-white">
        <thead class="table-dark">
            <tr>
                <th>Thông Tin Thiết Bị</th>
                <th>Giá Trị</th>
                <th>Thông Số</th>
                <th>Trạng Thái</th>
                <th width="300">Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (System.Data.DataRow row in Model.Rows)
            {
                <tr>
                    <td>
                        <strong>@row["TenTB"]</strong><br />
                        <small class="text-muted">Mã: @row["ID_ThietBi"]</small>
                    </td>
                    <td>@string.Format("{0:N0} đ", row["Gia"])</td>
                    <td>@row["ThongSoKT"]</td>
                    <td>
                        <span class="badge @(row["TrangThaiTB"].ToString() == "Tốt" ? "bg-success" : "bg-warning")">
                            @row["TrangThaiTB"]
                        </span>
                    </td>
                    <td>
                        @using (Html.BeginForm("BaoHong", "TruongKhoa", FormMethod.Post, new { @class = "row g-2" }))
                        {
                            <input type="hidden" name="id" value="@row["ID_ThietBi"]" />
                            <div class="col-8">
                                <input name="mota" class="form-control form-control-sm" placeholder="Mô tả lỗi..." required />
                            </div>
                            <div class="col-4">
                                <button class="btn btn-danger btn-sm w-100">Báo Hỏng</button>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>