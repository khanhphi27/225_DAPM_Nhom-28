@model List<QLTB.Models.BaoCaoTaiSanViewModel>
@{
    ViewBag.Title = "Báo Cáo Tài Sản Tổng Hợp";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Tính toán tổng số cho Dashboard
    decimal tongNguyenGia = Model.Sum(x => x.Gia);
    decimal tongSuaChua = Model.Sum(x => x.TongChiPhiSuaChua);
    decimal tongGiaTriConLai = Model.Sum(x => x.GiaTriConLai);
}

<style>
    :root {
        --primary: #4e73df;
        --success: #1cc88a;
        --warning: #f6c23e;
        --danger: #e74a3b;
    }

    body {
        background-color: #f8f9fc;
    }

    /* 1. Dashboard Cards */
    .stat-card {
        border-radius: 15px;
        border: none;
        transition: 0.3s;
        border-left: 5px solid var(--primary);
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

    .stat-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #858796;
    }

    .stat-value {
        font-size: 1.2rem;
        font-weight: 700;
        color: #5a5c69;
    }

    /* 2. Table Modernization */
    .table-container {
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 0.15rem 1.75rem rgba(58, 59, 69, 0.1);
    }

    .custom-table thead th {
        background: #f8fafc;
        color: #4e73df;
        font-size: 0.75rem;
        text-transform: uppercase;
        border: none;
    }

    .custom-table td {
        vertical-align: middle;
        font-size: 0.9rem;
        border-bottom: 1px solid #f1f5f9;
    }

    /* 3. Analysis Badge */
    .analysis-badge {
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 700;
    }

    .warning-bg {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
    }
</style>

<div class="container-fluid px-4 mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark m-0">Hệ Thống Theo Dõi & Báo Cáo Tài Chính</h3>
        <button class="btn btn-success fw-bold px-4 rounded-3" onclick="xuatExcel()">
            <i class="bi bi-file-earmark-excel me-2"></i> Xuất Báo Cáo Kiểm Toán
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card stat-card p-3" style="border-left-color: var(--primary)">
                <div class="stat-label">Tổng Nguyên Giá (Sổ sách)</div>
                <div class="stat-value text-primary">@tongNguyenGia.ToString("N0") đ</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card p-3" style="border-left-color: var(--danger)">
                <div class="stat-label">Tổng Chi Phí Bảo Trì Tích Lũy</div>
                <div class="stat-value text-danger">@tongSuaChua.ToString("N0") đ</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card p-3" style="border-left-color: var(--success)">
                <div class="stat-label">Giá Trị Tài Sản Còn Lại</div>
                <div class="stat-value text-success">@tongGiaTriConLai.ToString("N0") đ</div>
            </div>
        </div>
    </div>

    <div class="table-container">
        <div class="row g-3 mb-3">
            <div class="col-md-5">
                <input type="text" id="filterInput" class="form-control rounded-3" placeholder="Tìm tên thiết bị, số Seri hoặc mã đơn vị...">
            </div>
            <div class="col-md-3">
                <select id="filterStatus" class="form-select rounded-3">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Đang sử dụng">Đang sử dụng</option>
                    <option value="Cần bảo trì">Cần bảo trì</option>
                    <option value="Báo hỏng">Báo hỏng</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table custom-table" id="mainTable">
                <thead>
                    <tr>
                        <th>Thiết bị / Seri</th>
                        <th>Đơn vị</th>
                        <th class="text-end">Nguyên giá</th>
                        <th class="text-end">Đã chi bảo trì</th>
                        <th class="text-end">Khấu hao</th>
                        <th class="text-end">Giá trị còn lại</th>
                        <th class="text-center">Phân tích</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        // Logic cảnh báo ảnh 4: Nếu sửa > 50% giá mua
                        bool nenThanhLy = item.TongChiPhiSuaChua > (item.Gia * 0.5m);

                        <tr class="data-row" onclick="viewDetail(this)" style="cursor:pointer"
                            data-id="@item.ID_ThietBi"
                            data-ten="@item.TenTB"
                            data-seri="@(item.SoSeri ?? "Trống")"
                            data-specs="@item.ThongSoKT"
                            data-cp="@item.TongChiPhiSuaChua"
                            data-gia="@item.Gia">
                            <td>
                                <div class="fw-bold">@item.TenTB</div>
                                <div class="small text-muted">S/N: @(item.SoSeri ?? "N/A")</div>
                            </td>
                            <td><span class="badge bg-light text-dark">@item.TenPhongBanKhoa</span></td>
                            <td class="text-end fw-bold">@item.Gia.ToString("N0")</td>
                            <td class="text-end text-danger fw-bold">@item.TongChiPhiSuaChua.ToString("N0")</td>
                            <td class="text-end text-muted small">@item.KhauHao.ToString("N0")</td>
                            <td class="text-end text-success fw-bold">@item.GiaTriConLai.ToString("N0")</td>
                            <td class="text-center">
                                @if (nenThanhLy)
                                {
                                    <span class="analysis-badge warning-bg"><i class="bi bi-exclamation-triangle"></i> Nên thanh lý</span>
                                }
                                else
                                {
                                    <span class="analysis-badge bg-light text-muted">Ổn định</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 25px;">
            <div class="modal-header border-0 p-4 pb-0">
                <h5 class="fw-bold">Hồ sơ phân tích chi tiết: <span id="md-ten" class="text-primary"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-4 h-100">
                            <label class="small text-muted fw-bold text-uppercase">Cấu hình kỹ thuật</label>
                            <div id="md-specs" class="small text-dark mt-2"></div>
                            <hr>
                            <label class="small text-muted fw-bold text-uppercase">Mã hệ thống</label>
                            <div id="md-id" class="fw-bold"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 border border-2 rounded-4 h-100 d-flex flex-column justify-content-center">
                            <div class="text-center">
                                <div class="small text-muted mb-1">Tổng chi phí đã tiêu tốn</div>
                                <h3 id="md-cp" class="text-danger fw-800"></h3>
                                <div id="md-compare" class="small mt-2 px-3 py-1 rounded-pill d-inline-block"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <h6 class="fw-bold mb-3"><i class="bi bi-clock-history me-2"></i>Chi tiết các lần phát sinh chi phí:</h6>
                    <div class="border rounded-4 overflow-hidden">
                        <table class="table table-sm mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">Ngày</th>
                                    <th>Nội dung</th>
                                    <th class="text-end pe-3">Số tiền</th>
                                </tr>
                            </thead>
                            <tbody id="historyBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>
    function viewDetail(row) {
        const id = $(row).data('id');
        const giaMua = parseFloat($(row).data('gia'));
        const tongCP = parseFloat($(row).data('cp'));

        $('#md-ten').text($(row).data('ten'));
        $('#md-id').text(id);
        $('#md-specs').text($(row).data('specs') || "Chưa cập nhật thông số.");
        $('#md-cp').text(tongCP.toLocaleString('vi-VN') + ' đ');

        // Logic so sánh (Ảnh 4)
        const tile = (tongCP / giaMua) * 100;
        let compareText = `Chiếm ${tile.toFixed(1)}% nguyên giá`;
        let compareClass = tile > 50 ? "bg-danger text-white" : "bg-info text-white";
        if (tile > 50) compareText += " - KHÔNG NÊN SỬA THÊM";

        $('#md-compare').text(compareText).attr('class', 'small mt-2 px-3 py-1 rounded-pill d-inline-block ' + compareClass);

        // Load AJAX lịch sử sửa chữa
        $('#historyBody').html('<tr><td colspan="3" class="text-center py-3">Đang tải...</td></tr>');
        $.get('@Url.Action("GetLichSuSuaChua", "KHTC")', { id: id }, function(res) {
            if(res.ok && res.data.length > 0) {
                let html = "";
                res.data.forEach(h => {
                    html += `<tr>
                        <td class="ps-3">${h.Ngay}</td>
                        <td>${h.NoiDung}</td>
                        <td class="text-end pe-3 fw-bold text-danger">${Number(h.Tien).toLocaleString('vi-VN')} đ</td>
                    </tr>`;
                });
                $('#historyBody').html(html);
            } else {
                $('#historyBody').html('<tr><td colspan="3" class="text-center py-3 text-muted">Chưa có lịch sử sửa chữa.</td></tr>');
            }
        });

        new bootstrap.Modal(document.getElementById('detailModal')).show();
    }

    // Xuất báo cáo (Ảnh 6)
    function xuatExcel() {
        var rows = [["BÁO CÁO TÀI CHÍNH TÀI SẢN - NĂM @DateTime.Now.Year"]];
        rows.push(["Mã TB", "Tên TB", "Số Seri", "Đơn vị", "Nguyên giá", "Tiền bảo trì", "Giá trị còn lại"]);

        $("#mainTable tbody tr:visible").each(function() {
            var r = [];
            $(this).find("td").each(function(i) {
                if(i < 6) r.push($(this).text().trim());
            });
            rows.push(r);
        });

        var ws = XLSX.utils.aoa_to_sheet(rows);
        var wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "BaoCaoTaiChinh");
        XLSX.writeFile(wb, "Bao_Cao_Tai_San_KHTC.xlsx");
    }

    // Filter tìm kiếm
    $('#filterInput').on('keyup', function() {
        var value = $(this).val().toLowerCase();
        $("#mainTable tbody tr").filter(function() {
            $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
        });
    });
</script>