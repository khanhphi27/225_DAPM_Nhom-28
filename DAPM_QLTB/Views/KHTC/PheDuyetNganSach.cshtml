@model List<QLTB.Models.DeXuatViewModel>
@{
    ViewBag.Title = "Phê duyệt đề xuất ngân sách";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .modern-card {
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .custom-table th {
        background-color: #f8fafc;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        border-bottom: 2px solid #e2e8f0;
        padding: 15px;
    }

    .custom-table td {
        vertical-align: middle;
        padding: 15px;
        border-bottom: 1px solid #f1f5f9;
    }

    .data-row {
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .data-row:hover {
            background-color: #f0f7ff !important;
            transform: translateY(-2px);
        }

    .btn-modern {
        border-radius: 8px;
        font-weight: 500;
        padding: 6px 14px;
        transition: all 0.2s;
    }

    .inner-table {
        background: #f8fafc;
        border-radius: 12px;
        overflow: hidden;
    }

        .inner-table th {
            background: #e2e8f0;
            color: #475569;
            font-size: 0.85rem;
        }
</style>

<div class="d-flex justify-content-between align-items-center mt-3 mb-4">
    <h2 class="fw-bold text-dark" style="font-size: 1.5rem;">
        <i class="bi bi-clipboard-check-fill text-primary me-2"></i>Phê Duyệt Đề Xuất Mua Sắm
    </h2>
    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2 rounded-pill">
        @Model.Count đơn đang chờ
    </span>
</div>

<div class="card shadow-sm modern-card bg-white overflow-hidden">
    <div class="card-body p-0">
        @if (Model == null || Model.Count == 0)
        {
            <div class="text-center py-5">
                <i class="bi bi-patch-check text-success display-1"></i>
                <h4 class="mt-3 fw-bold">Hoàn tất công việc!</h4>
                <p class="text-muted">Không còn đề xuất nào cần phê duyệt lúc này.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table custom-table mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Mã Đơn</th>
                            <th>Người Đề Xuất</th>
                            <th>Ngày Gửi</th>
                            <th>Nội Dung Tóm Tắt</th>
                            <th class="text-center pe-4">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="data-row"
                                data-id="@item.ID_DeXuat"
                                data-nguoi="@item.NguoiDeXuat"
                                data-ngay="@item.NgayDeXuat.ToString("dd/MM/yyyy")"
                                data-mota="@item.MoTa">
                                <td class="ps-4">
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-2 py-1">
                                        @item.ID_DeXuat
                                    </span>
                                </td>
                                <td class="fw-bold text-dark">@item.NguoiDeXuat</td>
                                <td class="text-muted">@item.NgayDeXuat.ToString("dd/MM/yyyy")</td>
                                <td class="text-truncate" style="max-width: 300px;">@item.MoTa</td>
                                <td class="text-center pe-4">
                                    <button class="btn btn-outline-primary btn-modern btn-sm me-1 btn-view-detail" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="btn btn-success btn-modern btn-sm me-1" onclick="event.stopPropagation(); xuLy('@item.ID_DeXuat', 'duyet')">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                    <button class="btn btn-danger btn-modern btn-sm" onclick="event.stopPropagation(); xuLy('@item.ID_DeXuat', 'tuchoi')">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="modalDeXuat" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold"><i class="bi bi-file-earmark-text text-primary me-2"></i>Chi tiết Đề xuất <span id="md-id" class="text-primary"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <small class="text-muted d-block">Người yêu cầu:</small>
                        <strong id="md-nguoi" class="fs-5"></strong>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <small class="text-muted d-block">Ngày lập đơn:</small>
                        <strong id="md-ngay"></strong>
                    </div>
                </div>
                <div class="mb-4">
                    <small class="text-muted d-block mb-1">Lý do/Mô tả chung:</small>
                    <div id="md-mota" class="p-3 bg-light rounded-3 border fw-medium"></div>
                </div>
                <h6 class="fw-bold mb-3"><i class="bi bi-list-ul me-2"></i>Danh sách thiết bị yêu cầu:</h6>
                <div class="inner-table border">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th class="ps-3">Tên thiết bị</th>
                                <th>Danh mục</th>
                                <th class="text-center">SL</th>
                                <th class="text-end pe-3">Đơn giá dự kiến</th>
                            </tr>
                        </thead>
                        <tbody id="listItems"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer bg-light border-0 py-3" style="border-radius: 0 0 20px 20px;">
                <button class="btn btn-danger btn-modern px-4" id="btnReject">
                    <i class="bi bi-x-circle me-1"></i> Từ chối
                </button>
                <button class="btn btn-success btn-modern px-4" id="btnApprove">
                    <i class="bi bi-check-circle me-1"></i> Duyệt đề xuất
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        // Bắt sự kiện click vào dòng
        $(".data-row").click(function () {
            // Lấy dữ liệu từ thẻ tr thông qua data-attributes
            const id = $(this).data("id");
            const nguoi = $(this).data("nguoi");
            const ngay = $(this).data("ngay");
            const mota = $(this).data("mota");

            // Đổ vào Modal
            $('#md-id').text(id);
            $('#md-nguoi').text(nguoi);
            $('#md-ngay').text(ngay);
            $('#md-mota').text(mota);

            // Gán sự kiện cho nút Duyệt/Từ chối trong Modal
            $('#btnApprove').off().on('click', () => xuLy(id, 'duyet'));
            $('#btnReject').off().on('click', () => xuLy(id, 'tuchoi'));

            // Load chi tiết qua Ajax
            $('#listItems').html('<tr><td colspan="4" class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary"></div> Đang tải...</td></tr>');
            $.get('@Url.Action("GetDeXuatDetail", "KHTC")', { id: id }, function (res) {
                if (res.ok) {
                    let html = "";
                    if (res.data.length === 0) html = '<tr><td colspan="4" class="text-center text-muted py-3">Không có chi tiết hàng hóa</td></tr>';
                    res.data.forEach(item => {
                        html += `<tr>
                            <td class="ps-3 fw-bold">${item.Ten}</td>
                            <td class="text-muted">${item.DanhMuc}</td>
                            <td class="text-center">${item.SoLuong} ${item.DVT}</td>
                            <td class="text-end pe-3 text-primary fw-bold">${Number(item.Gia).toLocaleString('vi-VN')} đ</td>
                        </tr>`;
                    });
                    $('#listItems').html(html);
                }
            });

            // Hiện Modal (Dùng lệnh chuẩn Bootstrap 5)
            const myModal = new bootstrap.Modal(document.getElementById('modalDeXuat'));
            myModal.show();
        });
    });

    function xuLy(id, action) {
        let ghiChu = "";
        if (action === 'tuchoi') {
            ghiChu = prompt("Vui lòng nhập lý do từ chối đơn " + id + ":");
            if (!ghiChu) return;
        } else {
            if (!confirm("Duyệt đề xuất " + id + " và chuyển tiếp lên Ban Giám Hiệu?")) return;
        }

        $.post('@Url.Action("XuLyNganSach", "KHTC")', { id: id, action: action, ghiChu: ghiChu }, function (res) {
            if (res.ok) {
                alert("Đã xử lý thành công!");
                location.reload();
            } else {
                alert("Lỗi: " + res.msg);
            }
        });
    }
</script>