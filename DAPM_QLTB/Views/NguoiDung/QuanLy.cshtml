                        </button>
                        <button class="btn-icon del" title="XĂ³a" onclick="openDelete('@nd.ID_NguoiDung', '@Html.Raw(nd.HoTen.Replace("'","\\'"))')">
                            <i class="bi bi-trash3-fill"></i>
                        </button>
                    </td>
                </tr>
            }
            @if (!list.Any())
            {
                <tr><td colspan="8" style="text-align:center;color:#999;padding:30px;">ChÆ°a cĂ³ tĂ i khoáº£n nĂ o.</td></tr>
            }
        </tbody>
    </table>
</div>

<div class="modal-overlay" id="modalCreate">
    <div class="modal-box">
        <div class="modal-title">â• Táº¡o TĂ i Khoáº£n Má»›i</div>

