</div>

<div class="modal-overlay" id="modalDelete">
    <div class="modal-box" style="width:400px;">
        <div class="modal-title">đŸ—‘ï¸ XĂ¡c Nháº­n XĂ³a</div>
        <input type="hidden" id="d_id" />
        <p style="font-size:14px;color:#444;margin-bottom:20px;">
            Báº¡n cĂ³ cháº¯c muá»‘n xĂ³a tĂ i khoáº£n <strong id="d_ten"></strong>?<br>
            <span style="color:#e53935;font-size:12px;">HĂ nh Ä‘á»™ng nĂ y khĂ´ng thá»ƒ hoĂ n tĂ¡c.</span>
        </p>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeAll()">Há»§y</button>
            <button class="btn-danger" onclick="submitDelete()">đŸ—‘ï¸ XĂ³a</button>
        </div>
    </div>
</div>

@section scripts {
<script>
    function showAlert(msg, type) {
        var box = document.getElementById('alertBox');
        box.textContent = msg;
        box.className = 'alert-box ' + type;
        box.style.display = 'block';
        setTimeout(function () { box.style.display = 'none'; }, 4000);
    }

    function closeAll() {
        document.querySelectorAll('.modal-overlay').forEach(function (m) { m.classList.remove('active'); });
    }

    document.querySelectorAll('.modal-overlay').forEach(function (m) {
        m.addEventListener('click', function (e) { if (e.target === m) closeAll(); });
    });

    function applyFilter() {
        var khoa = document.getElementById('filterKhoa').value;
        var vaiTro = document.getElementById('filterVaiTro').value;
        var trangThai = document.getElementById('filterTrangThai').value;

        var rows = document.querySelectorAll('#tbodyNguoiDung tr');
        var visible = 0;

        rows.forEach(function (row) {
            var rKhoa = row.getAttribute('data-khoa') || '';
            var rVaiTro = row.getAttribute('data-vaitro') || '';
            var rTrangThai = row.getAttribute('data-trangthai') || '';

            var ok = (!khoa || rKhoa === khoa)
                  && (!vaiTro || rVaiTro === vaiTro)
                  && (!trangThai || rTrangThai === trangThai);

            row.style.display = ok ? '' : 'none';
            if (ok) visible++;
        });

        var isFiltering = khoa || vaiTro || trangThai;
        document.getElementById('lblLoc').style.display = isFiltering ? '' : 'none';
        document.getElementById('lblLocSo').textContent = visible;
    }

    function resetFilter() {
        document.getElementById('filterKhoa').value = '';
        document.getElementById('filterVaiTro').value = '';
        document.getElementById('filterTrangThai').value = '';
        applyFilter();
    }

    function openCreate() {
        document.getElementById('c_id').value = '';
        document.getElementById('c_hoTen').value = '';
        document.getElementById('c_email').value = '';
        document.getElementById('c_matKhau').value = '';
        document.getElementById('c_vaiTro').value = '';
        document.getElementById('c_khoa').value = '';
        document.getElementById('modalCreate').classList.add('active');
        setTimeout(function () { document.getElementById('c_id').focus(); }, 100);
    }

    function submitCreate() {
        var id = document.getElementById('c_id').value.trim();
        var hoTen = document.getElementById('c_hoTen').value.trim();
        var matKhau = document.getElementById('c_matKhau').value;

        if (!id) { showAlert('Vui lĂ²ng nháº­p ID ngÆ°á»i dĂ¹ng.', 'error'); return; }
        if (!hoTen) { showAlert('Vui lĂ²ng nháº­p há» tĂªn.', 'error'); return; }
        if (!matKhau) { showAlert('Vui lĂ²ng nháº­p máº­t kháº©u.', 'error'); return; }

        $.post('@Url.Action("TaoNguoiDung", "NguoiDung")', {
            id: id,
            hoTen: hoTen,
            email: document.getElementById('c_email').value,
            matKhau: matKhau,
            vaiTroNo: document.getElementById('c_vaiTro').value,
            khoaBanNo: document.getElementById('c_khoa').value
        }, function (res) {
            if (res.ok) { showAlert(res.msg, 'success'); closeAll(); setTimeout(function () { location.reload(); }, 1200); }
            else showAlert(res.msg, 'error');
        });
    }

    function openEdit(id) {
        $.get('@Url.Action("GetNguoiDung", "NguoiDung")', { id: id }, function (res) {
            if (!res.ok) { showAlert(res.msg, 'error'); return; }
            var d = res.data;
            document.getElementById('e_id').value = d.id;
            document.getElementById('e_id_display').value = d.id;
            document.getElementById('e_hoTen').value = d.hoTen;
            document.getElementById('e_email').value = d.email;
            document.getElementById('e_matKhau').value = '';
            document.getElementById('e_vaiTro').value = d.vaiTroNo;
            document.getElementById('e_khoa').value = d.khoaBanNo;
            document.getElementById('e_trangThai').value = d.trangThai ? 'true' : 'false';
            document.getElementById('modalEdit').classList.add('active');
        });
    }

    function submitEdit() {
        var hoTen = document.getElementById('e_hoTen').value.trim();
        if (!hoTen) { showAlert('Há» tĂªn khĂ´ng Ä‘Æ°á»£c Ä‘á»ƒ trá»‘ng.', 'error'); return; }

        $.post('@Url.Action("SuaNguoiDung", "NguoiDung")', {
            id: document.getElementById('e_id').value,
            hoTen: hoTen,
            email: document.getElementById('e_email').value,
            matKhauMoi: document.getElementById('e_matKhau').value,
            vaiTroNo: document.getElementById('e_vaiTro').value,
            khoaBanNo: document.getElementById('e_khoa').value,
            trangThai: document.getElementById('e_trangThai').value === 'true'
        }, function (res) {
            if (res.ok) { showAlert(res.msg, 'success'); closeAll(); setTimeout(function () { location.reload(); }, 1200); }
            else showAlert(res.msg, 'error');
        });
    }

    function openDelete(id, ten) {
        document.getElementById('d_id').value = id;
        document.getElementById('d_ten').textContent = ten;
        document.getElementById('modalDelete').classList.add('active');
    }

    function submitDelete() {
        $.post('@Url.Action("XoaNguoiDung", "NguoiDung")', {
            id: document.getElementById('d_id').value
        }, function (res) {
            if (res.ok) { showAlert('ÄĂ£ xĂ³a tĂ i khoáº£n.', 'success'); closeAll(); setTimeout(function () { location.reload(); }, 1200); }
            else showAlert(res.msg, 'error');
        });
    }
</script>
}

