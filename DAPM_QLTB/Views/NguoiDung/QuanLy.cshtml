                    <td>
                        <span class="badge-status @(nd.TrangThaiTK ? "active" : "inactive")">
                            @(nd.TrangThaiTK ? "âœ… Hoáº¡t Ä‘á»™ng" : "đŸ”’ KhĂ³a")
                        </span>
                    </td>
                    <td style="text-align:center; white-space:nowrap;">
                        <button class="btn-icon edit" title="Sá»­a" onclick="openEdit('@nd.ID_NguoiDung')">
