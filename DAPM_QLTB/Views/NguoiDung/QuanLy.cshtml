        <label class="form-lbl">ID NgÆ°á»i dĂ¹ng</label>
        <input type="text" id="e_id_display" class="form-inp" readonly style="font-family:monospace;background:#f0f2f8;color:#555;cursor:not-allowed;" />

        <label class="form-lbl">Há» vĂ  tĂªn <span style="color:red">*</span></label>
        <input type="text" id="e_hoTen" class="form-inp" />

        <label class="form-lbl">Email</label>
        <input type="email" id="e_email" class="form-inp" />

        <label class="form-lbl">Máº­t kháº©u má»›i <span style="color:#888;font-weight:400">(Ä‘á»ƒ trá»‘ng náº¿u khĂ´ng Ä‘á»•i)</span></label>
        <input type="password" id="e_matKhau" class="form-inp" placeholder="Nháº­p máº­t kháº©u má»›i..." />

        <label class="form-lbl">Vai trĂ²</label>
        <select id="e_vaiTro" class="form-inp">
            <option value="">-- ChÆ°a phĂ¢n quyá»n --</option>
            @foreach (var vt in vaiTros)
            {
                <option value="@vt.Value">@vt.Text</option>
            }
        </select>

        <label class="form-lbl">Khoa / PhĂ²ng ban</label>
        <select id="e_khoa" class="form-inp">
            <option value="">-- KhĂ´ng thuá»™c Ä‘Æ¡n vá»‹ --</option>
            @foreach (var kp in khoaList)
            {
                <option value="@kp.Value">@kp.Text</option>
            }
        </select>

        <label class="form-lbl">Tráº¡ng thĂ¡i</label>
        <select id="e_trangThai" class="form-inp">
            <option value="true">âœ… Hoáº¡t Ä‘á»™ng</option>
            <option value="false">đŸ”’ KhĂ³a</option>
        </select>

        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeAll()">Há»§y</button>
            <button class="btn-save" onclick="submitEdit()">đŸ’¾ LÆ°u thay Ä‘á»•i</button>
