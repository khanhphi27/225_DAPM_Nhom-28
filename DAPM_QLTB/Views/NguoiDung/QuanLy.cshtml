        <input type="text" id="c_id" class="form-inp" placeholder="VD: ND001" style="font-family:monospace;" />

        <label class="form-lbl">Há» vĂ  tĂªn <span style="color:red">*</span></label>
        <input type="text" id="c_hoTen" class="form-inp" placeholder="Nguyá»…n VÄƒn A" />

        <label class="form-lbl">Email</label>
        <input type="email" id="c_email" class="form-inp" placeholder="example@spkt.edu.vn" />

        <label class="form-lbl">Máº­t kháº©u <span style="color:red">*</span></label>
        <input type="password" id="c_matKhau" class="form-inp" placeholder="Nháº­p máº­t kháº©u" />

        <label class="form-lbl">Vai trĂ²</label>
        <select id="c_vaiTro" class="form-inp">
            <option value="">-- ChÆ°a phĂ¢n quyá»n --</option>
            @foreach (var vt in vaiTros)
            {
                <option value="@vt.Value">@vt.Text</option>
            }
        </select>

        <label class="form-lbl">Khoa / PhĂ²ng ban</label>
        <select id="c_khoa" class="form-inp">
            <option value="">-- KhĂ´ng thuá»™c Ä‘Æ¡n vá»‹ --</option>
